{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "dotnet build src/Pana.sln",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "dotnet test src/Pana.Tests",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "run (dev)",
            "type": "shell",
            "command": "dotnet run --project src/Pana.Api",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "ship",
            "type": "shell",
            "command": "${workspaceFolder}/ship.ps1",
            "group": {
                "kind": "build"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "qa-check",
            "type": "shell",
            "command": "dotnet build src/Pana.sln && dotnet test src/Pana.Tests",
            "group": {
                "kind": "test"
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
