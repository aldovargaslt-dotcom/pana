@* Views/Pos/_OrderConfirmation.cshtml — Post-order confirmation *@
@model Pana.Api.Application.Sales.SaleDto
@{
    var statusText = Model.Status switch
    {
        "Confirmed" => "Confirmada",
        "Delivered" => "Entregada",
        _ => Model.Status
    };
    var isPreOrder = Model.OrderType == "PreOrder";
}

<div class="p-6 text-center space-y-4 scale-in">
    @* Success icon *@
    <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto"
         style="background: color-mix(in srgb, var(--success) 15%, transparent);">
        <svg class="w-8 h-8" style="color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
    </div>

    <h3 class="text-lg font-bold" style="color: var(--fg);">¡Orden registrada!</h3>

    <div class="space-y-2 text-sm">
        <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
            <span style="color: var(--muted);">N° de orden</span>
            <span class="font-mono font-medium" style="color: var(--fg);">#@Model.Id.ToString()[..8]</span>
        </div>
        <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
            <span style="color: var(--muted);">Tipo</span>
            <span class="font-medium flex items-center gap-1.5" style="color: var(--fg);">
                @if (isPreOrder)
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span>Pre-orden</span>
                }
                else
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                    <span>En local</span>
                }
            </span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.PaymentMethod))
        {
            <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
                <span style="color: var(--muted);">Método de pago</span>
                <span class="font-medium" style="color: var(--fg);">@Model.PaymentMethod</span>
            </div>
        }
        <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
            <span style="color: var(--muted);">Estado</span>
            <span class="font-medium" style="color: var(--success);">@statusText</span>
        </div>
        <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
            <span style="color: var(--muted);">Items</span>
            <span class="font-medium" style="color: var(--fg);">@Model.Items.Count</span>
        </div>
        @if (isPreOrder && Model.ScheduledDate.HasValue)
        {
            <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
                <span style="color: var(--muted);">Entrega</span>
                <span class="font-medium" style="color: var(--fg);">@Model.ScheduledDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        }
        @if (isPreOrder && Model.DepositAmount > 0)
        {
            <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
                <span style="color: var(--muted);">Anticipo</span>
                <span class="font-medium" style="color: var(--primary);">$@Model.DepositAmount.ToString("N2")</span>
            </div>
            <div class="flex justify-between px-4 py-2 rounded-xl" style="background: var(--surface-container-low);">
                <span style="color: var(--muted);">Saldo pendiente</span>
                <span class="font-medium" style="color: var(--danger);">$@Model.BalanceDue.ToString("N2")</span>
            </div>
        }
        <div class="flex justify-between px-4 py-2 rounded-xl font-bold" style="background: var(--surface-container-low);">
            <span style="color: var(--fg);">Total</span>
            <span style="color: var(--primary);">$@Model.TotalAmount.ToString("N2")</span>
        </div>
    </div>

    <button onclick="window.location.reload()"
            class="w-full py-3 rounded-xl text-white font-bold text-sm transition-all duration-200
                   shadow-ambient hover:shadow-modal active:scale-[0.98]"
            style="background: var(--gradient-primary);">
        Nueva orden
    </button>
</div>
