@* Views/Pos/Index.cshtml — POS Menu View *@
@model Pana.Api.Web.ViewModels.PosViewModel
@{
    ViewData["Title"] = "Punto de Venta";
    var now = DateTime.Now;
    var todayName = now.ToString("dddd, d 'de' MMMM 'de' yyyy",
        new System.Globalization.CultureInfo("es-MX"));
}

<div x-data="posCart" class="flex flex-col lg:flex-row gap-0 lg:gap-5 h-[calc(100vh-5rem)] fade-in">

    @* ═══════════════════════════════════════════════════════
       MAIN PRODUCT AREA (left)
       ═══════════════════════════════════════════════════════ *@
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

        @* ── Top bar: date/time + actions ────────────────── *@
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4 flex-shrink-0">
            <div>
                <h1 class="text-3xl font-bold flex items-center gap-2" style="color: var(--fg);">
                    <span class="text-gradient">Punto de Venta</span>
                </h1>
                <p class="text-base mt-0.5" style="color: var(--muted);">@todayName</p>
            </div>
            <div class="flex items-center gap-2">
                <div class="flex items-center gap-2 text-sm rounded-lg px-4 py-2 shadow-ambient"
                     style="color: var(--meta); background: var(--surface-container-lowest);">
                    <span class="w-2.5 h-2.5 rounded-full" style="background: var(--fresh-green);" title="Activo"></span> Activo
                </div>
                <button class="inline-flex items-center gap-2 px-5 py-3 rounded-xl text-base font-medium
                               transition-all duration-200 shadow-ambient"
                        style="color: var(--fg-2); background: var(--surface-container-lowest);"
                        @@click="clearCart">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Limpiar
                </button>
            </div>
        </div>

        @* ── Category selector row ───────────────────────── *@
        <div class="flex items-center gap-3 mb-4 overflow-x-auto pb-1 flex-shrink-0" style="scrollbar-width: thin;">
            <button @@click="activeCategory = 'all'"
                    class="flex-shrink-0 px-5 py-3 rounded-xl text-base font-medium transition-all duration-200"
                    :class="activeCategory === 'all'
                        ? 'text-white shadow-ambient'
                        : ''"
                    :style="activeCategory === 'all'
                        ? 'background: var(--gradient-primary);'
                        : 'color: var(--fg-2); background: var(--surface-container-low);'">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                    Todos
                </span>
            </button>
            @foreach (var cat in Model.Categories)
            {
                <button @@click="activeCategory = '@cat.Name'"
                        class="flex-shrink-0 px-5 py-3 rounded-xl text-base font-medium transition-all duration-200 flex items-center gap-2"
                        :class="activeCategory === '@cat.Name'
                            ? 'text-white shadow-ambient'
                            : ''"
                        :style="activeCategory === '@cat.Name'
                            ? 'background: var(--gradient-primary);'
                            : 'color: var(--fg-2); background: var(--surface-container-low);'">
                    @switch (cat.Icon)
                    {
                        case "box":
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            break;
                        case "coffee":
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zm4-4h8v4H6V4z"/></svg>
                            break;
                        case "briefcase":
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            break;
                        default:
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            break;
                    }
                    <span>@cat.Name</span>
                    <span class="text-sm opacity-75">(@cat.ProductCount)</span>
                </button>
            }
        </div>

        @* ── Search bar ──────────────────────────────────── *@
        <div class="relative mb-4 flex-shrink-0">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="search" placeholder="Buscar productos..."
                   x-model="searchQuery"
                   class="w-full pl-11 pr-4 py-3.5 rounded-xl text-base
                          focus:outline-none focus:ring-2 transition-all duration-200"
                   style="background: var(--surface-container-high); color: var(--fg);"
                   onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                   onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
        </div>

        @* ── Product grid ────────────────────────────────── *@
        <div class="flex-1 overflow-y-auto pr-1" style="scrollbar-width: thin;">
            <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3" id="product-grid">
                @foreach (var product in Model.Products)
                {
                    <div class="product-card rounded-2xl p-5 shadow-ambient cursor-pointer transition-all duration-200
                                hover:shadow-modal hover:-translate-y-0.5 group"
                         style="background: var(--surface-container-lowest);"
                         x-data="{ cat: '@product.ProductType', customQty: 1 }"
                         x-show="(activeCategory === 'all' || categoryLabel(activeCategory) === '@product.ProductType')
                                  && (!searchQuery || '@product.Name.ToLower()'.includes(searchQuery.toLowerCase())
                                      || '@(product.Sku?.ToLower() ?? "")'.includes(searchQuery.toLowerCase()))"
                         x-transition.duration.200ms
                         @@click="$dispatch('add-to-cart-item', { productId: '@product.Id', productName: '@(product.Name.Replace("'","\\'"))', unitPrice: @product.Price })">
                        @* Product image fallback *@
                        <div class="w-full aspect-[4/3] rounded-xl mb-3 flex items-center justify-center relative"
                             style="background: var(--surface-container-low);">
                            <svg class="w-10 h-10" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                            </svg>
                            @* Info button (opens detail modal) *@
                            <button @@click.stop
                                    hx-get="/pos/product/@product.Id"
                                    hx-target="#modal-container"
                                    hx-swap="innerHTML"
                                    class="absolute top-2 right-2 w-7 h-7 rounded-lg flex items-center justify-center
                                           opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                                    style="background: var(--surface-container-lowest); color: var(--meta); box-shadow: var(--elev-ambient);"
                                    title="Ver detalle">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </button>
                        </div>

                        <h3 class="font-semibold text-base mb-1 line-clamp-1" style="color: var(--fg);">@product.Name</h3>
                        <p class="text-sm mb-2" style="color: var(--muted);">@product.ProductType</p>

                        <div class="flex items-center justify-between mb-3">
                            <span class="font-bold text-lg" style="color: var(--primary);">
                                $@product.Price.ToString("N2")
                            </span>
                            <span class="w-3 h-3 rounded-full" style="background: var(--fresh-green);" title="Disponible"></span>
                        </div>

                        @* Quantity presets ────────────────────────────────── *@
                        <div class="flex items-center gap-1.5" @@click.stop>
                            <button @@click="$dispatch('add-to-cart-item', { productId: '@product.Id', productName: '@(product.Name.Replace("'","\\'"))', unitPrice: @product.Price, qty: 5 })"
                                    class="flex-1 py-1.5 rounded-lg text-xs font-semibold transition-all duration-150
                                           opacity-0 group-hover:opacity-100 hover:shadow-sm active:scale-95"
                                    style="color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 8%, transparent);">
                                +5
                            </button>
                            <button @@click="$dispatch('add-to-cart-item', { productId: '@product.Id', productName: '@(product.Name.Replace("'","\\'"))', unitPrice: @product.Price, qty: 10 })"
                                    class="flex-1 py-1.5 rounded-lg text-xs font-semibold transition-all duration-150
                                           opacity-0 group-hover:opacity-100 hover:shadow-sm active:scale-95"
                                    style="color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 8%, transparent);">
                                +10
                            </button>
                            <div class="flex items-center gap-1 flex-1">
                                <input type="number" x-model="customQty" min="1" placeholder="1"
                                       class="w-full px-1.5 py-1.5 rounded-lg text-xs text-center font-medium border-0
                                              opacity-0 group-hover:opacity-100 transition-all duration-150
                                              focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 15%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                                <button @@click="$dispatch('add-to-cart-item', { productId: '@product.Id', productName: '@(product.Name.Replace("'","\\'"))', unitPrice: @product.Price, qty: customQty || 1 }); customQty = 1"
                                        class="shrink-0 px-2 py-1.5 rounded-lg text-xs font-bold transition-all duration-150
                                               opacity-0 group-hover:opacity-100 hover:shadow-sm active:scale-95"
                                        style="color: var(--primary); background: color-mix(in srgb, var(--primary) 8%, transparent);">
                                    +
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Empty state *@
            <div x-show="filteredCount === 0" x-cloak class="text-center py-16">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                     style="background: var(--surface-container);">
                    <svg class="w-8 h-8" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
                <p class="font-medium" style="color: var(--meta);">No se encontraron productos</p>
                <p class="text-xs mt-1" style="color: var(--meta);">Intentá con otra búsqueda o categoría</p>
            </div>
        </div>

        @* ── Bottom track-order strip ────────────────────── *@
        <div class="flex-shrink-0 mt-3 pt-3" style="border-top: 1px solid var(--surface-container-low);">
            <div class="flex items-center gap-3 overflow-x-auto" style="scrollbar-width: thin;">
                <template x-for="(item, idx) in cart" :key="idx">
                    <div class="flex-shrink-0 flex items-center gap-2 px-3 py-2 rounded-xl shadow-ambient"
                         style="background: var(--surface-container-lowest);">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                             style="background: var(--surface-container);">
                            <svg class="w-4 h-4" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <div class="min-w-0">
                            <p class="text-xs font-medium truncate" style="color: var(--fg);" x-text="item.productName"></p>
                            <p class="text-xs" style="color: var(--muted);" x-text="'x' + item.quantity + ' · $' + ((item.unitPrice || 0) * (item.quantity || 0)).toFixed(2)"></p>
                        </div>
                        <button @@click.stop="removeFromCart(idx)" class="flex-shrink-0 p-1 rounded-lg hover:bg-red-50 transition-colors"
                                style="color: var(--danger);">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>
                </template>
                <div x-show="cart.length === 0" class="text-xs" style="color: var(--meta);">
                    Sin productos en la orden
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════
       ORDER PANEL (right sidebar)
       ═══════════════════════════════════════════════════════ *@
    <div id="order-panel"
         class="w-full max-w-sm flex-shrink-0 rounded-2xl shadow-modal flex flex-col overflow-hidden"
         style="background: var(--surface-container-lowest);"
         x-on:add-to-cart-item.document="addToCartQty($event.detail.productId, $event.detail.productName, $event.detail.unitPrice, $event.detail.qty || 1)">

        @* Order header *@
        <div class="p-4" style="border-bottom: 1px solid var(--surface-container-low);">
            <h2 class="font-bold text-xl flex items-center gap-2" style="color: var(--fg);">
                <svg class="w-6 h-6" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Orden actual
            </h2>
            <div class="flex items-center gap-2 mt-2">
                <span class="text-sm px-3 py-1.5 rounded-full font-medium"
                      style="background: var(--surface-container-low); color: var(--fg-2);">
                    <span x-text="cart.length"></span> items
                </span>
            </div>
        </div>

        @* Order type selector *@
        <div class="px-4 py-2 flex gap-2" style="border-bottom: 1px solid var(--surface-container-low);">
            <button @@click="orderType = 'Standard'"
                    class="flex-1 py-3 rounded-xl text-base font-medium transition-all duration-200 flex items-center justify-center gap-2"
                    :class="orderType === 'Standard'
                        ? 'text-white'
                        : ''"
                    :style="orderType === 'Standard'
                        ? 'background: var(--gradient-primary);'
                        : 'color: var(--fg-2); background: var(--surface-container-low);'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                En local
            </button>
            <button @@click="orderType = 'PreOrder'"
                    class="flex-1 py-3 rounded-xl text-base font-medium transition-all duration-200 flex items-center justify-center gap-2"
                    :class="orderType === 'PreOrder'
                        ? 'text-white'
                        : ''"
                    :style="orderType === 'PreOrder'
                        ? 'background: var(--gradient-primary);'
                        : 'color: var(--fg-2); background: var(--surface-container-low);'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Pre-orden
            </button>
        </div>

        @* Pre-order fields (visible when PreOrder is selected) *@
        <div x-show="orderType === 'PreOrder'" x-transition.duration.200ms
             class="px-4 py-3 space-y-2 rounded-b-2xl" style="background: var(--surface-container);">
            <div class="grid grid-cols-2 gap-2">
                <div>
                    <label class="text-[10px] font-semibold uppercase tracking-wider block mb-0.5" style="color: var(--muted);">Cliente</label>
                    <input type="text" x-model="customerName" placeholder="Nombre del cliente"
                           class="w-full px-2.5 py-1.5 rounded-lg text-xs border-0
                                  focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                </div>
                <div>
                    <label class="text-[10px] font-semibold uppercase tracking-wider block mb-0.5" style="color: var(--muted);">Teléfono</label>
                    <input type="text" x-model="customerPhone" placeholder="Teléfono"
                           class="w-full px-2.5 py-1.5 rounded-lg text-xs border-0
                                  focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-2">
                <div>
                    <label class="text-[10px] font-semibold uppercase tracking-wider block mb-0.5" style="color: var(--muted);">Entrega / Pickup</label>
                    <input type="datetime-local" x-model="scheduledDate"
                           class="w-full px-2.5 py-1.5 rounded-lg text-xs border-0
                                  focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                </div>
                <div>
                    <label class="text-[10px] font-semibold uppercase tracking-wider block mb-0.5" style="color: var(--muted);">Anticipo</label>
                    <input type="number" x-model="depositAmount" placeholder="0.00" step="0.01" min="0"
                           class="w-full px-2.5 py-1.5 rounded-lg text-xs border-0
                                  focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                </div>
            </div>
            <div>
                <label class="text-[10px] font-semibold uppercase tracking-wider block mb-0.5" style="color: var(--muted);">Notas internas</label>
                <textarea x-model="internalNotes" rows="2" placeholder="Notas para producción..."
                          class="w-full px-2.5 py-1.5 rounded-lg text-xs border-0 resize-none
                                 focus:outline-none focus:ring-2 transition-all duration-200"
                          style="background: var(--surface-container-high); color: var(--fg);"
                          onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                          onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"></textarea>
            </div>
        </div>

        @* Order items list (scrollable) *@
        <div class="flex-1 overflow-y-auto p-4" style="scrollbar-width: thin;" id="order-items-list">
            <template x-for="(item, idx) in cart" :key="idx">
                <div class="flex items-center gap-3 py-3" style="border-bottom: 1px solid var(--surface-container-low);">
                    @* Item thumbnail *@
                    <div class="w-10 h-10 rounded-lg flex-shrink-0 flex items-center justify-center"
                         style="background: var(--surface-container-low);">
                        <svg class="w-5 h-5" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>

                    @* Item info *@
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium truncate" style="color: var(--fg);" x-text="item.productName"></p>
                        <p class="text-xs" style="color: var(--muted);" x-text="'$' + (item.unitPrice || 0).toFixed(2)"></p>
                    </div>

                    @* Quantity controls *@
                    <div class="flex items-center gap-2">
                        <button @@click="decrementItem(idx)"
                                class="w-10 h-10 rounded-xl flex items-center justify-center text-lg font-bold transition-colors"
                                style="color: var(--fg-2); background: var(--surface-container-low);"
                                :disabled="item.quantity <= 1">−</button>
                        <span class="w-8 text-center text-base font-semibold" style="color: var(--fg);" x-text="item.quantity"></span>
                        <button @@click="incrementItem(idx)"
                                class="w-10 h-10 rounded-xl flex items-center justify-center text-lg font-bold transition-colors"
                                style="color: var(--fg-2); background: var(--surface-container-low);">+</button>
                    </div>

                    @* Line total + remove *@
                    <div class="text-right flex-shrink-0">
                        <p class="text-base font-semibold" style="color: var(--fg);" x-text="'$' + ((item.unitPrice || 0) * (item.quantity || 0)).toFixed(2)"></p>
                        <button @@click="removeFromCart(idx)" class="text-sm mt-0.5 hover:underline" style="color: var(--danger);">Quitar</button>
                    </div>
                </div>
            </template>

            @* Empty order state *@
            <div x-show="cart.length === 0" class="text-center py-12">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                     style="background: var(--surface-container);">
                    <svg class="w-8 h-8" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                </div>
                <p class="font-medium" style="color: var(--meta);">Orden vacía</p>
                <p class="text-xs mt-1" style="color: var(--meta);">Seleccioná productos del menú para comenzar</p>
            </div>
        </div>

        @* Order summary + actions (sticky bottom) *@
        <div class="p-4 space-y-3 flex-shrink-0" style="border-top: 1px solid var(--surface-container-low); background: var(--surface-container-lowest);">
            @* Summary lines *@
            <div class="space-y-1.5 text-sm">
                <div class="flex justify-between">
                    <span style="color: var(--muted);">Subtotal</span>
                    <span style="color: var(--fg);" x-text="'$' + subtotal.toFixed(2)"></span>
                </div>
                <div class="flex justify-between">
                    <span style="color: var(--muted);">IVA (16%)</span>
                    <span style="color: var(--fg);" x-text="'$' + tax.toFixed(2)"></span>
                </div>
                <div class="flex justify-between" x-show="discount > 0">
                    <span style="color: var(--success);">Descuento</span>
                    <span style="color: var(--success);" x-text="'-$' + discount.toFixed(2)"></span>
                </div>
                <div class="flex justify-between font-bold text-lg pt-2" style="border-top: 1px solid var(--surface-container-low);">
                    <span style="color: var(--fg);">Total</span>
                    <span style="color: var(--primary);" x-text="'$' + total.toFixed(2)"></span>
                </div>
            </div>

            @* Promo/voucher field *@
            <div class="relative">
                <input type="text" placeholder="Código de promoción..."
                       x-model="promoCode"
                       class="w-full pl-3 pr-20 py-3 rounded-xl text-sm
                              focus:outline-none focus:ring-2 transition-all duration-200"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                <button class="absolute right-1.5 top-1/2 -translate-y-1/2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors"
                        style="color: var(--primary);"
                        @@click="applyPromo"
                        :disabled="!promoCode">Aplicar</button>
            </div>

            @* Payment method *@
            <div class="flex gap-2">
                <button @@click="paymentMethod = 'Efectivo'"
                        class="flex-1 py-3 rounded-xl text-sm font-medium transition-all duration-200 flex items-center justify-center gap-1.5"
                        :class="paymentMethod === 'Efectivo' ? 'text-white' : ''"
                        :style="paymentMethod === 'Efectivo'
                            ? 'background: var(--gradient-primary);'
                            : 'color: var(--fg-2); background: var(--surface-container-low);'">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    Efectivo
                </button>
                <button @@click="paymentMethod = 'Tarjeta'"
                        class="flex-1 py-3 rounded-xl text-sm font-medium transition-all duration-200 flex items-center justify-center gap-1.5"
                        :class="paymentMethod === 'Tarjeta' ? 'text-white' : ''"
                        :style="paymentMethod === 'Tarjeta'
                            ? 'background: var(--gradient-primary);'
                            : 'color: var(--fg-2); background: var(--surface-container-low);'">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                    Tarjeta
                </button>
                <button @@click="paymentMethod = 'Transferencia'"
                        class="flex-1 py-3 rounded-xl text-sm font-medium transition-all duration-200 flex items-center justify-center gap-1.5"
                        :class="paymentMethod === 'Transferencia' ? 'text-white' : ''"
                        :style="paymentMethod === 'Transferencia'
                            ? 'background: var(--gradient-primary);'
                            : 'color: var(--fg-2); background: var(--surface-container-low);'">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    Transf.
                </button>
            </div>

            @* Place order button *@
            <button @@click="placeOrder"
                    :disabled="cart.length === 0"
                    class="w-full py-4 rounded-xl text-white font-bold text-lg transition-all duration-200
                           shadow-ambient hover:shadow-modal active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
                    style="background: var(--gradient-primary);">
                <span x-show="cart.length > 0">Cobrar <span x-text="'$' + total.toFixed(2)"></span></span>
                <span x-show="cart.length === 0">Agregá productos</span>
            </button>
        </div>
    </div>

    @* ── Hidden form for HTMX POST (inside posCart scope) ────── *@
    <form id="place-order-form" method="post" action="/pos/place-order" style="display:none;"
          hx-post="/pos/place-order" hx-target="#order-panel" hx-swap="innerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" name="OrderType" x-bind:value="orderType" />
        <input type="hidden" name="PaymentMethod" x-bind:value="paymentMethod" />
        <input type="hidden" name="Notes" x-bind:value="orderNotes" />
        <input type="hidden" name="CustomerName" x-bind:value="customerName" />
        <input type="hidden" name="CustomerPhone" x-bind:value="customerPhone" />
        <input type="hidden" name="ScheduledDate" x-bind:value="scheduledDate" />
        <input type="hidden" name="DepositAmount" x-bind:value="depositAmount" />
        <input type="hidden" name="InternalNotes" x-bind:value="internalNotes" />
        <template x-for="(item, idx) in cart" :key="idx">
            <div>
                <input type="hidden" :name="'Items[' + idx + '].ProductId'" :value="item.productId" />
                <input type="hidden" :name="'Items[' + idx + '].UnitPrice'" :value="item.unitPrice" />
                <input type="hidden" :name="'Items[' + idx + '].Quantity'" :value="item.quantity" />
            </div>
        </template>
    </form>

    @* ── Cash Payment Modal ──────────────────────────────────── *@
    <div x-show="showCashModal" x-cloak
         class="fixed inset-0 z-50 flex items-center justify-center"
         style="background: rgba(28,28,25,0.4); backdrop-filter: blur(4px);"
         @@click.self="showCashModal = false; resetBills()">
        <div class="rounded-3xl shadow-modal overflow-hidden scale-in"
             style="max-width: 480px; width: 94vw; background: var(--surface-container-lowest);"
             @@click.stop="">

            @* ── Header ───────────────────────────────────────── *@
            <div class="px-6 py-4 flex items-center justify-between"
                 style="background: var(--surface-container-low);">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                         style="background: color-mix(in srgb, var(--success) 15%, transparent); color: var(--success);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold" style="color: var(--fg);">Cobro en efectivo</h3>
                        <p class="text-xs" style="color: var(--meta);">Seleccioná los billetes recibidos</p>
                    </div>
                </div>
                <button @@click="showCashModal = false"
                        class="w-8 h-8 rounded-xl flex items-center justify-center transition-colors"
                        style="color: var(--meta);"
                        onmouseover="this.style.background='var(--surface-container)'"
                        onmouseout="this.style.background='transparent'">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            @* ── Total to pay ─────────────────────────────────── *@
            <div class="px-6 py-4 text-center" style="background: var(--surface-container-lowest);">
                <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--muted);">Total a cobrar</p>
                <p class="text-4xl font-extrabold tabular-nums" style="color: var(--primary);"
                   x-text="'$' + total.toFixed(2)"></p>
            </div>

            @* ── Bill buttons grid ────────────────────────────── *@
            <div class="px-6 pb-2">
                <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--muted);">Billetes recibidos</p>
                <div class="grid grid-cols-3 gap-2">
                    <template x-for="bill in bills" :key="bill.value">
                        <button @@click="addBill(bill.value)"
                                class="flex flex-col items-center gap-1 py-3 px-2 rounded-2xl transition-all duration-150
                                       hover:shadow-ambient hover:-translate-y-0.5 active:scale-95"
                                style="background: var(--surface-container-low);">
                            @* Bill illustration *@
                            <div class="w-full aspect-[2.6/1] rounded-lg flex items-center justify-center relative overflow-hidden mb-0.5"
                                 :style="'background: linear-gradient(135deg, ' + bill.gradient + ');'">
                                <span class="text-white font-extrabold drop-shadow-sm"
                                      :style="'font-size: ' + (bill.value >= 500 ? '0.9rem' : bill.value >= 100 ? '1rem' : '1.15rem') + ';'"
                                      x-text="'$' + bill.value"></span>
                                @* Decorative corners *@
                                <span class="absolute top-1 left-1.5 text-[8px] font-bold opacity-40 text-white" x-text="bill.value"></span>
                                <span class="absolute bottom-1 right-1.5 text-[8px] font-bold opacity-40 text-white" x-text="bill.value"></span>
                            </div>
                            <span class="text-xs font-bold" style="color: var(--fg-2);" x-text="'$' + bill.value"></span>
                        </button>
                    </template>
                </div>
            </div>

            @* ── Received / Change display ────────────────────── *@
            <div class="px-6 py-3 space-y-2">
                <div class="flex items-center justify-between py-2 px-4 rounded-xl"
                     style="background: var(--surface-container-low);">
                    <span class="text-sm font-medium" style="color: var(--fg-2);">Recibido</span>
                    <span class="text-xl font-bold tabular-nums" style="color: var(--fg);"
                          x-text="'$' + cashReceived.toFixed(2)"></span>
                </div>
                <div class="flex items-center justify-between py-2 px-4 rounded-xl"
                     :style="cashChange >= 0
                         ? 'background: color-mix(in srgb, var(--success) 10%, transparent);'
                         : 'background: color-mix(in srgb, var(--danger) 8%, transparent);'">
                    <span class="text-sm font-medium"
                          :style="cashChange >= 0 ? 'color: var(--success);' : 'color: var(--danger);'"
                          x-text="cashChange >= 0 ? 'Cambio a devolver' : 'Faltante'"></span>
                    <span class="text-xl font-bold tabular-nums"
                          :style="cashChange >= 0 ? 'color: var(--success);' : 'color: var(--danger);'"
                          x-text="cashChange >= 0 ? '$' + cashChange.toFixed(2) : '$' + Math.abs(cashChange).toFixed(2)"></span>
                </div>
            </div>

            @* ── Action buttons ───────────────────────────────── *@
            <div class="px-6 pb-6 pt-2 flex gap-3">
                <button @@click="resetBills(); showCashModal = false"
                        class="flex-1 py-3 rounded-xl text-sm font-semibold transition-all duration-200"
                        style="color: var(--fg-2); background: var(--surface-container-low);">
                    Cancelar
                </button>
                <button @@click="showCashModal = false; resetBills(); submitOrder()"
                        :disabled="cashReceived < total"
                        class="flex-[2] py-3 rounded-xl text-white font-bold transition-all duration-200
                               shadow-ambient hover:shadow-modal active:scale-[0.98]
                               disabled:opacity-40 disabled:cursor-not-allowed"
                        style="background: var(--gradient-primary);">
                    <span x-show="cashReceived >= total">Confirmar cobro</span>
                    <span x-show="cashReceived < total" class="inline-flex items-center gap-2">
                        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        Esperando pago
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('alpine:init', () => {
    // ── productDetailCart — modal add-to-cart component ──
    Alpine.data('productDetailCart', (productId, productName, unitPrice) => ({
        qty: 1,
        notes: '',
        get total() {
            return this.qty * unitPrice;
        },
        addAndClose() {
            for (let i = 0; i < this.qty; i++) {
                window.dispatchEvent(new CustomEvent('add-to-cart', {
                    detail: { productId, productName, unitPrice }
                }));
            }
            const overlay = document.querySelector('.modal-overlay');
            if (overlay) overlay.remove();
        }
    }));

    Alpine.data('posCart', () => ({
        cart: [],
        activeCategory: 'all',
        searchQuery: '',
        orderType: 'Standard',
        paymentMethod: 'Efectivo',
        promoCode: '',
        orderNotes: '',
        discount: 0,
        // Pre-order fields
        customerName: '',
        customerPhone: '',
        scheduledDate: '',
        depositAmount: 0,
        internalNotes: '',
        showCashModal: false,
        cashReceived: 0,

        bills: [
            { value: 10,  gradient: '#a07020, #c8962e' },
            { value: 20,  gradient: '#3a5fc8, #5b7fe0' },
            { value: 50,  gradient: '#c44b6b, #e8658a' },
            { value: 100, gradient: '#c8903e, #e0b860' },
            { value: 200, gradient: '#2d8c4a, #3db860' },
            { value: 500, gradient: '#5c3d8c, #7e5db0' },
        ],

        get cashChange() {
            return this.cashReceived - this.total;
        },

        get subtotal() {
            return this.cart.reduce((sum, item) => sum + (item.unitPrice * item.quantity), 0);
        },
        get tax() {
            return this.subtotal * 0.16;
        },
        get total() {
            return this.subtotal + this.tax - this.discount;
        },

        get filteredCount() {
            return 1;
        },

        categoryLabel(catName) {
            const map = {
                'Productos': 'Storable',
                'Consumibles': 'Consumable',
                'Servicios': 'Service'
            };
            return map[catName] || catName;
        },

        addToCart(productId, productName, unitPrice) {
            const existing = this.cart.find(i => i.productId === productId);
            if (existing) {
                existing.quantity++;
            } else {
                this.cart.push({
                    productId: productId,
                    productName: productName,
                    unitPrice: unitPrice,
                    quantity: 1
                });
            }
        },

        addToCartQty(productId, productName, unitPrice, qty) {
            const q = Math.max(1, parseInt(qty) || 1);
            const existing = this.cart.find(i => i.productId === productId);
            if (existing) {
                existing.quantity += q;
            } else {
                this.cart.push({
                    productId: productId,
                    productName: productName,
                    unitPrice: unitPrice,
                    quantity: q
                });
            }
        },

        removeFromCart(idx) {
            this.cart.splice(idx, 1);
        },

        incrementItem(idx) {
            this.cart[idx].quantity++;
        },

        decrementItem(idx) {
            if (this.cart[idx].quantity > 1) {
                this.cart[idx].quantity--;
            } else {
                this.removeFromCart(idx);
            }
        },

        clearCart() {
            if (this.cart.length > 0 && confirm('¿Limpiar la orden actual?')) {
                this.cart = [];
                this.discount = 0;
                this.promoCode = '';
                this.customerName = '';
                this.customerPhone = '';
                this.scheduledDate = '';
                this.depositAmount = 0;
                this.internalNotes = '';
            }
        },

        applyPromo() {
            if (this.promoCode.toLowerCase() === 'pana10') {
                this.discount = this.subtotal * 0.10;
                alert('¡Promoción aplicada! 10% de descuento.');
            } else {
                this.discount = 0;
                alert('Código no válido.');
            }
        },

        placeOrder() {
            if (this.cart.length === 0) return;
            if (this.orderType === 'PreOrder' && !this.customerName) {
                alert('Ingresá el nombre del cliente para la pre-orden.');
                return;
            }
            // Intercept cash payments — show bill calculator modal
            if (this.paymentMethod === 'Efectivo') {
                this.cashReceived = 0;
                this.showCashModal = true;
                return;
            }
            this.submitOrder();
        },

        submitOrder() {
            const form = document.getElementById('place-order-form');
            form.querySelector('[name="OrderType"]').value = this.orderType;
            form.querySelector('[name="PaymentMethod"]').value = this.paymentMethod;
            form.querySelector('[name="Notes"]').value = this.orderNotes;
            form.querySelector('[name="CustomerName"]').value = this.customerName;
            form.querySelector('[name="CustomerPhone"]').value = this.customerPhone;
            form.querySelector('[name="ScheduledDate"]').value = this.scheduledDate;
            form.querySelector('[name="DepositAmount"]').value = this.depositAmount;
            form.querySelector('[name="InternalNotes"]').value = this.internalNotes;
            const container = form.querySelector('template').parentElement;
            const existingInputs = container.querySelectorAll('div:not(:first-child)');
            existingInputs.forEach(el => el.remove());
            this.cart.forEach((item, idx) => {
                const div = document.createElement('div');
                div.innerHTML = `
                    <input type="hidden" name="Items[${idx}].ProductId" value="${item.productId}" />
                    <input type="hidden" name="Items[${idx}].UnitPrice" value="${item.unitPrice}" />
                    <input type="hidden" name="Items[${idx}].Quantity" value="${item.quantity}" />
                `;
                container.appendChild(div);
            });
            htmx.trigger(form, 'submit');
        },

        addBill(value) {
            this.cashReceived += value;
        },

        resetBills() {
            this.cashReceived = 0;
        },

        init() {
            window.addEventListener('add-to-cart', (e) => {
                this.addToCart(e.detail.productId, e.detail.productName, e.detail.unitPrice);
            });
        }
    }));
});
</script>
}
