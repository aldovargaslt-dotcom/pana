@model Pana.Api.Application.Operations.DailyProductionDto?
@{
    ViewData["Title"] = "Producción Diaria";
    var products = ViewBag.Products as List<dynamic> ?? new List<dynamic>();
}

<div class="content-area space-y-5">

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Producción Diaria</span>
            </h1>
            <p class="text-sm mt-1" style="color: var(--muted);">
                @DateTime.Now.ToString("dddd, d 'de' MMMM", new System.Globalization.CultureInfo("es-MX"))
                @if (Model?.IsClosed == true)
                {
                    <span class="font-medium ml-2" style="color: var(--success);">· Día cerrado</span>
                }
            </p>
        </div>
        <div class="flex items-center gap-3">
            @if (Model?.IsClosed != true)
            {
                <button onclick="addProductionRow()"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-white text-sm font-medium rounded-xl
                               transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                        style="background: var(--gradient-primary);">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Agregar producto
                </button>
                <button type="button"
                        onclick="window.dispatchEvent(new CustomEvent('pana-modal:open',{detail:{id:'closeDayModal'}}))"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-white text-sm font-medium rounded-xl
                               transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                        style="background: var(--danger);">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Cerrar día
                </button>
            }
        </div>
    </div>

    @if (Model?.IsClosed == true)
    {
        <div class="rounded-2xl p-6 text-center shadow-ambient"
             style="background: color-mix(in srgb, var(--success) 8%, var(--surface-container-lowest));">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-3"
                 style="background: color-mix(in srgb, var(--success) 20%, transparent);">
                <svg class="w-7 h-7" style="color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h2 class="text-lg font-semibold" style="color: var(--fg);">Día cerrado</h2>
            <p class="text-sm mt-1" style="color: var(--fg-2);">La producción de hoy ya fue registrada y el inventario actualizado.</p>
        </div>
        @if (Model.Lines.Count > 0)
        {
            <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="background: var(--surface-container-low);">
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase" style="color: var(--muted);">Producto</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase" style="color: var(--muted);">Inicial</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase" style="color: var(--muted);">Producción</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase" style="color: var(--muted);">Devolución</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase" style="color: var(--muted);">Disponible</th>
                        </tr>
                    </thead>
                    <tbody class="table-tonal">
                        @foreach (var line in Model.Lines)
                        {
                            <tr>
                                <td class="px-6 py-3 font-medium" style="color: var(--fg);">@line.ProductName</td>
                                <td class="px-6 py-3 text-right" style="color: var(--fg-2);">@line.Inicial</td>
                                <td class="px-6 py-3 text-right" style="color: var(--fg-2);">@line.Produccion</td>
                                <td class="px-6 py-3 text-right" style="color: var(--danger);">@line.Devolucion</td>
                                <td class="px-6 py-3 text-right font-semibold" style="color: var(--fg);">@line.Disponible</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <form method="post" action="/production/upsert" id="production-form"
              class="rounded-2xl shadow-ambient p-6 space-y-4" style="background: var(--surface-container-lowest);">
            <div id="production-rows" class="space-y-3">
                @if (Model?.Lines != null)
                {
                    for (int i = 0; i < Model.Lines.Count; i++)
                    {
                        var line = Model.Lines[i];
                        <div class="production-row flex items-end gap-3 p-4 rounded-xl" style="background: var(--surface-container-low);">
                            <div class="flex-1">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producto</label>
                            <div x-data="panaSelect" class="pana-select-wrapper">
                                <select x-ref="native" name="lines[@i].ProductId" class="sr-only">
                                    @foreach (var p in products!)
                                    {
                                        <option value="@p.Id" selected="@(p.Id == line.ProductId)">@p.Name</option>
                                    }
                                </select>
                                <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                        class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                                    <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                                    <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                                </button>
                                <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                                     class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                                    <div class="pana-select-search">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                        <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                                    </div>
                                    <div x-ref="optionsList" class="pana-select-options">
                                        <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                            <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                                 @@mouseenter="highlightIndex = i" tabindex="0"
                                                 class="pana-select-option"
                                                 :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                                <span x-text="opt.label"></span>
                                                <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                            </div>
                                        </template>
                                        <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                                    </div>
                                </div>
                            </div>
                            </div>
                            <div class="w-24">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Inicial</label>
                                <input type="number" name="lines[@i].Inicial" value="@line.Inicial" min="0" step="0.01"
                                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                            </div>
                            <div class="w-24">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producción</label>
                                <input type="number" name="lines[@i].Produccion" value="@line.Produccion" min="0" step="0.01"
                                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                            </div>
                            <div class="w-24">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Devolución</label>
                                <input type="number" name="lines[@i].Devolucion" value="@line.Devolucion" min="0" step="0.01"
                                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                            </div>
                            <button type="button" onclick="this.closest('.production-row').remove()"
                                    class="p-2.5 rounded-xl transition-colors"
                                    style="color: var(--meta);"
                                    onmouseover="this.style.color='var(--danger)'; this.style.background='color-mix(in srgb, var(--danger) 12%, transparent)'"
                                    onmouseout="this.style.color='var(--meta)'; this.style.background='transparent'" title="Quitar">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </button>
                        </div>
                    }
                }
            </div>

            <div class="flex items-center justify-end gap-3 pt-3" style="background: var(--surface-container-low); margin: 0 -1.5rem -1.5rem; padding: 0.75rem 1.5rem; border-radius: 0 0 16px 16px;">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-semibold rounded-xl
                               transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                        style="background: var(--gradient-primary);">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Guardar producción
                </button>
            </div>
        </form>
    }
</div>

@* ── Close Day Confirmation Modal ──────────────────────────── *@
<div x-data="panaModal('closeDayModal')" x-show="open" x-transition.opacity.duration.200ms class="pana-modal-backdrop" @@click.self="close" @@keydown.escape.window="close" aria-modal="true" role="dialog">
<div class="pana-modal-panel p-6 space-y-5 text-center" @@click.stop x-transition.scale.origin.top.duration.200ms>
<div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto" style="background:color-mix(in srgb,var(--danger) 12%,transparent)"><svg class="w-7 h-7" style="color:var(--danger)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L2.73 16.5C1.96 17.333 2.922 19 4.462 19z"/></svg></div>
<div><h3 class="text-lg font-semibold" style="color:var(--fg)">¿Cerrar el día?</h3><p class="text-sm mt-2" style="color:var(--fg-2)">Se actualizará el inventario con la producción y devoluciones registradas. <strong>Esta acción no se puede deshacer.</strong></p></div>
<div class="flex gap-3"><button type="button" @@click="close" class="flex-1 px-4 py-3 rounded-xl text-sm font-medium transition-all" style="background:var(--surface-container-high);color:var(--fg-2)">Cancelar</button><form method="post" action="/production/close" class="flex-1">@Html.AntiForgeryToken()<button type="submit" class="w-full px-4 py-3 rounded-xl text-sm font-semibold text-white transition-all shadow-ambient active:scale-[0.98]" style="background:var(--danger)">Confirmar cierre</button></form></div>
</div>
</div>

@if (Model?.IsClosed != true)
{
    <template id="production-row-template">
        <div class="production-row flex items-end gap-3 p-4 rounded-xl" style="background: var(--surface-container-low);">
            <div class="flex-1">
                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producto</label>
            <div x-data="panaSelect" class="pana-select-wrapper">
                <select x-ref="native" name="lines[IDX].ProductId" class="sr-only">
                    @foreach (var p in products!)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
                <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                        class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                    <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                    <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                </button>
                <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                     class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                    <div class="pana-select-search">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                        <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                    </div>
                    <div x-ref="optionsList" class="pana-select-options">
                        <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                            <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                 @@mouseenter="highlightIndex = i" tabindex="0"
                                 class="pana-select-option"
                                 :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                <span x-text="opt.label"></span>
                                <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            </div>
                        </template>
                        <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                    </div>
                </div>
            </div>
            </div>
            <div class="w-24">
                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Inicial</label>
                <input type="number" name="lines[IDX].Inicial" value="0" min="0" step="0.01"
                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
            </div>
            <div class="w-24">
                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producción</label>
                <input type="number" name="lines[IDX].Produccion" value="0" min="0" step="0.01"
                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
            </div>
            <div class="w-24">
                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Devolución</label>
                <input type="number" name="lines[IDX].Devolucion" value="0" min="0" step="0.01"
                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
            </div>
            <button type="button" onclick="this.closest('.production-row').remove()"
                    class="p-2.5 rounded-xl transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.color='var(--danger)'; this.style.background='color-mix(in srgb, var(--danger) 12%, transparent)'"
                    onmouseout="this.style.color='var(--meta)'; this.style.background='transparent'" title="Quitar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
    </template>

    <script>
        var prodRowCount = @((Model?.Lines?.Count ?? 0));
        function addProductionRow() {
            var tmpl = document.getElementById('production-row-template');
            if (!tmpl) return;
            var clone = tmpl.content.cloneNode(true);
            clone.querySelectorAll('[name]').forEach(function(el) {
                el.name = el.name.replace(/IDX/, prodRowCount);
            });
            document.getElementById('production-rows').appendChild(clone);
            prodRowCount++;
        }
    </script>
}

@* ── Pre-orders for production planning ──────────────────── *@
@{
    var preOrders = ViewBag.PreOrders as List<Pana.Api.Web.ViewModels.ScheduledOrderItemViewModel> ?? new();
}
@if (preOrders.Any())
{
    <div class="space-y-4">
        <div class="flex items-center gap-2">
            <h2 class="text-lg font-bold flex items-center gap-2" style="color: var(--fg);"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg> Pre-órdenes activas</h2>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background: var(--surface-container-low); color: var(--fg-2);">@preOrders.Count</span>
        </div>
        <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
            <table class="w-full text-sm">
                <thead>
                    <tr style="background: var(--surface-container-low);">
                        <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Cliente</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Entrega</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Items</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Total</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Estado</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);"></th>
                    </tr>
                </thead>
                <tbody class="table-tonal">
                    @foreach (var po in preOrders)
                    {
                        var (poColor, poBg) = po.Status switch
                        {
                            "InProduction" => ("var(--tertiary)", "color-mix(in srgb, var(--tertiary) 12%, transparent)"),
                            "Confirmed" => ("var(--primary)", "color-mix(in srgb, var(--primary) 12%, transparent)"),
                            _ => ("var(--meta)", "color-mix(in srgb, var(--meta) 12%, transparent)")
                        };
                        var poLabel = po.Status switch
                        {
                            "InProduction" => "En producción",
                            "Confirmed" => "Confirmada",
                            _ => po.Status
                        };
                        <tr class="transition-colors"
                            onmouseover="this.style.background='var(--surface-container-low)'"
                            onmouseout="this.style.background='transparent'">
                            <td class="px-6 py-3">
                                <p class="font-medium" style="color: var(--fg);">@po.CustomerName</p>
                                <p class="text-xs" style="color: var(--meta);">@po.OrderLabel</p>
                            </td>
                            <td class="px-6 py-3">
                                <span style="color: var(--fg-2);">@(po.ScheduledDate?.ToString("dd/MM HH:mm") ?? "—")</span>
                            </td>
                            <td class="px-6 py-3 text-right">
                                <span style="color: var(--fg-2);">@po.ItemCount</span>
                            </td>
                            <td class="px-6 py-3 text-right">
                                <span class="font-semibold" style="color: var(--fg);">$@po.TotalAmount.ToString("N2")</span>
                            </td>
                            <td class="px-6 py-3 text-center">
                                <span class="inline-block text-xs px-2.5 py-1 rounded-full font-medium"
                                      style="color: @poColor; background: @poBg;">@poLabel</span>
                            </td>
                            <td class="px-6 py-3 text-right">
                                <button hx-get="/sales/@po.Id"
                                        hx-target="#modal-container"
                                        class="p-1.5 rounded-lg transition-colors"
                                        style="color: var(--meta);"
                                        onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                                        onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'"
                                        title="Ver detalle">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
