@* Views/Reports/Index.cshtml — Report Dashboard View *@
@model Pana.Api.Web.ViewModels.ReportsViewModel
@{
    ViewData["Title"] = "Reportes";
}

<div class="content-area space-y-5 fade-in">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Reportes</span>
            </h1>
            <p class="text-sm mt-0.5" style="color: var(--muted);">Ventas y análisis del negocio</p>
        </div>
        <div class="flex items-center gap-2">
            @* Export action — integration point *@
            <button class="inline-flex items-center gap-2 px-3 py-2 rounded-xl text-xs font-medium transition-colors"
                    style="color: var(--fg-2); background: var(--surface-container-low); cursor: not-allowed; opacity: 0.6;"
                    disabled
                    title="Exportar — próximamente">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Exportar
            </button>
        </div>
    </div>

    @* ── Period selector (HTMX-boosted for SPA-like navigation) *@
    <div class="flex flex-wrap items-center gap-2" hx-boost="true">
        <a href="?period=today"
           class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200
                  @(Context.Request.Query["period"] == "today" || string.IsNullOrEmpty(Context.Request.Query["period"])
                      ? "text-white shadow-ambient"
                      : "")"
           style="@(Context.Request.Query["period"] == "today" || string.IsNullOrEmpty(Context.Request.Query["period"])
                      ? "background: var(--gradient-primary);"
                      : "color: var(--fg-2); background: var(--surface-container-low);")">
            Hoy
        </a>
        <a href="?period=yesterday"
           class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200
                  @(Context.Request.Query["period"] == "yesterday" ? "text-white shadow-ambient" : "")"
           style="@(Context.Request.Query["period"] == "yesterday"
                      ? "background: var(--gradient-primary);"
                      : "color: var(--fg-2); background: var(--surface-container-low);")">
            Ayer
        </a>
        <a href="?period=week"
           class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200
                  @(Context.Request.Query["period"] == "week" ? "text-white shadow-ambient" : "")"
           style="@(Context.Request.Query["period"] == "week"
                      ? "background: var(--gradient-primary);"
                      : "color: var(--fg-2); background: var(--surface-container-low);")">
            Últimos 7 días
        </a>
        <a href="?period=month"
           class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200
                  @(Context.Request.Query["period"] == "month" ? "text-white shadow-ambient" : "")"
           style="@(Context.Request.Query["period"] == "month"
                      ? "background: var(--gradient-primary);"
                      : "color: var(--fg-2); background: var(--surface-container-low);")">
            Últimos 30 días
        </a>
        <span class="text-xs ml-2" style="color: var(--meta);">@Model.PeriodLabel</span>
    </div>

    @* ── Metric cards ────────────────────────────────────────── *@
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        @* Total Sales *@
        <div class="rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                     style="background: color-mix(in srgb, var(--primary) 12%, transparent);">
                    <svg class="w-4 h-4" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: var(--muted);">Ventas totales</span>
            </div>
            <p class="text-2xl font-bold" style="color: var(--fg);">$@Model.Metrics.TotalSales.ToString("N0")</p>
            @if (Model.Metrics.SalesGrowthPct != 0)
            {
                var isPositive = Model.Metrics.SalesGrowthPct > 0;
                <div class="flex items-center gap-1 mt-1">
                    <svg class="w-3 h-3" style="color: @(isPositive ? "var(--success)" : "var(--danger)");" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(isPositive ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")"/>
                    </svg>
                    <span class="text-xs font-medium" style="color: @(isPositive ? "var(--success)" : "var(--danger)");">
                        @(isPositive ? "+" : "")@Model.Metrics.SalesGrowthPct%
                    </span>
                </div>
            }
        </div>

        @* Total Products Sold *@
        <div class="rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                     style="background: color-mix(in srgb, var(--tertiary) 12%, transparent);">
                    <svg class="w-4 h-4" style="color: var(--tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: var(--muted);">Transacciones</span>
            </div>
            <p class="text-2xl font-bold" style="color: var(--fg);">@Model.Metrics.TotalTransactions.ToString("N0")</p>
            @if (Model.Metrics.TransactionGrowthPct != 0)
            {
                var isPositive = Model.Metrics.TransactionGrowthPct > 0;
                <div class="flex items-center gap-1 mt-1">
                    <svg class="w-3 h-3" style="color: @(isPositive ? "var(--success)" : "var(--danger)");" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(isPositive ? "M5 10l7-7m0 0l7 7m-7-7v18" : "M19 14l-7 7m0 0l-7-7m7 7V3")"/>
                    </svg>
                    <span class="text-xs font-medium" style="color: @(isPositive ? "var(--success)" : "var(--danger)");">
                        @(isPositive ? "+" : "")@Model.Metrics.TransactionGrowthPct%
                    </span>
                </div>
            }
        </div>

        @* Total Customers *@
        <div class="rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                     style="background: color-mix(in srgb, var(--success) 12%, transparent);">
                    <svg class="w-4 h-4" style="color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: var(--muted);">Clientes</span>
            </div>
            <p class="text-2xl font-bold" style="color: var(--fg);">@Model.Metrics.TotalCustomers.ToString("N0")</p>
            <p class="text-xs mt-1" style="color: var(--meta);">Órdenes únicas</p>
        </div>

        @* Net Profit *@
        <div class="rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);">
            <div class="flex items-center gap-2 mb-2">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                     style="background: color-mix(in srgb, var(--warn) 12%, transparent);">
                    <svg class="w-4 h-4" style="color: var(--warn);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: var(--muted);">Ganancia neta</span>
            </div>
            <p class="text-2xl font-bold" style="color: var(--fg);">
                @if (Model.Metrics.NetProfit == 0)
                {
                    <span style="color: var(--meta);">—</span>
                }
                else
                {
                    <span>$@Model.Metrics.NetProfit.ToString("N0")</span>
                }
            </p>
            <p class="text-xs mt-1" style="color: var(--meta);">Integración P&L pendiente</p>
        </div>
    </div>

    @* ── Chart + Top Products row ────────────────────────────── *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        @* Sales trend chart (2 cols) *@
        <div class="lg:col-span-2 rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);"
             x-data="salesChart">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-semibold" style="color: var(--fg);">Tendencia de ventas</h3>
                <span class="text-xs" style="color: var(--meta);">@Model.PeriodLabel</span>
            </div>
            <div class="w-full" style="height: 280px;">
                <canvas id="salesTrendChart"></canvas>
            </div>
        </div>

        @* Top products panel *@
        <div class="rounded-2xl p-5 shadow-ambient" style="background: var(--surface-container-lowest);">
            <h3 class="font-semibold mb-4" style="color: var(--fg);">Más vendidos</h3>
            @if (!Model.TopProducts.Any())
            {
                <div class="text-center py-8">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3"
                         style="background: var(--surface-container);">
                        <svg class="w-6 h-6" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <p class="text-sm" style="color: var(--meta);">Sin datos de ventas</p>
                </div>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var product in Model.TopProducts)
                    {
                        <div class="flex items-center gap-3">
                            @* Product thumbnail fallback *@
                            <div class="w-10 h-10 rounded-lg flex-shrink-0 flex items-center justify-center"
                                 style="background: var(--surface-container-low);">
                                <svg class="w-5 h-5" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium truncate" style="color: var(--fg);">@product.ProductName</p>
                                <p class="text-xs" style="color: var(--muted);">@product.Category · @product.TotalOrders órdenes</p>
                            </div>
                            <div class="text-right flex-shrink-0">
                                <p class="text-sm font-semibold" style="color: var(--fg);">@product.TotalSold.ToString("N0")</p>
                                <p class="text-xs" style="color: var(--meta);">vendidos</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ── All orders table ────────────────────────────────────── *@
    <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
        <div class="px-5 py-4 flex items-center justify-between" style="background: var(--surface-container-low);">
            <h3 class="font-semibold" style="color: var(--fg);">Todas las órdenes</h3>
            <span class="text-xs" style="color: var(--meta);">@Model.AllOrders.Count órdenes</span>
        </div>
        @if (!Model.AllOrders.Any())
        {
            <div class="text-center py-16">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                     style="background: var(--surface-container);">
                    <svg class="w-8 h-8" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </div>
                <p class="font-medium" style="color: var(--meta);">Sin órdenes en este período</p>
                <p class="text-xs mt-1" style="color: var(--meta);">Seleccioná otro período o registrá nuevas ventas</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr style="background: var(--surface-container-low);">
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">#</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Fecha</th>
                            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Orden</th>
                            <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Estado</th>
                            <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Total</th>
                            <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Pago</th>
                            <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);"></th>
                        </tr>
                    </thead>
                    <tbody class="table-tonal">
                        @foreach (var item in Model.AllOrders)
                        {
                            var (statusColor, statusBg) = item.Status switch
                            {
                                "Completed" => ("var(--success)", "color-mix(in srgb, var(--success) 12%, transparent)"),
                                "Voided" => ("var(--danger)", "color-mix(in srgb, var(--danger) 12%, transparent)"),
                                "Draft" => ("var(--tertiary)", "color-mix(in srgb, var(--tertiary) 12%, transparent)"),
                                _ => ("var(--primary)", "color-mix(in srgb, var(--primary) 12%, transparent)")
                            };
                            var statusLabel = item.Status switch
                            {
                                "Completed" => "Completada",
                                "Voided" => "Anulada",
                                "Confirmed" => "Confirmada",
                                "Preparing" => "En preparación",
                                "Ready" => "Lista",
                                "Draft" => "Borrador",
                                _ => item.Status
                            };
                            var (payColor, payBg) = item.PaymentStatus switch
                            {
                                "Pagado" => ("var(--success)", "color-mix(in srgb, var(--success) 12%, transparent)"),
                                "Anulado" => ("var(--danger)", "color-mix(in srgb, var(--danger) 12%, transparent)"),
                                _ => ("var(--tertiary)", "color-mix(in srgb, var(--tertiary) 12%, transparent)")
                            };

                            <tr class="transition-colors"
                                onmouseover="this.style.background='var(--surface-container-low)'"
                                onmouseout="this.style.background='transparent'">
                                <td class="px-5 py-3">
                                    <span class="font-mono text-xs" style="color: var(--meta);">#@item.Sequence</span>
                                </td>
                                <td class="px-5 py-3">
                                    <p class="text-xs" style="color: var(--fg-2);">@item.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    <p class="text-xs" style="color: var(--meta);">@item.CreatedAt.ToString("HH:mm")</p>
                                </td>
                                <td class="px-5 py-3">
                                    <p class="font-medium" style="color: var(--fg);">@item.OrderLabel</p>
                                </td>
                                <td class="px-5 py-3 text-center">
                                    <span class="inline-block text-xs px-2.5 py-1 rounded-full font-medium"
                                          style="color: @statusColor; background: @statusBg;">@statusLabel</span>
                                </td>
                                <td class="px-5 py-3 text-right">
                                    <span class="font-semibold" style="color: var(--fg);">$@item.TotalAmount.ToString("N2")</span>
                                </td>
                                <td class="px-5 py-3 text-center">
                                    <span class="inline-block text-xs px-2.5 py-1 rounded-full font-medium"
                                          style="color: @payColor; background: @payBg;">@item.PaymentStatus</span>
                                </td>
                                <td class="px-5 py-3 text-right">
                                    <button hx-get="/sales/@item.Id"
                                            hx-target="#modal-container"
                                            class="p-1.5 rounded-lg transition-colors"
                                            style="color: var(--meta);"
                                            onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                                            onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('salesChart', () => ({
        chart: null,
        init() {
            this.$nextTick(() => {
                this.renderChart();
            });
        },
        renderChart() {
            const ctx = document.getElementById('salesTrendChart');
            if (!ctx) return;
            if (this.chart) this.chart.destroy();

            const dailyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.DailyTrend.Select(d => new { d.Label, d.Ventas, d.Transacciones })));

            this.chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dailyData.map(d => d.Label),
                    datasets: [{
                        label: 'Ventas (MXN)',
                        data: dailyData.map(d => d.Ventas),
                        borderColor: getComputedStyle(document.documentElement).getPropertyValue('--chart-1').trim() || '#9e0012',
                        backgroundColor: 'rgba(158, 0, 18, 0.08)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 3,
                        pointBackgroundColor: '#9e0012',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { font: { size: 11 }, color: '#94948c' }
                        },
                        y: {
                            grid: { color: 'rgba(28, 28, 25, 0.06)' },
                            ticks: {
                                font: { size: 11 },
                                color: '#94948c',
                                callback: v => '$' + v.toLocaleString()
                            },
                            beginAtZero: true
                        }
                    },
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    }
                }
            });
        }
    }));
});
</script>
}
