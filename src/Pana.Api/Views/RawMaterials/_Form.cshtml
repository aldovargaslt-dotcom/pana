@model Pana.Api.Web.ViewModels.RawMaterialFormViewModel

<div class="modal-overlay" @@click.self="$el.remove()">
    <div class="modal-content surface-container-lowest rounded-2xl p-6 shadow-xl"
         style="max-width: 520px; width: 90vw; background: var(--surface-container-lowest);"
         @@click.stop="">

        <header class="flex justify-between items-center mb-6">
            <h2 class="text-lg font-bold" style="color: var(--fg);">
                @(Model.Id is null ? "Nuevo Material" : "Editar Material")
            </h2>
            <button class="w-8 h-8 rounded-lg flex items-center justify-center transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.background='var(--surface-container)'"
                    onmouseout="this.style.background='transparent'"
                    @@click="$el.closest('.modal-overlay').remove()">
                ✕
            </button>
        </header>

        <form hx-post="@(Model.Id is null ? "/raw-materials/create" : $"/raw-materials/{Model.Id}/edit")"
              hx-target="#table-body"
              hx-swap="outerHTML"
              class="space-y-4">
            @Html.AntiForgeryToken()

            @if (Model.Id is not null)
            {
                <input type="hidden" name="Id" value="@Model.Id" />
            }

            <div class="form-group">
                <label for="name" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Nombre</label>
                <input type="text" id="name" name="Name" value="@Model.Name" required
                       class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       placeholder="Ej. Harina de trigo 00" />
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="form-group">
                    <label for="category" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Categoría</label>
                    <div x-data="panaSelect" class="pana-select-wrapper">
                        <select x-ref="native" name="Category" class="sr-only">
                            <option value="">Seleccionar...</option>
                            <option value="Flours" selected="@(Model.Category == "Flours")">Harinas</option>
                            <option value="Sugars" selected="@(Model.Category == "Sugars")">Azúcares</option>
                            <option value="Eggs" selected="@(Model.Category == "Eggs")">Huevos</option>
                            <option value="Dairy" selected="@(Model.Category == "Dairy")">Lácteos</option>
                            <option value="Fats" selected="@(Model.Category == "Fats")">Grasas</option>
                            <option value="Leaveners" selected="@(Model.Category == "Leaveners")">Levaduras</option>
                            <option value="Flavorings" selected="@(Model.Category == "Flavorings")">Saborizantes</option>
                            <option value="Other" selected="@(Model.Category == "Other")">Otro</option>
                        </select>
                        <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                            <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                            <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                             class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                            <div class="pana-select-search">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                            </div>
                            <div x-ref="optionsList" class="pana-select-options">
                                <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                    <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                         @@mouseenter="highlightIndex = i" tabindex="0"
                                         class="pana-select-option"
                                         :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                        <span x-text="opt.label"></span>
                                        <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                </template>
                                <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="supplier" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Proveedor</label>
                    <input type="text" id="supplier" name="Supplier" value="@Model.Supplier"
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           placeholder="Opcional" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div class="form-group">
                    <label for="purchasePrice" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Precio de compra</label>
                    <input type="number" id="purchasePrice" name="PurchasePrice" value="@Model.PurchasePrice" step="0.01" min="0" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all font-mono"
                           style="background: var(--surface-container-high); color: var(--fg);" />
                </div>

                <div class="form-group">
                    <label for="purchaseUnit" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Unidad de compra</label>
                    <div x-data="panaSelect" class="pana-select-wrapper">
                        <select x-ref="native" name="PurchaseUnit" class="sr-only">
                            <option value="kg" selected="@(Model.PurchaseUnit == "kg")">kg</option>
                            <option value="g" selected="@(Model.PurchaseUnit == "g")">g</option>
                            <option value="L" selected="@(Model.PurchaseUnit == "L")">L</option>
                            <option value="mL" selected="@(Model.PurchaseUnit == "mL")">mL</option>
                            <option value="pza" selected="@(Model.PurchaseUnit == "pza")">pza</option>
                            <option value="docena" selected="@(Model.PurchaseUnit == "docena")">docena</option>
                            <option value="cono" selected="@(Model.PurchaseUnit == "cono")">cono</option>
                        </select>
                        <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                            <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                            <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                             class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                            <div class="pana-select-search">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                            </div>
                            <div x-ref="optionsList" class="pana-select-options">
                                <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                    <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                         @@mouseenter="highlightIndex = i" tabindex="0"
                                         class="pana-select-option"
                                         :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                        <span x-text="opt.label"></span>
                                        <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                </template>
                                <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-3">
                <div class="form-group">
                    <label for="presentationQty" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Presentación</label>
                    <input type="number" id="presentationQty" name="PresentationQty" value="@Model.PresentationQty" step="0.01" min="0.01" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all"
                           style="background: var(--surface-container-high); color: var(--fg);" />
                </div>

                <div class="form-group">
                    <label for="baseUnit" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Unidad base</label>
                    <div x-data="panaSelect" class="pana-select-wrapper">
                        <select x-ref="native" name="BaseUnit" class="sr-only">
                            <option value="g" selected="@(Model.BaseUnit == "g")">g</option>
                            <option value="mL" selected="@(Model.BaseUnit == "mL")">mL</option>
                            <option value="pza" selected="@(Model.BaseUnit == "pza")">pza</option>
                        </select>
                        <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                            <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                            <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                             class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                            <div class="pana-select-search">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                            </div>
                            <div x-ref="optionsList" class="pana-select-options">
                                <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                    <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                         @@mouseenter="highlightIndex = i" tabindex="0"
                                         class="pana-select-option"
                                         :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                        <span x-text="opt.label"></span>
                                        <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                </template>
                                <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="yieldPct" class="block text-sm font-medium mb-1" style="color: var(--fg-2);">Rendimiento %</label>
                    <input type="number" id="yieldPct" name="YieldPct" value="@Model.YieldPct" step="0.01" min="0.01" max="100" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all"
                           style="background: var(--surface-container-high); color: var(--fg);" />
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4" style="background: var(--surface-container-low); margin: 0 -1.5rem -1.5rem; padding: 0.75rem 1.5rem; border-radius: 0 0 16px 16px;">
                <button type="button"
                        class="px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
                        style="background: var(--surface-container); color: var(--fg-2);"
                        onmouseover="this.style.background='var(--surface-container-high)'"
                        onmouseout="this.style.background='var(--surface-container)'"
                        @@click="$el.closest('.modal-overlay').remove()">
                    Cancelar
                </button>
                <button type="submit"
                        class="px-5 py-2.5 text-white text-sm font-medium rounded-xl transition-all duration-200 shadow-ambient active:scale-[0.98]"
                        style="background: var(--gradient-primary);">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>
