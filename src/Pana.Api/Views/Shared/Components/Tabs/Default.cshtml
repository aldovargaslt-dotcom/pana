@model Pana.Api.Web.Components.TabsProps

<div x-data="{ activeTab: '@Model.ActiveTab' }" class="space-y-5">
    @* Tab headers *@
    <div class="flex border-b border-gray-200 gap-0">
        @foreach (var tab in Model.Tabs)
        {
            <button @@click="activeTab = '@tab.Id'"
                    hx-get="@tab.HxGet"
                    hx-target="@tab.HxTarget"
                    hx-trigger="click"
                    :class="activeTab === '@tab.Id'
                        ? 'border-b-2 border-brand-500 text-brand-700 font-semibold'
                        : 'text-gray-400 hover:text-gray-600 font-medium'"
                    class="px-5 py-3 text-sm transition-all duration-200">
                @tab.Label
            </button>
        }
    </div>

    @* Tab content *@
    @foreach (var tab in Model.Tabs)
    {
        <div x-show="activeTab === '@tab.Id'" id="@tab.HxTarget.TrimStart('#')"
             hx-get="@tab.HxGet" hx-trigger="revealed once">
            <div class="space-y-3">
                <div class="skeleton h-4 w-3/4"></div>
                <div class="skeleton h-4 w-1/2"></div>
                <div class="skeleton h-3 w-2/3"></div>
            </div>
        </div>
    }
</div>
