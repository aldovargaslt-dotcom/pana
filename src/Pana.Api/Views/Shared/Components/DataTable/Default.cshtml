@model Pana.Api.Web.Components.DataTableProps

<div>
    @if (Model.Searchable)
    {
        <div class="mb-4">
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="search"
                       name="q"
                       placeholder="Buscar..."
                       hx-get="@Model.HxGet"
                       hx-trigger="keyup changed delay:300ms"
                       hx-target="#table-body-@(Model.Columns[0].Key)"
                       hx-include="[name='q']"
                       class="w-full max-w-xs pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm
                              focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                              placeholder-gray-400 transition-all duration-200" />
            </div>
        </div>
    }

    <div class="overflow-x-auto rounded-2xl border border-gray-100">
        <table class="w-full text-sm">
            <thead class="bg-gray-50/80 border-b border-gray-100">
                <tr>
                    @foreach (var col in Model.Columns)
                    {
                        <th class="px-4 py-3 text-left font-semibold text-gray-500 text-xs uppercase tracking-wider @(col.Width != null ? col.Width : "")">
                            @col.Label
                            @if (col.Sortable)
                            {
                                <button class="ml-1 text-gray-300 hover:text-gray-500 transition-colors">↕</button>
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody id="table-body-@(Model.Columns[0].Key)"
                   hx-get="@Model.HxGet"
                   hx-trigger="load"
                   class="divide-y divide-gray-50">
                @* Content loaded via HTMX *@
                <tr><td colspan="@Model.Columns.Count" class="p-10 text-center"><div class="skeleton h-5 w-2/3 mx-auto"></div></td></tr>
            </tbody>
        </table>
    </div>
</div>
