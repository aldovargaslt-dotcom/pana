@model Pana.Api.Web.Components.EmptyStateProps

<div class="text-center py-16">
    <div class="mx-auto w-20 h-20 rounded-2xl flex items-center justify-center mb-5"
         style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
        <svg class="w-10 h-10" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
        </svg>
    </div>
    <h3 class="text-lg font-semibold mb-1" style="color: var(--fg-2);">@Model.Title</h3>
    <p class="text-sm mb-6 max-w-xs mx-auto" style="color: var(--meta);">@Model.Description</p>
    @if (Model.ActionLabel != null && Model.ActionHxGet != null)
    {
        @await Component.InvokeAsync("Button", new {
            text = Model.ActionLabel,
            variant = "primary",
            hxGet = Model.ActionHxGet,
            hxTarget = Model.ActionHxTarget
        })
    }
</div>
