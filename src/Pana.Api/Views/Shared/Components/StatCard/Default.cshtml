@model Pana.Api.Web.Components.StatCardProps

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 hover:shadow-md transition-shadow"
     @if (Model.HxGet != null) { <text>hx-get="@Model.HxGet" hx-trigger="every 60s" hx-swap="innerHTML"</text> }>

    <div class="flex items-start justify-between">
        <div>
            <p class="text-sm text-gray-500 mb-1">@Model.Label</p>
            <p class="text-2xl font-bold text-gray-900">@Model.Value</p>
            @if (Model.Trend != null && Model.TrendValue != null)
            {
                <div class="flex items-center gap-1 mt-1">
                    <span class="text-xs font-medium @(Model.Trend == "up" ? "text-emerald-600" : "text-red-600")">
                        @if (Model.Trend == "up") { <text>↑</text> } else { <text>↓</text> }
                        @Model.TrendValue
                    </span>
                    <span class="text-xs text-gray-400">vs. mes anterior</span>
                </div>
            }
        </div>
        @if (Model.Icon != null)
        {
            <div class="p-3 bg-brand-50 rounded-lg text-brand-600">
                @switch (Model.Icon)
                {
                    case "money":
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        break;
                    case "box":
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        break;
                    case "chart":
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        break;
                    case "trend":
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                        break;
                }
            </div>
        }
    </div>
</div>
