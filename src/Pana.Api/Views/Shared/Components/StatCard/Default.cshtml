@model Pana.Api.Web.Components.StatCardProps

<div class="group rounded-2xl shadow-ambient p-5 hover:shadow-ambient hover:-translate-y-0.5 transition-all duration-300"
     style="background: var(--surface-container-lowest);"
     @if (Model.HxGet != null) { <text>hx-get="@Model.HxGet" hx-trigger="every 60s" hx-swap="innerHTML"</text> }>

    <div class="flex items-start justify-between">
        <div class="space-y-1">
            <p class="text-sm font-medium" style="color: var(--muted);">@Model.Label</p>
            <p class="text-3xl font-bold tracking-tight" style="color: var(--fg);">@Model.Value</p>
            @if (Model.Trend != null && Model.TrendValue != null)
            {
                <div class="flex items-center gap-1.5 mt-1.5">
                    <span class="inline-flex items-center gap-0.5 text-xs font-semibold px-2 py-0.5 rounded-full @(Model.Trend == "up" ? "" : "")"
                          style="@(Model.Trend == "up" ? "color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);" : "color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);")">
                        @if (Model.Trend == "up") { <text>↑</text> } else { <text>↓</text> }
                        @Model.TrendValue
                    </span>
                    <span class="text-xs" style="color: var(--meta);">vs. mes anterior</span>
                </div>
            }
        </div>
        @if (Model.Icon != null)
        {
            <div class="p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
                 style="background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 5%, transparent), color-mix(in srgb, var(--primary) 10%, transparent)); color: var(--primary);">
                @switch (Model.Icon)
                {
                    case "money":
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        break;
                    case "box":
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        break;
                    case "chart":
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        break;
                    case "trend":
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                        break;
                }
            </div>
        }
    </div>
</div>
