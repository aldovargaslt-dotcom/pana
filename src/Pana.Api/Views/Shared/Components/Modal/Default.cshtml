@model Pana.Api.Web.Components.ModalProps

<div id="@Model.Id"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 fade-in"
     x-data="{ open: true }"
     x-show="open"
     x-transition.opacity
     @@keydown.escape.window="open = false">

    <div class="bg-white rounded-xl shadow-xl w-full @Model.SizeClasses p-0 max-h-[85vh] flex flex-col"
         @@click.outside="open = false"
         x-transition.scale>

        @* Header *@
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800">@Model.Title</h2>
            <button @@click="open = false"
                    class="p-1 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6"
             @if (Model.HxGet != null) { <text>hx-get="@Model.HxGet" hx-trigger="load"</text> }
             @if (Model.HxPost != null) { <text>hx-post="@Model.HxPost"</text> }>
            @if (Model.HxGet != null)
            {
                <div class="space-y-3">
                    <div class="skeleton h-10 rounded w-3/4"></div>
                    <div class="skeleton h-10 rounded"></div>
                    <div class="skeleton h-24 rounded"></div>
                </div>
            }
        </div>
    </div>
</div>
