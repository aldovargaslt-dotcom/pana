@model Pana.Api.Web.Components.ModalProps

<div id="@Model.Id"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
     x-data="{ open: true }"
     x-show="open"
     x-transition.opacity.duration.200ms
     @@keydown.escape.window="open = false">

    <div class="rounded-2xl shadow-modal w-full @Model.SizeClasses p-0 max-h-[85vh] flex flex-col scale-in"
         style="background: var(--surface-container-lowest);"
         @@click.outside="open = false">

        @* Header — tonal separation, no border *@
        <div class="flex items-center justify-between px-6 py-4 rounded-t-2xl"
             style="background: var(--surface-container-low);">
            <h2 class="text-lg font-semibold" style="color: var(--fg);">@Model.Title</h2>
            <button @@click="open = false"
                    class="p-2 rounded-xl transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                    onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6"
             @if (Model.HxGet != null) { <text>hx-get="@Model.HxGet" hx-trigger="load"</text> }
             @if (Model.HxPost != null) { <text>hx-post="@Model.HxPost"</text> }>
            @if (Model.HxGet != null)
            {
                <div class="space-y-3">
                    <div class="skeleton h-10 w-3/4"></div>
                    <div class="skeleton h-10"></div>
                    <div class="skeleton h-24"></div>
                </div>
            }
        </div>
    </div>
</div>
