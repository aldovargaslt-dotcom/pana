@* _LayoutAuth.cshtml — Auth layout (login, register)
   Uses _Head.cshtml for shared fonts/tokens/Tailwind config.
   No sidebar, no top bar — just the centered auth form. *@
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    @await Html.PartialAsync("_Head")
    @RenderSection("Styles", required: false)
    <style>
        #loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            z-index: 9999;
            width: 0;
            opacity: 0;
            background: var(--gradient-primary);
            transition: width .3s ease, opacity .15s ease;
        }
        #loading-bar.active { width: 70%; opacity: 1; }
        #loading-bar.done { width: 100%; opacity: 0; transition: width .2s ease, opacity .3s ease .15s; }
    </style>
</head>
<body class="min-h-screen font-sans antialiased" style="background: var(--bg);">
    <div id="loading-bar"></div>
    @RenderBody()
    <script>
        document.body.addEventListener('htmx:beforeRequest', function() {
            document.getElementById('loading-bar').classList.add('active');
            document.getElementById('loading-bar').classList.remove('done');
        });
        document.body.addEventListener('htmx:afterRequest', function() {
            document.getElementById('loading-bar').classList.add('done');
            document.getElementById('loading-bar').classList.remove('active');
        });
    </script>
</body>
</html>
