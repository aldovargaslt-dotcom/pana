@* _Head.cshtml — Shared <head> content for all layouts (auth + app)
   Every layout includes this partial to avoid duplicating fonts, tokens, and Tailwind config. *@
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@ViewData["Title"] — Pana</title>

@* ── Google Fonts (Plus Jakarta Sans) ──────────────────── *@
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

@* ── Pana Design Tokens (Open Design schema, v2 "The Modern Hearth") ── *@
<link rel="stylesheet" href="/css/pana-tokens.css" />

@* ── Tailwind CSS (compiled, no CDN) ───────────────────── *@
<link rel="stylesheet" href="/css/tailwind.min.css" />
