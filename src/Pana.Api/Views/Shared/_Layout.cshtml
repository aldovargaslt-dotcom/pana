<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Pana</title>

    @* ── Google Fonts (Plus Jakarta Sans) ──────────────────── *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    @* ── Pana Design Tokens (Open Design schema, v2 "The Modern Hearth") *@
    <link rel="stylesheet" href="/css/pana-tokens.css" />

    @* ── Tailwind CSS v4 (CDN) ──────────────────────────────── *@
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'system-ui', '-apple-system', 'sans-serif'],
                    },
                    colors: {
                        // ── Semantic design tokens (The Modern Hearth) ──
                        primary: 'var(--primary)',
                        'primary-container': 'var(--primary-container)',
                        'primary-fixed': 'var(--primary-fixed)',
                        'on-primary': 'var(--on-primary)',
                        tertiary: 'var(--tertiary)',
                        'tertiary-fixed': 'var(--tertiary-fixed)',
                        'on-tertiary-fixed': 'var(--on-tertiary-fixed)',
                        surface: 'var(--surface)',
                        'surface-lowest': 'var(--surface-container-lowest)',
                        'surface-low': 'var(--surface-container-low)',
                        'surface-container': 'var(--surface-container)',
                        'surface-high': 'var(--surface-container-high)',
                        'surface-highest': 'var(--surface-container-highest)',
                        fg: 'var(--fg)',
                        'fg-2': 'var(--fg-2)',
                        muted: 'var(--muted)',
                        success: 'var(--success)',
                        warn: 'var(--warn)',
                        danger: 'var(--danger)',
                        // ── Brand palette (backward compat + warm red scale) ──
                        brand: {
                            50: '#fff5f5',
                            100: '#ffe0e0',
                            200: '#ffc2c2',
                            300: '#ff9494',
                            400: '#ff6666',
                            500: '#c41e24',
                            600: '#b31a20',
                            700: '#9e0012',
                            800: '#7a0010',
                            900: '#5c000c',
                            950: '#3d0008',
                        }
                    },
                    boxShadow: {
                        'ambient': '0px 4px 16px rgba(28, 28, 25, 0.04), 0px 12px 32px rgba(28, 28, 25, 0.06)',
                        'modal': '0px 20px 60px rgba(28, 28, 25, 0.12), 0px 0px 0px 1px rgba(28, 28, 25, 0.04)',
                        'card': 'var(--elev-ambient)',
                    },
                    borderRadius: {
                        'sm': '4px',
                        'md': '12px',
                        'lg': '16px',
                        'xl': '24px',
                    }
                }
            }
        }
    </script>

    @* ── HTMX 2.0 ────────────────────────────────────────────── *@
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>

    @* ── Alpine.js ───────────────────────────────────────────── *@
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js"></script>

    @* ── Chart.js ────────────────────────────────────────────── *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js"></script>

    @* ── Base styles ─────────────────────────────────────────── *@
    <style>
        /* ── Scrollbar ──────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

        /* ── Selection ──────────────────────────────── */
        ::selection { background: var(--primary); color: var(--on-primary); }

        /* ── HTMX animations ────────────────────────── */
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-flex; }
        .htmx-request.htmx-indicator { display: inline-flex; }

        /* ── Table loading state ───────────────────── */
        tbody.htmx-request {
            opacity: 0.4;
            transition: opacity 0.15s ease;
        }

        /* ── Page transitions ───────────────────────── */
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

        .slide-in-right { animation: slideInRight 0.35s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        .scale-in { animation: scaleIn 0.2s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes scaleIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

        /* ── Skeleton loading ───────────────────────── */
        .skeleton {
            background: linear-gradient(110deg, #e5e7eb 8%, #f3f4f6 18%, #e5e7eb 33%);
            background-size: 200% 100%;
            animation: shimmer 1.5s ease-in-out infinite;
            border-radius: 6px;
        }
        @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* ── Toast animations ───────────────────────── */
        .toast-enter { animation: toastIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes toastIn { from { opacity: 0; transform: translateX(100px) scale(0.95); } to { opacity: 1; transform: translateX(0) scale(1); } }

        .toast-exit { animation: toastOut 0.3s ease-in forwards; }
        @@keyframes toastOut { to { opacity: 0; transform: translateX(100px) scale(0.95); } }

        /* ── Pulse dot ──────────────────────────────── */
        .pulse-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--fresh-green); display: inline-block;
            animation: pulseDot 2s ease-in-out infinite;
        }
        @@keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.3); }
        }

        /* ── Gradient text utility ──────────────────── */
        .text-gradient {
            background: linear-gradient(135deg, var(--primary), var(--primary-container));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ── Freshness Pulse (The Modern Hearth) ───── */
        .freshness-pulse {
            display: inline-flex; align-items: center; gap: 0.375rem;
            padding: 0.25rem 0.75rem;
            background: var(--tertiary-fixed);
            color: var(--tertiary);
            border-radius: var(--radius-pill);
            font-size: var(--text-label-sm);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: var(--tracking-label);
            animation: freshnessPulse 2.5s ease-in-out infinite;
        }
        @@keyframes freshnessPulse {
            0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(101, 71, 0, 0.3); }
            50% { opacity: 0.85; box-shadow: 0 0 0 6px rgba(101, 71, 0, 0); }
        }

        /* ── Custom Select Dropdown (The Modern Hearth) ──
         * Alpine.js powered. Replaces native <select> entirely.
         * Hidden native select stays for form submission.
         * Design: glass panel, tonal layering, warm shadows,
         * smooth animations, no hard borders.
         */
        .pana-select-wrapper {
            position: relative;
            display: block;
            width: 100%;
        }

        /* ── Trigger button ─────────────────────────── */
        .pana-select-trigger {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            width: 100%;
            padding: 0.625rem 0.875rem;
            font-family: var(--font-body);
            font-size: var(--text-body-sm);
            font-weight: var(--weight-body);
            line-height: var(--leading-body);
            color: var(--fg);
            background-color: var(--surface-container-high);
            border: none;
            border-radius: var(--radius-md);
            cursor: pointer;
            outline: none;
            text-align: left;
            transition: background-color var(--dur-fast) var(--ease-standard),
                        box-shadow var(--dur-fast) var(--ease-standard);
            box-shadow: var(--elev-flat);
        }

        .pana-select-trigger:hover {
            background-color: var(--surface-container);
        }

        .pana-select-trigger:focus,
        .pana-select-trigger-open {
            background-color: var(--primary-fixed);
            box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent);
        }

        .pana-select-trigger .text-muted {
            color: var(--muted);
        }

        .pana-select-trigger span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            min-width: 0;
        }

        /* Chevron icon */
        .pana-select-chevron {
            width: 1.125rem;
            height: 1.125rem;
            flex-shrink: 0;
            color: var(--muted);
            transition: transform var(--dur-fast) var(--ease-standard);
        }

        .pana-select-chevron.rotate-180 {
            transform: rotate(180deg);
        }

        /* ── Dropdown panel (fixed position — breaks overflow) */
        .pana-select-dropdown {
            position: fixed;
            z-index: 10000;
            min-width: 12rem;
            max-height: 18rem;
            display: flex;
            flex-direction: column;
            background: var(--surface-container-lowest);
            border-radius: var(--radius-md);
            box-shadow: var(--elev-modal);
            overflow: hidden;
        }

        /* ── Search input ───────────────────────────── */
        .pana-select-search {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--surface-container-low);
            flex-shrink: 0;
        }

        .pana-select-search svg {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
            color: var(--muted);
        }

        .pana-select-search input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            font-family: var(--font-body);
            font-size: var(--text-body-sm);
            color: var(--fg);
            padding: 0.25rem 0;
        }

        .pana-select-search input::placeholder {
            color: var(--meta);
        }

        /* ── Options list ───────────────────────────── */
        .pana-select-options {
            overflow-y: auto;
            padding: 0.375rem;
            flex: 1;
            scroll-behavior: smooth;
        }

        /* ── Option item ────────────────────────────── */
        .pana-select-option {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem;
            font-family: var(--font-body);
            font-size: var(--text-body-sm);
            color: var(--fg);
            border-radius: 0.5rem;
            cursor: pointer;
            transition: background-color 0.1s ease;
            outline: none;
            user-select: none;
        }

        .pana-select-option:hover,
        .pana-select-option-highlighted {
            background-color: var(--surface-container-low);
        }

        .pana-select-option:focus {
            background-color: var(--surface-container-low);
        }

        .pana-select-option-selected {
            color: var(--primary);
            font-weight: var(--weight-emphasis);
            background-color: var(--primary-fixed);
        }

        .pana-select-option-selected:hover,
        .pana-select-option-selected.pana-select-option-highlighted {
            background-color: color-mix(in srgb, var(--primary-fixed) 80%, var(--primary) 10%);
        }

        .pana-select-option svg {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
            color: var(--primary);
        }

        /* ── Empty state ────────────────────────────── */
        .pana-select-empty {
            padding: 1rem 0.75rem;
            text-align: center;
            font-size: var(--text-body-sm);
            color: var(--meta);
        }

        /* ── Table tonal rows (No-Line Rule compliant) ─ */
        tbody.table-tonal tr:nth-child(even) { background: var(--surface-container-low); }

        /* ── Danger variant (Waste module) ──────────── */
        .pana-select-trigger-danger:focus,
        .pana-select-trigger-danger.pana-select-trigger-open {
            background-color: color-mix(in srgb, var(--danger) 8%, transparent);
            box-shadow: 0 0 0 2px color-mix(in srgb, var(--danger) 20%, transparent);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body class="min-h-screen font-sans antialiased"
      style="background-color: var(--bg); color: var(--fg);"
      x-data="appShell">

    @* ═══════════════════════════════════════════════════════════
       SIDEBAR — Glass Morphism (The Modern Hearth)
       ═══════════════════════════════════════════════════════════ *@
    <aside class="fixed left-0 top-0 h-full w-64 z-40
                   transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
           style="background: var(--sidebar-bg); backdrop-filter: blur(var(--glass-blur-sidebar)); -webkit-backdrop-filter: blur(var(--glass-blur-sidebar)); border-right: 1px solid var(--sidebar-border);"
           :class="{ '-translate-x-full': !sidebarOpen, 'translate-x-0': sidebarOpen }">

        @* Brand *@
        <div class="flex items-center gap-3 px-6 py-6" style="background: rgba(28,28,25,0.02);">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-lg"
                 style="background: var(--gradient-primary);">
                P
            </div>
            <div>
                <span class="font-bold text-lg tracking-tight" style="color: var(--primary);">Pana</span>
                <p class="text-xs" style="color: var(--meta);">Business Platform</p>
            </div>
        </div>

        @* Navigation *@
        <nav class="p-4 space-y-1.5">
            @* ── Admin section ──────────────────────────────── *@
            @if (User.IsInRole("Admin"))
            {
            <a href="/"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path == "/"
                          ? ""
                          : "")"
               style="@(ViewContext.HttpContext.Request.Path == "/"
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
                Dashboard
            </a>
            <a href="/products"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/products")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Productos
            </a>
            <a href="/waste"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/waste")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Desperdicios
            </a>
            <a href="/raw-materials"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/raw-materials")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Materias Primas
            </a>
            <a href="/recipes"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/recipes")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                Recetas
            </a>
            <a href="/reports"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/reports")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Reportes
            </a>

            @* ── Divider ──────────────────────────────────── *@
            <div class="my-3" style="border-top: 1px solid var(--sidebar-border);"></div>
            }

            @* ── Staff section (all roles) ──────────────────── *@
            <a href="/inventory"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/inventory")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Inventario
            </a>
            <a href="/pos"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/pos")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                Punto de Venta
            </a>
            <a href="/activity"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
               style="@(ViewContext.HttpContext.Request.Path.StartsWithSegments("/activity")
                          ? "background: var(--sidebar-accent); color: var(--sidebar-fg-active);"
                          : "color: var(--sidebar-fg);")"
               onmouseover="if(!this.classList.contains('active')) this.style.background='rgba(28,28,25,0.04)'"
               onmouseout="if(!this.classList.contains('active')) this.style.background='transparent'">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                Actividad
            </a>
        </nav>

        @* Footer *@
        <div class="absolute bottom-0 left-0 right-0 p-4" style="background: rgba(28,28,25,0.02);">
            <div class="flex items-center gap-3 px-3 py-2 rounded-xl" style="background: rgba(28,28,25,0.03);">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-xs font-bold"
                     style="background: var(--gradient-primary);">DB</div>
                <div>
                    <p class="text-xs font-medium" style="color: var(--fg-2);">Default Bakery</p>
                    <p class="text-[10px] flex items-center gap-1" style="color: var(--meta);"><span class="pulse-dot"></span> Activo</p>
                </div>
            </div>
        </div>
    </aside>

    @* ── Overlay (mobile) ───────────────────────────────────── *@
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-30 lg:hidden"
         x-show="sidebarOpen"
         x-transition.opacity.duration.300ms
         @@click="sidebarOpen = false"></div>

    @* ═══════════════════════════════════════════════════════════
       MAIN CONTENT
       ═══════════════════════════════════════════════════════════ *@
    <main class="lg:ml-64 min-h-screen flex flex-col">

        @* ── Top bar (glass morphism — The Modern Hearth) ──── *@
        <header class="sticky top-0 z-20 px-6 py-3.5 flex items-center justify-between"
                style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); -webkit-backdrop-filter: blur(var(--glass-blur)); border-bottom: 1px solid var(--sidebar-border);">
            <button @@click="sidebarOpen = !sidebarOpen"
                    class="lg:hidden p-2 -ml-2 rounded-xl hover:bg-black/5 transition-colors" style="color: var(--fg-2);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>

            <div class="flex items-center gap-1 text-sm ml-auto" style="color: var(--meta);">
                <span class="hidden sm:inline">Default Bakery</span>
                <span class="mx-1 hidden sm:inline" style="color: var(--meta);">·</span>
            </div>

            @* User avatar *@
            <div class="flex items-center gap-2.5 ml-2">
                <div class="w-8 h-8 bg-gradient-to-br from-brand-400 to-brand-600 rounded-full flex items-center justify-center text-white font-semibold text-xs shadow-sm ring-2 ring-white">
                    U
                </div>
            </div>
        </header>

        @* ── Page content ───────────────────────────────────── *@
        <div class="flex-1 p-6 fade-in">
            @RenderBody()
        </div>
    </main>

    @* ── Modal container ────────────────────────────────────── *@
    <div id="modal-container"></div>

    @* ── Toast container ────────────────────────────────────── *@
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2" x-data="toast">
        <template x-for="toast in toasts" :key="toast.id">
            <div :id="'toast-' + toast.id"
                 class="toast-enter flex items-center gap-3 px-4 py-3 rounded-2xl shadow-modal"
                 style="background: var(--surface-container-lowest); max-width: 360px; pointer-events: auto;"
                 @@click="removeToast(toast.id)">
                <span x-html="toast.icon"></span>
                <p class="text-sm font-medium" style="color: var(--fg);" x-text="toast.message"></p>
            </div>
        </template>
    </div>

    @* ═══════════════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════════════ *@
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('appShell', () => ({
                sidebarOpen: false,
            }));

            // ── panaSelect — Custom dropdown replacing native <select> ──
            // Wrap a hidden <select x-ref="native"> and a
            // <button x-ref="trigger"> inside a x-data="panaSelect" div.
            // Options are read from the native <select> automatically.
            // Supports: search, keyboard nav, click-outside, danger variant.
            Alpine.data('panaSelect', () => ({
                open: false,
                value: '',
                displayText: '',
                placeholder: '',
                query: '',
                highlightIndex: -1,
                options: [],
                _dropdownTop: 0,
                _dropdownLeft: 0,
                _dropdownWidth: 0,
                _variant: 'default',

                init() {
                    const native = this.$refs.native;
                    if (!native) return;

                    // Prevent native select from receiving focus
                    native.setAttribute('tabindex', '-1');
                    native.setAttribute('aria-hidden', 'true');

                    // Check for danger variant marker
                    this._variant = native.dataset.panaVariant || 'default';

                    // Read options from the native select
                    this.options = Array.from(native.options).map((o, i) => ({
                        value: o.value,
                        label: o.textContent.trim(),
                        index: i,
                        dataset: Object.assign({}, o.dataset),
                    }));

                    // Placeholder = first option with empty value
                    const first = this.options[0];
                    if (first && first.value === '') {
                        this.placeholder = first.label;
                    } else {
                        this.placeholder = 'Seleccionar...';
                    }

                    this.value = native.value;
                    this.updateDisplay();

                    // Sync value → native select
                    this.$watch('value', v => {
                        native.value = v;
                        native.dispatchEvent(new Event('change', { bubbles: true }));
                        this.updateDisplay();
                    });

                    // Listen for external native select changes (HTMX form reset, etc.)
                    native.addEventListener('change', () => {
                        if (native.value !== this.value) {
                            this.value = native.value;
                            this.updateDisplay();
                        }
                    });

                    // Recalculate position on scroll/resize
                    this._onWinEvent = () => { if (this.open) this._reposition(); };
                    window.addEventListener('scroll', this._onWinEvent, true);
                    window.addEventListener('resize', this._onWinEvent);
                },

                destroy() {
                    window.removeEventListener('scroll', this._onWinEvent, true);
                    window.removeEventListener('resize', this._onWinEvent);
                },

                get filteredOptions() {
                    const q = this.query.toLowerCase().trim();
                    return this.options.filter(o => {
                        if (o.value === '') return false; // skip placeholder
                        if (!q) return true;
                        return o.label.toLowerCase().includes(q);
                    });
                },

                get dropdownStyle() {
                    return {
                        top: this._dropdownTop + 'px',
                        left: this._dropdownLeft + 'px',
                        width: this._dropdownWidth + 'px',
                    };
                },

                toggle() {
                    this.open = !this.open;
                    if (this.open) {
                        this.$nextTick(() => {
                            this._reposition();
                            this.query = '';
                            this.highlightIndex = this.filteredOptions.findIndex(o => o.value === this.value);
                            const search = this.$refs.search;
                            if (search) setTimeout(() => search.focus(), 50);
                        });
                    }
                },

                close() {
                    this.open = false;
                    const trigger = this.$refs.trigger;
                    if (trigger) setTimeout(() => trigger.focus(), 50);
                },

                select(opt) {
                    this.value = opt.value;
                    this.close();
                },

                updateDisplay() {
                    const opt = this.options.find(o => o.value === this.value);
                    this.displayText = (opt && opt.value !== '') ? opt.label : this.placeholder;
                },

                _reposition() {
                    const trigger = this.$refs.trigger;
                    if (!trigger) return;
                    const rect = trigger.getBoundingClientRect();
                    const maxH = 320;
                    const spaceBelow = window.innerHeight - rect.bottom;
                    const spaceAbove = rect.top;

                    this._dropdownWidth = Math.max(rect.width, 192); // min 12rem
                    this._dropdownLeft = rect.left;

                    if (spaceBelow >= maxH || spaceBelow >= spaceAbove) {
                        this._dropdownTop = rect.bottom + 4;
                    } else {
                        this._dropdownTop = Math.max(4, rect.top - maxH - 4);
                    }
                },

                // ── Keyboard ──────────────────────────
                onTriggerKey(e) {
                    if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                        e.preventDefault();
                        this.open = true;
                        this.$nextTick(() => {
                            this._reposition();
                            const search = this.$refs.search;
                            if (search) setTimeout(() => search.focus(), 50);
                        });
                    }
                },

                onDropdownKey(e) {
                    const filtered = this.filteredOptions;
                    if (e.key === 'Escape') {
                        e.preventDefault();
                        this.close();
                        return;
                    }
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        this.highlightIndex = Math.min(this.highlightIndex + 1, filtered.length - 1);
                        this._scrollToHighlight();
                        return;
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        this.highlightIndex = Math.max(this.highlightIndex - 1, 0);
                        this._scrollToHighlight();
                        return;
                    }
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        const opt = filtered[this.highlightIndex];
                        if (opt) this.select(opt);
                        return;
                    }
                },

                onSearchKey(e) {
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        this.highlightIndex = 0;
                        this.$nextTick(() => {
                            const list = this.$refs.optionsList;
                            const first = list?.querySelector('.pana-select-option');
                            if (first) first.focus();
                        });
                    }
                },

                onOptionKey(e, opt, i) {
                    const filtered = this.filteredOptions;
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        const next = this.$refs.optionsList?.children[i + 1];
                        if (next) next.focus();
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (i === 0) { this.$refs.search?.focus(); return; }
                        const prev = this.$refs.optionsList?.children[i - 1];
                        if (prev) prev.focus();
                    }
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.select(opt);
                    }
                    if (e.key === 'Escape') {
                        e.preventDefault();
                        this.close();
                    }
                },

                _scrollToHighlight() {
                    this.$nextTick(() => {
                        const list = this.$refs.optionsList;
                        const el = list?.children[this.highlightIndex];
                        if (el) el.scrollIntoView({ block: 'nearest' });
                    });
                },
            }));

            Alpine.data('toast', () => ({
                toasts: [],
                addToast(message, type = 'info', duration = 4000) {
                    const id = Date.now() + Math.random();
                    const icons = {
                        success: `<svg class="w-5 h-5" style="color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        error: `<svg class="w-5 h-5" style="color: var(--danger);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        info: `<svg class="w-5 h-5" style="color: var(--primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        warning: `<svg class="w-5 h-5" style="color: var(--warn);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>`,
                    };
                    this.toasts.push({ id, message, type, icon: icons[type] || icons.info });
                    setTimeout(() => this.removeToast(id), duration);
                },
                removeToast(id) {
                    const el = document.getElementById('toast-' + id);
                    if (el) {
                        el.classList.add('toast-exit');
                        setTimeout(() => {
                            this.toasts = this.toasts.filter(t => t.id !== id);
                        }, 300);
                    }
                }
            }));
        });

        // ── Global toast helper (callable from anywhere) ──────
        window.showToast = function(message, type = 'info') {
            const container = document.getElementById('toast-container');
            if (!container || !container.__x) return;
            container.__x.$data.addToast(message, type);
        };

        // ── HTMX: after swap, show toast if header present ────
        document.addEventListener('htmx:afterSwap', function(evt) {
            const toastMsg = evt.detail.xhr.getResponseHeader('X-Toast-Message');
            const toastType = evt.detail.xhr.getResponseHeader('X-Toast-Type') || 'info';
            if (toastMsg) window.showToast(decodeURIComponent(toastMsg), toastType);
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
