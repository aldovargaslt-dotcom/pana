<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Pana</title>

    @* ── Google Fonts (Inter) ───────────────────────────────── *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    @* ── Pana Design Tokens (Open Design schema) ────────────── *@
    <link rel="stylesheet" href="/css/pana-tokens.css" />

    @* ── Tailwind CSS v4 (CDN) ──────────────────────────────── *@
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
                    },
                    colors: {
                        // ── Semantic design tokens (Open Design schema) ──
                        accent: 'var(--accent)',
                        'accent-hover': 'var(--accent-hover)',
                        'accent-active': 'var(--accent-active)',
                        surface: 'var(--surface)',
                        'surface-warm': 'var(--surface-warm)',
                        fg: 'var(--fg)',
                        muted: 'var(--muted)',
                        border: 'var(--border)',
                        'border-soft': 'var(--border-soft)',
                        success: 'var(--success)',
                        warn: 'var(--warn)',
                        danger: 'var(--danger)',
                        // ── Brand palette (backward compat + gradients) ──
                        brand: {
                            50: '#eef2ff',
                            100: '#e0e7ff',
                            200: '#c7d2fe',
                            300: '#a5b4fc',
                            400: '#818cf8',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                            800: '#3730a3',
                            900: '#312e81',
                            950: '#1e1b4b',
                        }
                    },
                    boxShadow: {
                        'soft': '0 2px 15px -3px rgba(0, 0, 0, 0.07), 0 10px 20px -2px rgba(0, 0, 0, 0.04)',
                        'glow': '0 0 20px rgba(99, 102, 241, 0.3)',
                        'card': 'var(--elev-raised)',
                    }
                }
            }
        }
    </script>

    @* ── HTMX 2.0 ────────────────────────────────────────────── *@
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>

    @* ── Alpine.js ───────────────────────────────────────────── *@
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js"></script>

    @* ── Chart.js ────────────────────────────────────────────── *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js"></script>

    @* ── Base styles ─────────────────────────────────────────── *@
    <style>
        /* ── Scrollbar ──────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

        /* ── Selection ──────────────────────────────── */
        ::selection { background: var(--accent); color: var(--accent-on); }

        /* ── HTMX animations ────────────────────────── */
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-flex; }
        .htmx-request.htmx-indicator { display: inline-flex; }

        /* ── Page transitions ───────────────────────── */
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

        .slide-in-right { animation: slideInRight 0.35s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        .scale-in { animation: scaleIn 0.2s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes scaleIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

        /* ── Skeleton loading ───────────────────────── */
        .skeleton {
            background: linear-gradient(110deg, #e5e7eb 8%, #f3f4f6 18%, #e5e7eb 33%);
            background-size: 200% 100%;
            animation: shimmer 1.5s ease-in-out infinite;
            border-radius: 6px;
        }
        @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* ── Toast animations ───────────────────────── */
        .toast-enter { animation: toastIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        @@keyframes toastIn { from { opacity: 0; transform: translateX(100px) scale(0.95); } to { opacity: 1; transform: translateX(0) scale(1); } }

        .toast-exit { animation: toastOut 0.3s ease-in forwards; }
        @@keyframes toastOut { to { opacity: 0; transform: translateX(100px) scale(0.95); } }

        /* ── Pulse dot ──────────────────────────────── */
        .pulse-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--fresh-green); display: inline-block;
            animation: pulseDot 2s ease-in-out infinite;
        }
        @@keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.3); }
        }

        /* ── Gradient text utility ──────────────────── */
        .text-gradient {
            background: linear-gradient(135deg, var(--accent), var(--chart-5));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body class="bg-gray-50/80 min-h-screen font-sans antialiased" x-data="appShell">

    @* ═══════════════════════════════════════════════════════════
       SIDEBAR
       ═══════════════════════════════════════════════════════════ *@
    <aside class="fixed left-0 top-0 h-full w-64 z-40
                   bg-gradient-to-b from-brand-950 via-brand-900 to-brand-950
                   transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
           :class="{ '-translate-x-full': !sidebarOpen, 'translate-x-0': sidebarOpen }">

        @* Brand *@
        <div class="flex items-center gap-3 px-6 py-6 border-b border-white/10">
            <div class="w-10 h-10 bg-gradient-to-br from-brand-400 to-brand-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-glow">
                P
            </div>
            <div>
                <span class="font-bold text-white text-lg tracking-tight">Pana</span>
                <p class="text-brand-300/60 text-xs">Business Platform</p>
            </div>
        </div>

        @* Navigation *@
        <nav class="p-4 space-y-1.5">
            <a href="/"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path == "/"
                          ? "bg-white/15 text-white shadow-sm"
                          : "text-brand-200/70 hover:bg-white/8 hover:text-white")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/></svg>
                Dashboard
            </a>
            <a href="/products"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/products")
                          ? "bg-white/15 text-white shadow-sm"
                          : "text-brand-200/70 hover:bg-white/8 hover:text-white")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Productos
            </a>
            <a href="/sales"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/sales")
                          ? "bg-white/15 text-white shadow-sm"
                          : "text-brand-200/70 hover:bg-white/8 hover:text-white")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Ventas
            </a>
            <a href="/waste"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/waste")
                          ? "bg-white/15 text-white shadow-sm"
                          : "text-brand-200/70 hover:bg-white/8 hover:text-white")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Desperdicios
            </a>
            <a href="/production"
               class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-200
                      @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/production")
                          ? "bg-white/15 text-white shadow-sm"
                          : "text-brand-200/70 hover:bg-white/8 hover:text-white")">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                Producción
            </a>
        </nav>

        @* Footer *@
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-white/10">
            <div class="flex items-center gap-3 px-3 py-2 rounded-xl bg-white/5">
                <div class="w-8 h-8 bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">DB</div>
                <div>
                    <p class="text-white/90 text-xs font-medium">Default Bakery</p>
                    <p class="text-brand-300/50 text-[10px] flex items-center gap-1"><span class="pulse-dot"></span> Activo</p>
                </div>
            </div>
        </div>
    </aside>

    @* ── Overlay (mobile) ───────────────────────────────────── *@
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-30 lg:hidden"
         x-show="sidebarOpen"
         x-transition.opacity.duration.300ms
         @@click="sidebarOpen = false"></div>

    @* ═══════════════════════════════════════════════════════════
       MAIN CONTENT
       ═══════════════════════════════════════════════════════════ *@
    <main class="lg:ml-64 min-h-screen flex flex-col">

        @* ── Top bar (glass morphism) ───────────────────────── *@
        <header class="sticky top-0 z-20 bg-white/70 backdrop-blur-xl border-b border-gray-200/50 px-6 py-3.5 flex items-center justify-between">
            <button @@click="sidebarOpen = !sidebarOpen"
                    class="lg:hidden p-2 -ml-2 rounded-xl hover:bg-gray-100 text-gray-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>

            <div class="flex items-center gap-1 text-sm text-gray-400 ml-auto">
                <span class="hidden sm:inline">Default Bakery</span>
                <span class="text-gray-300 mx-1 hidden sm:inline">·</span>
            </div>

            @* User avatar *@
            <div class="flex items-center gap-2.5 ml-2">
                <div class="w-8 h-8 bg-gradient-to-br from-brand-400 to-brand-600 rounded-full flex items-center justify-center text-white font-semibold text-xs shadow-sm ring-2 ring-white">
                    U
                </div>
            </div>
        </header>

        @* ── Page content ───────────────────────────────────── *@
        <div class="flex-1 p-6 fade-in">
            @RenderBody()
        </div>
    </main>

    @* ── Modal container ────────────────────────────────────── *@
    <div id="modal-container"></div>

    @* ── Toast container ────────────────────────────────────── *@
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2 pointer-events-none"></div>

    @* ═══════════════════════════════════════════════════════════
       SCRIPTS
       ═══════════════════════════════════════════════════════════ *@
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('appShell', () => ({
                sidebarOpen: false,
            }));

            Alpine.data('toast', () => ({
                toasts: [],
                addToast(message, type = 'info', duration = 4000) {
                    const id = Date.now() + Math.random();
                    const icons = {
                        success: `<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        error: `<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        info: `<svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                        warning: `<svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>`,
                    };
                    this.toasts.push({ id, message, type, icon: icons[type] || icons.info });
                    setTimeout(() => this.removeToast(id), duration);
                },
                removeToast(id) {
                    const el = document.getElementById('toast-' + id);
                    if (el) {
                        el.classList.add('toast-exit');
                        setTimeout(() => {
                            this.toasts = this.toasts.filter(t => t.id !== id);
                        }, 300);
                    }
                }
            }));
        });

        // ── Global toast helper (callable from anywhere) ──────
        window.showToast = function(message, type = 'info') {
            const container = document.getElementById('toast-container');
            if (!container || !container.__x) return;
            container.__x.$data.addToast(message, type);
        };

        // ── HTMX: after swap, show toast if header present ────
        document.addEventListener('htmx:afterSwap', function(evt) {
            const toastMsg = evt.detail.xhr.getResponseHeader('X-Toast-Message');
            const toastType = evt.detail.xhr.getResponseHeader('X-Toast-Type') || 'info';
            if (toastMsg) window.showToast(decodeURIComponent(toastMsg), toastType);
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
