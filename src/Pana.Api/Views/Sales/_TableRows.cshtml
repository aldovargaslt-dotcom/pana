@model List<Pana.Api.Web.ViewModels.SaleRowViewModel>

@if (Model.Count == 0)
{
    <tr>
        <td colspan="6" class="p-12">
            @await Component.InvokeAsync("EmptyState", new {
                title = "Sin ventas",
                description = "Las ventas aparecerán aquí cuando se registren."
            })
        </td>
    </tr>
}
else
{
    @foreach (var sale in Model)
    {
        <tr class="hover:bg-gray-50 transition-colors fade-in"
            id="sale-row-@sale.Id">
            <td class="px-4 py-3">
                <p class="font-medium text-gray-900">#@sale.Id.ToString()[..8]</p>
            </td>
            <td class="px-4 py-3">
                <pana-badge variant="@(sale.Status == "completed" ? "success" : sale.Status == "voided" ? "danger" : "warning")">
                    @(sale.Status == "completed" ? "Completada" : sale.Status == "voided" ? "Anulada" : "Pendiente")
                </pana-badge>
            </td>
            <td class="px-4 py-3 text-gray-600">@sale.ItemCount</td>
            <td class="px-4 py-3 font-semibold text-gray-900">$@sale.TotalAmount.ToString("N2")</td>
            <td class="px-4 py-3 text-sm text-gray-500">@sale.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            <td class="px-4 py-3">
                <button hx-get="/sales/@sale.Id"
                        hx-target="#modal-container"
                        class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors"
                        title="Ver detalle">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </td>
        </tr>
    }
}
