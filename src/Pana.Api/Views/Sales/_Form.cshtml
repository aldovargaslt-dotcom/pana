@model Pana.Api.Web.ViewModels.SaleFormViewModel
@{
    var products = ViewBag.Products as List<dynamic>;
    var modalId = "sale-form-" + Guid.NewGuid().ToString("N")[..6];
}

@* ── Modal wrapper ─────────────────────────────────────────── *@
<div id="@modalId"
     style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)"
     onclick="if(event.target===this)this.remove()">

    <div style="background:var(--surface-container-lowest);border-radius:16px;box-shadow:var(--elev-modal);width:100%;max-width:36rem;max-height:85vh;display:flex;flex-direction:column"
         onclick="event.stopPropagation()">

        @* Header — tonal separation, no border *@
        <div class="flex items-center justify-between px-6 py-4 rounded-t-2xl"
             style="background: var(--surface-container-low);">
            <h2 class="text-lg font-semibold" style="color: var(--fg);">Nueva Venta</h2>
            <button onclick="document.getElementById('@modalId').remove()"
                    class="p-2 rounded-xl transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                    onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6">
            <form hx-post="/sales/create"
                  hx-target="#table-body-sales"
                  hx-swap="innerHTML"
                  hx-on::after-request="if(event.detail.successful) document.getElementById('@modalId').remove()"
                  class="space-y-5">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="text-sm rounded-xl p-4" style="color: var(--danger); background: color-mix(in srgb, var(--danger) 10%, transparent);">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <div id="sale-items-container" class="space-y-3">
                    @if (Model.Items != null && Model.Items.Count > 0)
                    {
                        for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <div class="sale-item-row flex items-end gap-3 p-4 rounded-xl" style="background: var(--surface-container-low);">
                                <div class="flex-1">
                                    <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producto</label>
                                <div x-data="panaSelect" class="pana-select-wrapper">
                                    <select x-ref="native" name="Items[@i].ProductId" class="sr-only">
                                        <option value="">Seleccionar...</option>
                                        @foreach (var p in products!)
                                        {
                                            var selected = Model.Items[i].ProductId == (Guid)p.Id;
                                            <!option value="@p.Id" @(selected ? "selected" : "") data-price="@p.Price">@p.Name — $@p.Price.ToString("F2")</!option>
                                        }
                                    </select>
                                    <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                            class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                                        <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                                        <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                                    </button>
                                    <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                                         class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                                        <div class="pana-select-search">
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                            <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                                        </div>
                                        <div x-ref="optionsList" class="pana-select-options">
                                            <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                                <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                                     @@mouseenter="highlightIndex = i" tabindex="0"
                                                     class="pana-select-option"
                                                     :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                                    <span x-text="opt.label"></span>
                                                    <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                                </div>
                                            </template>
                                            <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                                        </div>
                                    </div>
                                </div>
                                </div>
                                <div class="w-28">
                                    <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Cantidad</label>
                                    <input type="number" name="Items[@i].Quantity" value="@Model.Items[i].Quantity"
                                           min="1" required
                                           class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                           style="background: var(--surface-container-high); color: var(--fg);"
                                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                                </div>
                                <div class="w-28">
                                    <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Precio unit.</label>
                                    <input type="number" name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice.ToString("F2")"
                                           step="0.01" min="0" required
                                           class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                           style="background: var(--surface-container-high); color: var(--fg);"
                                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                                </div>
                                <button type="button"
                                        class="p-2.5 rounded-xl transition-colors"
                                        style="color: var(--meta);"
                                        onmouseover="this.style.color='var(--danger)'; this.style.background='color-mix(in srgb, var(--danger) 12%, transparent)'"
                                        onmouseout="this.style.color='var(--meta)'; this.style.background='transparent'"
                                        onclick="this.closest('.sale-item-row').remove()"
                                        title="Quitar">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        @* Default empty row *@
                        <div class="sale-item-row flex items-end gap-3 p-4 rounded-xl" style="background: var(--surface-container-low);">
                            <div class="flex-1">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Producto</label>
                            <div x-data="panaSelect" class="pana-select-wrapper">
                                <select x-ref="native" name="Items[0].ProductId" class="sr-only">
                                    <option value="">Seleccionar...</option>
                                    @foreach (var p in products!)
                                    {
                                        <!option value="@p.Id" data-price="@p.Price">@p.Name — $@p.Price.ToString("F2")</!option>
                                    }
                                </select>
                                <button type="button" x-ref="trigger" @@click="toggle" @@keydown="onTriggerKey"
                                        class="pana-select-trigger" :class="{ 'pana-select-trigger-open': open }">
                                    <span x-text="displayText" :class="{ 'text-muted': !value }"></span>
                                    <svg class="pana-select-chevron" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6"/></svg>
                                </button>
                                <div x-show="open" x-transition @@click.outside="close" x-ref="dropdown"
                                     class="pana-select-dropdown" :style="dropdownStyle" @@keydown="onDropdownKey">
                                    <div class="pana-select-search">
                                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
                                        <input x-ref="search" x-model="query" @@keydown="onSearchKey" placeholder="Buscar..." autocomplete="off">
                                    </div>
                                    <div x-ref="optionsList" class="pana-select-options">
                                        <template x-for="(opt, i) in filteredOptions" :key="opt.value">
                                            <div @@click="select(opt)" @@keydown="onOptionKey($event, opt, i)"
                                                 @@mouseenter="highlightIndex = i" tabindex="0"
                                                 class="pana-select-option"
                                                 :class="{ 'pana-select-option-selected': opt.value === value, 'pana-select-option-highlighted': highlightIndex === i }">
                                                <span x-text="opt.label"></span>
                                                <svg x-show="opt.value === value" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                                            </div>
                                        </template>
                                        <div x-show="filteredOptions.length === 0" class="pana-select-empty">Sin resultados</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="w-28">
                            <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Cantidad</label>
                            <input type="number" name="Items[0].Quantity" value="1"
                                       min="1" required
                                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                            </div>
                            <div class="w-28">
                                <label class="block text-xs font-medium mb-1" style="color: var(--muted);">Precio unit.</label>
                                <input type="number" name="Items[0].UnitPrice" value="0.00"
                                       step="0.01" min="0" required
                                       class="w-full px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                                       style="background: var(--surface-container-high); color: var(--fg);"
                                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                            </div>
                            <button type="button"
                                    class="p-2.5 rounded-xl transition-colors"
                                    style="color: var(--meta);"
                                    onmouseover="this.style.color='var(--danger)'; this.style.background='color-mix(in srgb, var(--danger) 12%, transparent)'"
                                    onmouseout="this.style.color='var(--meta)'; this.style.background='transparent'"
                                    onclick="this.closest('.sale-item-row').remove()"
                                    title="Quitar">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </button>
                        </div>
                    }
                </div>

                @* Add item button *@
                <button type="button"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl transition-colors"
                        style="color: var(--primary); background: color-mix(in srgb, var(--primary) 8%, transparent);"
                        onmouseover="this.style.background='color-mix(in srgb, var(--primary) 14%, transparent)'"
                        onmouseout="this.style.background='color-mix(in srgb, var(--primary) 8%, transparent)'"
                        onclick="addSaleItem()">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Agregar otro producto
                </button>

                @* Notes *@
                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Notas (opcional)</label>
                    <textarea name="Notes" rows="2"
                              class="w-full px-4 py-2.5 rounded-xl text-sm resize-none focus:outline-none focus:ring-2"
                              style="background: var(--surface-container-high); color: var(--fg);"
                              onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                              onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"
                              placeholder="Ej. Pedido para llevar...">@Model.Notes</textarea>
                </div>

                @* Actions *@
                <div class="flex items-center justify-end gap-3 pt-3" style="background: var(--surface-container-low); margin: 0 -1.5rem -1.5rem; padding: 0.75rem 1.5rem; border-radius: 0 0 16px 16px;">
                    <button type="button" onclick="document.getElementById('@modalId').remove()"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 cursor-pointer active:scale-[0.97]"
                            style="color: var(--fg-2);"
                            onmouseover="this.style.background='var(--surface-container)'"
                            onmouseout="this.style.background='transparent'">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-semibold rounded-xl
                                   transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                            style="background: var(--success);">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Crear Venta
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Close on Escape key *@
<script>
    (function() {
        var modal = document.getElementById('@modalId');
        console.log('[Pana] Sale modal loaded:', '@modalId', modal);
        if (!modal) return;
        function onKey(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onKey); } }
        document.addEventListener('keydown', onKey);
        new MutationObserver(function() {
            if (!document.getElementById('@modalId')) document.removeEventListener('keydown', onKey);
        }).observe(document.body, { childList: true, subtree: true });
    })();
</script>

<script>
    var saleItemCount = @((Model.Items?.Count ?? 1));
    function addSaleItem() {
        var container = document.getElementById('sale-item-container-template');
        if (!container) return;
        var clone = container.content.cloneNode(true);
        clone.querySelectorAll('[name]').forEach(function(el) {
            el.name = el.name.replace(/\[\d+\]/, '[' + saleItemCount + ']');
        });
        document.getElementById('sale-items-container').appendChild(clone);
        saleItemCount++;
    }
</script>

