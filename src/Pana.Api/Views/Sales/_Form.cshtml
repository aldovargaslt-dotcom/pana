@model Pana.Api.Web.ViewModels.SaleFormViewModel
@{
    var products = ViewBag.Products as List<dynamic>;
    var modalId = "sale-form-" + Guid.NewGuid().ToString("N")[..6];
}

@* ── Modal wrapper ─────────────────────────────────────────── *@
<div id="@modalId"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
     x-data="{ open: true }"
     x-show="open"
     x-transition.opacity.duration.200ms
     @@keydown.escape.window="open = false">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl p-0 max-h-[85vh] flex flex-col scale-in"
         @@click.outside="open = false">

        @* Header *@
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800">Nueva Venta</h2>
            <button @@click="open = false"
                    class="p-2 rounded-xl hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6">
            <form hx-post="/sales/create"
                  hx-target="#table-body-sales"
                  hx-swap="innerHTML"
                  class="space-y-5"
                  @@htmx:after-request="if(event.detail.successful) open = false">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-100 text-red-700 text-sm rounded-xl p-4">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <div id="sale-items-container" class="space-y-3">
                    @if (Model.Items != null && Model.Items.Count > 0)
                    {
                        for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <div class="sale-item-row flex items-end gap-3 p-4 bg-gray-50 rounded-xl">
                                <div class="flex-1">
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Producto</label>
                                    <select name="Items[@i].ProductId"
                                            class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                                   focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300">
                                        <option value="">Seleccionar...</option>
                                        @foreach (var p in products!)
                                        {
                                            var selected = Model.Items[i].ProductId == (Guid)p.Id;
                                            <!option value="@p.Id" @(selected ? "selected" : "") data-price="@p.Price">@p.Name — $@p.Price.ToString("F2")</!option>
                                        }
                                    </select>
                                </div>
                                <div class="w-28">
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Cantidad</label>
                                    <input type="number" name="Items[@i].Quantity" value="@Model.Items[i].Quantity"
                                           min="1" required
                                           class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                                  focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
                                </div>
                                <div class="w-28">
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Precio unit.</label>
                                    <input type="number" name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice.ToString("F2")"
                                           step="0.01" min="0" required
                                           class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                                  focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
                                </div>
                                <button type="button"
                                        class="p-2.5 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-colors"
                                        onclick="this.closest('.sale-item-row').remove()"
                                        title="Quitar">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        @* Default empty row *@
                        <div class="sale-item-row flex items-end gap-3 p-4 bg-gray-50 rounded-xl">
                            <div class="flex-1">
                                <label class="block text-xs font-medium text-gray-500 mb-1">Producto</label>
                                <select name="Items[0].ProductId"
                                        class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                               focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300">
                                    <option value="">Seleccionar...</option>
                                    @foreach (var p in products!)
                                    {
                                        <!option value="@p.Id" data-price="@p.Price">@p.Name — $@p.Price.ToString("F2")</!option>
                                    }
                                </select>
                            </div>
                            <div class="w-28">
                                <label class="block text-xs font-medium text-gray-500 mb-1">Cantidad</label>
                                <input type="number" name="Items[0].Quantity" value="1"
                                       min="1" required
                                       class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                              focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
                            </div>
                            <div class="w-28">
                                <label class="block text-xs font-medium text-gray-500 mb-1">Precio unit.</label>
                                <input type="number" name="Items[0].UnitPrice" value="0.00"
                                       step="0.01" min="0" required
                                       class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                                              focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
                            </div>
                            <button type="button"
                                    class="p-2.5 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-colors"
                                    onclick="this.closest('.sale-item-row').remove()"
                                    title="Quitar">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </button>
                        </div>
                    }
                </div>

                @* Add item button *@
                <button type="button"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-brand-600
                               bg-brand-50 hover:bg-brand-100 rounded-xl transition-colors"
                        onclick="addSaleItem()">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Agregar otro producto
                </button>

                @* Notes *@
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Notas (opcional)</label>
                    <textarea name="Notes" rows="2"
                              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm resize-none
                                     focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300"
                              placeholder="Ej. Pedido para llevar...">@Model.Notes</textarea>
                </div>

                @* Actions *@
                <div class="flex items-center justify-end gap-3 pt-3 border-t border-gray-100">
                    <button type="button" @@click="open = false"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 text-gray-600 hover:bg-gray-100 cursor-pointer active:scale-[0.97]">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-emerald-500 to-emerald-600
                                   text-white text-sm font-semibold rounded-xl hover:from-emerald-600 hover:to-emerald-700
                                   transition-all duration-200 shadow-sm hover:shadow-md active:scale-[0.98]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Crear Venta
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    var saleItemCount = @((Model.Items?.Count ?? 1));
    function addSaleItem() {
        var container = document.getElementById('sale-item-container-template');
        if (!container) return;
        var clone = container.content.cloneNode(true);
        clone.querySelectorAll('[name]').forEach(function(el) {
            el.name = el.name.replace(/\[\d+\]/, '[' + saleItemCount + ']');
        });
        document.getElementById('sale-items-container').appendChild(clone);
        saleItemCount++;
    }
</script>

@* Hidden template for new rows *@
<template id="sale-item-container-template">
    <div class="sale-item-row flex items-end gap-3 p-4 bg-gray-50 rounded-xl">
        <div class="flex-1">
            <label class="block text-xs font-medium text-gray-500 mb-1">Producto</label>
            <select name="Items[0].ProductId"
                    class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                           focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300">
                <option value="">Seleccionar...</option>
                @foreach (var p in products!)
                {
                    <!option value="@p.Id" data-price="@p.Price">@p.Name — $@p.Price.ToString("F2")</!option>
                }
            </select>
        </div>
        <div class="w-28">
            <label class="block text-xs font-medium text-gray-500 mb-1">Cantidad</label>
            <input type="number" name="Items[0].Quantity" value="1"
                   min="1" required
                   class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                          focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
        </div>
        <div class="w-28">
            <label class="block text-xs font-medium text-gray-500 mb-1">Precio unit.</label>
            <input type="number" name="Items[0].UnitPrice" value="0.00"
                   step="0.01" min="0" required
                   class="w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm
                          focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300" />
        </div>
        <button type="button"
                class="p-2.5 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-colors"
                onclick="this.closest('.sale-item-row').remove()"
                title="Quitar">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
</template>
