@model Pana.Api.Application.Sales.SaleDto

<div class="space-y-6">
    @* Summary cards *@
    <div class="grid grid-cols-3 gap-4">
        <div class="rounded-xl p-4 text-center" style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
            <p class="text-xs mb-1" style="color: var(--muted);">Total</p>
            <p class="text-xl font-bold" style="color: var(--fg);">$@Model.TotalAmount.ToString("N2")</p>
        </div>
        <div class="rounded-xl p-4 text-center" style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
            <p class="text-xs mb-1" style="color: var(--muted);">Items</p>
            <p class="text-xl font-bold" style="color: var(--fg);">@Model.Items.Count</p>
        </div>
        <div class="rounded-xl p-4 text-center flex flex-col items-center justify-center" style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
            <p class="text-xs mb-1.5" style="color: var(--muted);">Estado</p>
            @{
                var (statusBg, statusDot) = Model.Status switch
                {
                    "completed" => ($"color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);", "background: var(--success);"),
                    "draft" => ($"color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 12%, transparent);", "background: var(--tertiary);"),
                    "voided" => ($"color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);", "background: var(--danger);"),
                    _ => ($"color: var(--muted); background: var(--surface-container);", "background: var(--meta);")
                };
            }
            <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-full" style="@statusBg">
                <span class="w-1.5 h-1.5 rounded-full" style="@statusDot"></span>
                @Model.Status
            </span>
        </div>
    </div>

    @* Line items *@
    <div>
        <h4 class="text-sm font-semibold mb-3" style="color: var(--fg-2);">Detalle de items</h4>
        <div class="rounded-xl overflow-hidden shadow-ambient" style="background: var(--surface-container-lowest);">
            <table class="w-full text-sm">
                <thead style="background: var(--surface-container-low);">
                    <tr>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Producto</th>
                        <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Precio</th>
                        <th class="px-4 py-2.5 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Cant.</th>
                        <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="table-tonal">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="@(item.IsVoided ? "opacity-40 line-through" : "")">
                            <td class="px-4 py-2.5 font-medium" style="color: var(--fg);">@item.ProductName</td>
                            <td class="px-4 py-2.5 text-right" style="color: var(--fg-2);">$@item.UnitPrice.ToString("N2")</td>
                            <td class="px-4 py-2.5 text-center" style="color: var(--fg-2);">@item.Quantity</td>
                            <td class="px-4 py-2.5 text-right font-semibold" style="color: var(--fg);">$@item.LineTotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Notes *@
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="rounded-xl p-4 flex items-start gap-3" style="background: color-mix(in srgb, var(--tertiary) 10%, transparent);">
            <svg class="w-5 h-5 flex-shrink-0" style="color: var(--tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <p class="text-sm" style="color: var(--tertiary);">@Model.Notes</p>
        </div>
    }

    @* Pre-order details *@
    @if (Model.OrderType == "PreOrder")
    {
        <div class="rounded-xl p-4 space-y-2" style="background: var(--surface-container-low);">
            <h4 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Detalles de pre-orden</h4>
            <div class="grid grid-cols-2 gap-2 text-sm">
                @if (!string.IsNullOrWhiteSpace(Model.CustomerName))
                {
                    <div>
                        <span class="text-xs" style="color: var(--meta);">Cliente</span>
                        <p style="color: var(--fg);">@Model.CustomerName</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
                {
                    <div>
                        <span class="text-xs" style="color: var(--meta);">Teléfono</span>
                        <p style="color: var(--fg);">@Model.CustomerPhone</p>
                    </div>
                }
                @if (Model.ScheduledDate.HasValue)
                {
                    <div>
                        <span class="text-xs" style="color: var(--meta);">Entrega programada</span>
                        <p style="color: var(--fg);">@Model.ScheduledDate.Value.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                }
                <div>
                    <span class="text-xs" style="color: var(--meta);">Anticipo</span>
                    <p style="color: var(--fg);">$@Model.DepositAmount.ToString("N2")</p>
                </div>
                <div>
                    <span class="text-xs" style="color: var(--meta);">Saldo pendiente</span>
                    <p style="color: var(--fg);">$@Model.BalanceDue.ToString("N2")</p>
                </div>
                <div>
                    <span class="text-xs" style="color: var(--meta);">Pago</span>
                    <p style="color: var(--fg);">@Model.PaymentStatus</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.PaymentMethod))
                {
                    <div>
                        <span class="text-xs" style="color: var(--meta);">Método</span>
                        <p style="color: var(--fg);">@Model.PaymentMethod</p>
                    </div>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.InternalNotes))
            {
                <div class="pt-3">
                    <span class="text-xs" style="color: var(--meta);">Notas internas</span>
                    <p class="text-sm mt-1" style="color: var(--fg-2);">@Model.InternalNotes</p>
                </div>
            }
        </div>
    }

    <p class="text-xs" style="color: var(--meta);">Creada: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
</div>
