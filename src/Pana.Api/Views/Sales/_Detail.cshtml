@model Pana.Api.Application.Sales.SaleDto

<div class="space-y-5">
    @* Summary *@
    <div class="grid grid-cols-3 gap-3">
        <div class="bg-gray-50 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500">Total</p>
            <p class="text-lg font-bold text-gray-900">$@Model.TotalAmount.ToString("N2")</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500">Items</p>
            <p class="text-lg font-bold text-gray-900">@Model.Items.Count</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500">Estado</p>
            <pana-badge variant="@(Model.Status == "completed" ? "success" : "danger")">
                @Model.Status
            </pana-badge>
        </div>
    </div>

    @* Items *@
    <div>
        <h4 class="text-sm font-semibold text-gray-700 mb-2">Detalle de items</h4>
        <div class="border border-gray-200 rounded-lg overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-gray-600 font-medium">Producto</th>
                        <th class="px-4 py-2 text-right text-gray-600 font-medium">Precio</th>
                        <th class="px-4 py-2 text-center text-gray-600 font-medium">Cant.</th>
                        <th class="px-4 py-2 text-right text-gray-600 font-medium">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="@(item.IsVoided ? "opacity-50 line-through" : "")">
                            <td class="px-4 py-2 text-gray-800">@item.ProductName</td>
                            <td class="px-4 py-2 text-right text-gray-600">$@item.UnitPrice.ToString("N2")</td>
                            <td class="px-4 py-2 text-center text-gray-600">@item.Quantity</td>
                            <td class="px-4 py-2 text-right font-medium text-gray-800">$@item.LineTotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Notes *@
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="bg-amber-50 rounded-lg p-3">
            <p class="text-sm text-amber-800">📝 @Model.Notes</p>
        </div>
    }

    <p class="text-xs text-gray-400">Creada: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
</div>
