@model List<Pana.Api.Web.ViewModels.SalesChartData>
@{
    var labels = Model.Select(d => d.Day).ToList();
    var values = Model.Select(d => d.Total).ToList();
    var chartId = "chart-" + Guid.NewGuid().ToString("N")[..6];
}

<canvas id="@chartId" class="w-full h-64"></canvas>

<script>
    (function() {
        const ctx = document.getElementById('@chartId');
        if (!ctx) return;
        const style = getComputedStyle(document.documentElement);
        const c1 = style.getPropertyValue('--chart-1').trim() || '#9e0012';
        const c2 = style.getPropertyValue('--chart-5').trim() || '#c41e24';
        const fg = style.getPropertyValue('--fg').trim() || '#1c1c19';
        const meta = style.getPropertyValue('--meta').trim() || '#94948c';
        const surfaceLow = style.getPropertyValue('--surface-container-low').trim() || '#f6f3ee';

        const gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, c1 + 'b3');
        gradient.addColorStop(1, c2 + '4d');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Json.Serialize(labels),
                datasets: [{
                    label: 'Ventas',
                    data: @Json.Serialize(values),
                    backgroundColor: gradient,
                    borderRadius: 10,
                    borderSkipped: false,
                    borderColor: c1 + '80',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: fg,
                        titleColor: '#ffffff',
                        bodyColor: style.getPropertyValue('--surface-container-lowest').trim() || '#ffffff',
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: meta, font: { size: 11 } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: surfaceLow },
                        ticks: {
                            color: meta,
                            font: { size: 11 },
                            callback: v => '$' + v
                        }
                    }
                }
            }
        });
    })();
</script>
