@model List<Pana.Api.Web.ViewModels.SaleRowViewModel>

@if (Model.Count == 0)
{
    <p class="text-sm text-gray-400">No hay ventas recientes.</p>
}
else
{
    <div class="space-y-3">
        @foreach (var sale in Model)
        {
            <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                <div>
                    <p class="text-sm font-medium text-gray-700">Venta #@sale.Id.ToString()[..8]</p>
                    <p class="text-xs text-gray-400">@sale.CreatedAt.ToString("HH:mm") — @sale.ItemCount items</p>
                </div>
                <div class="text-right">
                    <p class="text-sm font-semibold text-gray-900">$@sale.TotalAmount.ToString("N2")</p>
                    <pana-badge variant="@(sale.Status == "completed" ? "success" : "warning")">@sale.Status</pana-badge>
                </div>
            </div>
        }
    </div>
}
