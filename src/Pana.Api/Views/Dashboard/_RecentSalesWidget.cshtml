@* Views/Dashboard/_RecentSalesWidget.cshtml — Last 5 sales with status badges *@
@model List<Pana.Api.Web.ViewModels.SaleRowViewModel>

<div id="recent-sales-widget"
     class="rounded-2xl shadow-ambient p-6"
     style="background: var(--surface-container-lowest);"
     hx-get="/web/dashboard/widget/recent-sales" hx-trigger="every 60s" hx-swap="outerHTML">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="font-semibold" style="color: var(--fg);">Últimas ventas</h2>
            <p class="text-sm" style="color: var(--meta);">Recientes</p>
        </div>
        <a href="/sales"
           class="text-xs font-medium transition-colors" style="color: var(--primary);">
            Ver todas →
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-10" style="color: var(--meta);">
            <svg class="w-10 h-10 mb-2 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <p class="text-sm font-medium">Sin ventas aún</p>
            <p class="text-xs mt-1">Las ventas de hoy aparecerán aquí</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var sale in Model)
            {
                var statusColor = sale.Status switch
                {
                    "Completed" => "color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);",
                    "Voided" => "color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);",
                    "Ready" => "color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);",
                    "Preparing" => "color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 12%, transparent);",
                    "Confirmed" => "color: var(--primary); background: color-mix(in srgb, var(--primary) 10%, transparent);",
                    _ => "color: var(--muted); background: var(--surface-container);"
                };
                var statusLabel = sale.Status switch
                {
                    "Completed" => "Completada",
                    "Voided" => "Anulada",
                    "Ready" => "Lista",
                    "Preparing" => "En preparación",
                    "Confirmed" => "Confirmada",
                    "Draft" => "Borrador",
                    _ => sale.Status
                };

                <div id="sale-row-@sale.Id"
                     class="flex items-center justify-between p-3 rounded-xl transition-colors duration-200 group"
                     style="background: var(--surface-container-low);"
                     onmouseover="this.style.background='var(--surface-container)'"
                     onmouseout="this.style.background='var(--surface-container-low)'">
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-semibold tabular-nums" style="color: var(--fg);">
                                @sale.TotalAmount.ToString("C0")
                            </span>
                            <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full" style="@statusColor">
                                @statusLabel
                            </span>
                        </div>
                        <p class="text-xs mt-0.5" style="color: var(--meta);">
                            @sale.ItemCount artículo@(sale.ItemCount != 1 ? "s" : "") ·
                            @sale.CreatedAt.ToLocalTime().ToString("HH:mm")
                        </p>
                    </div>
                    <a href="/sales"
                       class="shrink-0 p-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-200"
                       style="color: var(--meta);"
                       onmouseover="this.style.color='var(--primary)'; this.style.background='color-mix(in srgb, var(--primary) 5%, transparent)'"
                       onmouseout="this.style.color='var(--meta)'; this.style.background='transparent'">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            }
        </div>
    }
</div>
