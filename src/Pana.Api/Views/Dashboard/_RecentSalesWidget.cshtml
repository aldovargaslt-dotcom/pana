@model List<Pana.Api.Web.ViewModels.SaleRowViewModel>

@if (Model.Count == 0)
{
    <div class="flex flex-col items-center justify-center py-8 text-gray-400">
        <svg class="w-10 h-10 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <p class="text-sm">No hay ventas recientes</p>
    </div>
}
else
{
    <div class="space-y-1">
        @foreach (var sale in Model)
        {
            <div class="flex items-center justify-between py-3 px-2 -mx-2 rounded-xl hover:bg-gray-50 transition-colors">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center text-gray-500 text-xs font-mono">
                        @sale.Id.ToString()[..6]
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-700">@sale.ItemCount items</p>
                        <p class="text-xs text-gray-400">@sale.CreatedAt.ToString("HH:mm")</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-sm font-semibold text-gray-800">$@sale.TotalAmount.ToString("N2")</p>
                    <span class="text-xs @(sale.Status == "completed" ? "text-emerald-600" : "text-amber-600")">
                        @sale.Status
                    </span>
                </div>
            </div>
        }
    </div>
}
