@* Views/Dashboard/_RecentSalesWidget.cshtml — Last 5 sales with status badges *@
@model List<Pana.Api.Web.ViewModels.SaleRowViewModel>

<div id="recent-sales-widget"
     class="bg-white dark:bg-gray-800 rounded-2xl shadow-card border border-gray-100 dark:border-gray-700 p-6"
     hx-get="/web/dashboard/widget/recent-sales" hx-trigger="every 60s" hx-swap="outerHTML">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="font-semibold text-gray-800 dark:text-white">Últimas ventas</h2>
            <p class="text-sm text-gray-400 dark:text-gray-500">Recientes</p>
        </div>
        <a href="/sales"
           class="text-xs text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300
                  font-medium transition-colors">
            Ver todas →
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-10 text-gray-300 dark:text-gray-600">
            <svg class="w-10 h-10 mb-2 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <p class="text-sm font-medium">Sin ventas aún</p>
            <p class="text-xs mt-1">Las ventas de hoy aparecerán aquí</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var sale in Model)
            {
                var statusColor = sale.Status switch
                {
                    "Completed" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400",
                    "Voided" => "bg-red-100 text-red-700 dark:bg-red-500/20 dark:text-red-400",
                    "Ready" => "bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-400",
                    "Preparing" => "bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-400",
                    "Confirmed" => "bg-purple-100 text-purple-700 dark:bg-purple-500/20 dark:text-purple-400",
                    _ => "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400"
                };
                var statusLabel = sale.Status switch
                {
                    "Completed" => "Completada",
                    "Voided" => "Anulada",
                    "Ready" => "Lista",
                    "Preparing" => "En preparación",
                    "Confirmed" => "Confirmada",
                    "Draft" => "Borrador",
                    _ => sale.Status
                };

                <div id="sale-row-@sale.Id"
                     class="flex items-center justify-between p-3 rounded-xl
                            bg-gray-50 dark:bg-gray-900/50
                            hover:bg-gray-100 dark:hover:bg-gray-800
                            transition-colors duration-200 group">
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-semibold text-gray-900 dark:text-white tabular-nums">
                                @sale.TotalAmount.ToString("C0")
                            </span>
                            <span class="@statusColor text-[10px] font-semibold px-1.5 py-0.5 rounded-full">
                                @statusLabel
                            </span>
                        </div>
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                            @sale.ItemCount artículo@(sale.ItemCount != 1 ? "s" : "") ·
                            @sale.CreatedAt.ToLocalTime().ToString("HH:mm")
                        </p>
                    </div>
                    <a href="/sales"
                       class="shrink-0 p-1.5 rounded-lg text-gray-400 hover:text-brand-600
                              dark:hover:text-brand-400 hover:bg-brand-50 dark:hover:bg-brand-500/10
                              opacity-0 group-hover:opacity-100 transition-all duration-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            }
        </div>
    }
</div>
