@* Views/Dashboard/_SalesTrendChart.cshtml — 7-day sales trend bar chart via Chart.js *@
@model List<Pana.Api.Application.Analytics.DailyTrendPointDto>
@{
    var chartId = "sales-trend-chart-" + Guid.NewGuid().ToString("N")[..6];
    var labels = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => d.Label));
    var revenues = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => d.Ventas));
    var transactions = System.Text.Json.JsonSerializer.Serialize(Model.Select(d => d.Transacciones));
}

<div id="sales-trend-widget"
     class="bg-white dark:bg-gray-800 rounded-2xl shadow-card border border-gray-100 dark:border-gray-700 p-6"
     hx-get="/web/dashboard/widget/sales-trend" hx-trigger="every 120s" hx-swap="outerHTML">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
        <div>
            <h2 class="font-semibold text-gray-800 dark:text-white">Tendencia de ventas</h2>
            <p class="text-sm text-gray-400 dark:text-gray-500">Últimos 7 días</p>
        </div>
        <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
            <span class="inline-flex items-center gap-1">
                <span class="w-3 h-3 rounded-sm bg-brand-500"></span> Ventas ($)
            </span>
            <span class="inline-flex items-center gap-1">
                <span class="w-3 h-3 rounded-sm bg-brand-200 dark:bg-brand-700"></span> Transacciones
            </span>
        </div>
    </div>

    @if (Model.Count == 0 || Model.All(d => d.Ventas == 0))
    {
        <div class="h-64 flex flex-col items-center justify-center text-gray-300 dark:text-gray-600">
            <svg class="w-16 h-16 mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <p class="text-sm font-medium">Sin datos de ventas aún</p>
            <p class="text-xs mt-1">Las ventas de los últimos 7 días aparecerán aquí</p>
        </div>
    }
    else
    {
        <div class="h-64">
            <canvas id="@chartId"></canvas>
        </div>
        <script>
            (function() {
                const ctx = document.getElementById('@chartId');
                if (!ctx) return;
                // Destroy previous chart instance if it exists
                const existing = Chart.getChart(ctx);
                if (existing) existing.destroy();
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(labels),
                        datasets: [
                            {
                                label: 'Ventas ($)',
                                data: @Html.Raw(revenues),
                                backgroundColor: '#6366f1',
                                borderRadius: 6,
                                borderSkipped: false,
                                order: 1,
                                yAxisID: 'y',
                            },
                            {
                                label: 'Transacciones',
                                data: @Html.Raw(transactions),
                                type: 'line',
                                borderColor: '#a5b4fc',
                                backgroundColor: 'transparent',
                                borderWidth: 2,
                                pointBackgroundColor: '#a5b4fc',
                                pointRadius: 3,
                                pointHoverRadius: 5,
                                tension: 0.3,
                                order: 0,
                                yAxisID: 'y1',
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e1b4b',
                                titleColor: '#fff',
                                bodyColor: '#c7d2fe',
                                padding: 12,
                                cornerRadius: 8,
                                displayColors: true,
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: {
                                    color: '#9ca3af',
                                    font: { size: 11 },
                                }
                            },
                            y: {
                                position: 'left',
                                grid: { color: '#f3f4f6' },
                                ticks: {
                                    color: '#6366f1',
                                    font: { size: 11, weight: '600' },
                                    callback: value => '$' + value.toLocaleString(),
                                }
                            },
                            y1: {
                                position: 'right',
                                grid: { drawOnChartArea: false },
                                ticks: {
                                    color: '#a5b4fc',
                                    font: { size: 11 },
                                    stepSize: 1,
                                }
                            }
                        }
                    }
                });
            })();
        </script>
    }
</div>
