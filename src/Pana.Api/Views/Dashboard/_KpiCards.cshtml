@* Views/Dashboard/_KpiCards.cshtml — Auto-refreshing KPI stat cards *@
@model Pana.Api.Web.ViewModels.DashboardKpiViewModel
@{
    var revenueChange = Model.YesterdayRevenue > 0
        ? ((Model.TodayRevenue - Model.YesterdayRevenue) / Model.YesterdayRevenue * 100m)
        : (decimal?)null;
    var orderChange = Model.YesterdayOrderCount > 0
        ? ((decimal)(Model.TodayOrderCount - Model.YesterdayOrderCount) / Model.YesterdayOrderCount * 100m)
        : (decimal?)null;
}

<div id="kpi-cards" class="grid grid-cols-2 lg:grid-cols-4 gap-4"
     hx-get="/web/dashboard/widget/kpi-cards" hx-trigger="every 60s" hx-swap="outerHTML">

    @* ── Today's Revenue ────────────────────────────────────── *@
    <div class="group relative overflow-hidden bg-white dark:bg-gray-800 rounded-2xl p-5
                shadow-card border border-gray-100 dark:border-gray-700
                hover:shadow-soft hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-emerald-500/10 to-transparent rounded-bl-full"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Ventas hoy</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white tabular-nums">@Model.TodayRevenue.ToString("C0")</p>
                    @if (revenueChange.HasValue)
                    {
                        <div class="flex items-center gap-1 mt-1">
                            @if (revenueChange >= 0)
                            {
                                <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">↑ @Math.Abs(revenueChange.Value).ToString("F1")%</span>
                            }
                            else
                            {
                                <span class="text-xs font-semibold text-red-500 dark:text-red-400">↓ @Math.Abs(revenueChange.Value).ToString("F1")%</span>
                            }
                            <span class="text-xs text-gray-400 dark:text-gray-500">vs ayer</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">@Model.TodayOrderCount órdenes</p>
                    }
                </div>
                <div class="p-2.5 bg-gradient-to-br from-emerald-50 to-emerald-100 dark:from-emerald-500/20 dark:to-emerald-500/10
                            rounded-xl text-emerald-600 dark:text-emerald-400
                            group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
    </div>

    @* ── Today's Orders ─────────────────────────────────────── *@
    <div class="group relative overflow-hidden bg-white dark:bg-gray-800 rounded-2xl p-5
                shadow-card border border-gray-100 dark:border-gray-700
                hover:shadow-soft hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-brand-500/10 to-transparent rounded-bl-full"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Órdenes hoy</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white tabular-nums">@Model.TodayOrderCount</p>
                    @if (orderChange.HasValue)
                    {
                        <div class="flex items-center gap-1 mt-1">
                            @if (orderChange >= 0)
                            {
                                <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">↑ @Math.Abs(orderChange.Value).ToString("F0")%</span>
                            }
                            else
                            {
                                <span class="text-xs font-semibold text-red-500 dark:text-red-400">↓ @Math.Abs(orderChange.Value).ToString("F0")%</span>
                            }
                            <span class="text-xs text-gray-400 dark:text-gray-500">vs ayer</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">completadas</p>
                    }
                </div>
                <div class="p-2.5 bg-gradient-to-br from-brand-50 to-brand-100 dark:from-brand-500/20 dark:to-brand-500/10
                            rounded-xl text-brand-600 dark:text-brand-400
                            group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
            </div>
        </div>
    </div>

    @* ── Today's Margin ─────────────────────────────────────── *@
    <div class="group relative overflow-hidden bg-white dark:bg-gray-800 rounded-2xl p-5
                shadow-card border border-gray-100 dark:border-gray-700
                hover:shadow-soft hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-amber-500/10 to-transparent rounded-bl-full"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Margen hoy</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white tabular-nums">@Model.TodayMargin.ToString("C0")</p>
                    <div class="flex items-center gap-1 mt-1">
                        @{
                            var marginPct = Model.TodayRevenue > 0 ? (Model.TodayMargin / Model.TodayRevenue * 100m) : 0;
                        }
                        <span class="text-xs font-semibold @(marginPct >= 30 ? "text-emerald-600 dark:text-emerald-400" : marginPct >= 15 ? "text-amber-600 dark:text-amber-400" : "text-red-500 dark:text-red-400")">@marginPct.ToString("F1")%</span>
                        <span class="text-xs text-gray-400 dark:text-gray-500">margen</span>
                    </div>
                </div>
                <div class="p-2.5 bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-500/20 dark:to-amber-500/10
                            rounded-xl text-amber-600 dark:text-amber-400
                            group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
            </div>
        </div>
    </div>

    @* ── Active Products ────────────────────────────────────── *@
    <div class="group relative overflow-hidden bg-white dark:bg-gray-800 rounded-2xl p-5
                shadow-card border border-gray-100 dark:border-gray-700
                hover:shadow-soft hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-purple-500/10 to-transparent rounded-bl-full"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Productos</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900 dark:text-white tabular-nums">@Model.ActiveProductCount</p>
                    <div class="flex items-center gap-1 mt-1">
                        @if (Model.LowStockCount > 0)
                        {
                            <span class="text-xs font-semibold text-red-500 dark:text-red-400">⚠ @Model.LowStockCount bajo stock</span>
                        }
                        else
                        {
                            <span class="text-xs text-gray-400 dark:text-gray-500">en catálogo</span>
                        }
                    </div>
                </div>
                <div class="p-2.5 bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-500/20 dark:to-purple-500/10
                            rounded-xl text-purple-600 dark:text-purple-400
                            group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
            </div>
        </div>
    </div>
</div>
