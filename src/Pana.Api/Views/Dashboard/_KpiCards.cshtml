@* Views/Dashboard/_KpiCards.cshtml — Auto-refreshing KPI stat cards *@
@model Pana.Api.Web.ViewModels.DashboardKpiViewModel
@{
    var revenueChange = Model.YesterdayRevenue > 0
        ? ((Model.TodayRevenue - Model.YesterdayRevenue) / Model.YesterdayRevenue * 100m)
        : (decimal?)null;
    var orderChange = Model.YesterdayOrderCount > 0
        ? ((decimal)(Model.TodayOrderCount - Model.YesterdayOrderCount) / Model.YesterdayOrderCount * 100m)
        : (decimal?)null;
}

<div id="kpi-cards" class="grid grid-cols-1 sm:grid-cols-3 gap-4"
     hx-get="/web/dashboard/widget/kpi-cards" hx-trigger="every 60s" hx-swap="outerHTML">

    @* ── Today's Revenue ────────────────────────────────────── *@
    <div class="group relative overflow-hidden rounded-2xl p-5 shadow-ambient hover:shadow-ambient hover:-translate-y-0.5 transition-all duration-300"
         style="background: var(--surface-container-lowest);">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-bl-full"
             style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--success) 12%, transparent), transparent 70%);"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Ventas hoy</p>
                    <p class="mt-1 text-2xl font-bold tabular-nums" style="color: var(--fg);">@Model.TodayRevenue.ToString("C0")</p>
                    @if (revenueChange.HasValue)
                    {
                        <div class="flex items-center gap-1 mt-1">
                            @if (revenueChange >= 0)
                            {
                                <span class="text-xs font-semibold" style="color: var(--success);">↑ @Math.Abs(revenueChange.Value).ToString("F1")%</span>
                            }
                            else
                            {
                                <span class="text-xs font-semibold" style="color: var(--danger);">↓ @Math.Abs(revenueChange.Value).ToString("F1")%</span>
                            }
                            <span class="text-xs" style="color: var(--meta);">vs ayer</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs mt-1" style="color: var(--meta);">@Model.TodayOrderCount órdenes</p>
                    }
                </div>
                <div class="p-2.5 rounded-xl group-hover:scale-110 transition-transform duration-300"
                     style="background: linear-gradient(135deg, color-mix(in srgb, var(--success) 8%, transparent), color-mix(in srgb, var(--success) 16%, transparent)); color: var(--success);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            @* Drilldown trigger *@
            <button onclick="openKpiDrilldown('revenue', this)"
                    class="mt-3 w-full flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs font-medium
                           opacity-0 group-hover:opacity-100 transition-all duration-200 hover:shadow-sm"
                    style="color: var(--success); background: color-mix(in srgb, var(--success) 6%, transparent);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                Ver detalle
            </button>
        </div>
    </div>

    @* ── Today's Orders ─────────────────────────────────────── *@
    <div class="group relative overflow-hidden rounded-2xl p-5 shadow-ambient hover:shadow-ambient hover:-translate-y-0.5 transition-all duration-300"
         style="background: var(--surface-container-lowest);">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-bl-full"
             style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--primary) 10%, transparent), transparent 70%);"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Órdenes hoy</p>
                    <p class="mt-1 text-2xl font-bold tabular-nums" style="color: var(--fg);">@Model.TodayOrderCount</p>
                    @if (orderChange.HasValue)
                    {
                        <div class="flex items-center gap-1 mt-1">
                            @if (orderChange >= 0)
                            {
                                <span class="text-xs font-semibold" style="color: var(--success);">↑ @Math.Abs(orderChange.Value).ToString("F0")%</span>
                            }
                            else
                            {
                                <span class="text-xs font-semibold" style="color: var(--danger);">↓ @Math.Abs(orderChange.Value).ToString("F0")%</span>
                            }
                            <span class="text-xs" style="color: var(--meta);">vs ayer</span>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs mt-1" style="color: var(--meta);">completadas</p>
                    }
                </div>
                <div class="p-2.5 rounded-xl group-hover:scale-110 transition-transform duration-300"
                     style="background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 8%, transparent), color-mix(in srgb, var(--primary) 16%, transparent)); color: var(--primary);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
            </div>
            @* Drilldown trigger *@
            <button onclick="openKpiDrilldown('orders', this)"
                    class="mt-3 w-full flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs font-medium
                           opacity-0 group-hover:opacity-100 transition-all duration-200 hover:shadow-sm"
                    style="color: var(--primary); background: color-mix(in srgb, var(--primary) 6%, transparent);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                Ver detalle
            </button>
        </div>
    </div>

    @* ── Today's Margin ─────────────────────────────────────── *@
    <div class="group relative overflow-hidden rounded-2xl p-5 shadow-ambient hover:shadow-ambient hover:-translate-y-0.5 transition-all duration-300"
         style="background: var(--surface-container-lowest);">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-bl-full"
             style="background: radial-gradient(circle at top right, color-mix(in srgb, var(--tertiary) 12%, transparent), transparent 70%);"></div>
        <div class="relative">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Margen hoy</p>
                    <p class="mt-1 text-2xl font-bold tabular-nums" style="color: var(--fg);">@Model.TodayMargin.ToString("C0")</p>
                    <div class="flex items-center gap-1 mt-1">
                        @{
                            var marginPct = Model.TodayRevenue > 0 ? (Model.TodayMargin / Model.TodayRevenue * 100m) : 0;
                        }
                        <span class="text-xs font-semibold" style="color: @(marginPct >= 30 ? "var(--success)" : marginPct >= 15 ? "var(--tertiary)" : "var(--danger)");">@marginPct.ToString("F1")%</span>
                        <span class="text-xs" style="color: var(--meta);">margen</span>
                    </div>
                </div>
                <div class="p-2.5 rounded-xl group-hover:scale-110 transition-transform duration-300"
                     style="background: linear-gradient(135deg, color-mix(in srgb, var(--tertiary) 10%, transparent), color-mix(in srgb, var(--tertiary) 20%, transparent)); color: var(--tertiary);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
            </div>
            @* Drilldown trigger *@
            <button onclick="openKpiDrilldown('margin', this)"
                    class="mt-3 w-full flex items-center justify-center gap-1 py-1.5 rounded-lg text-xs font-medium
                           opacity-0 group-hover:opacity-100 transition-all duration-200 hover:shadow-sm"
                    style="color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 6%, transparent);">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                Ver detalle
            </button>
        </div>
    </div>

</div>

