@* Views/Dashboard/_LowStockWidget.cshtml — Inventory alerts for items below reorder point *@
@model List<Pana.Api.Web.ViewModels.LowStockAlertViewModel>

<div id="low-stock-widget"
     class="rounded-2xl shadow-ambient p-6"
     style="background: var(--surface-container-lowest);"
     hx-get="/web/dashboard/widget/low-stock" hx-trigger="every 120s" hx-swap="outerHTML">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="font-semibold inline-flex items-center gap-1.5" style="color: var(--fg);"><svg class="w-5 h-5" style="color: var(--warn);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>Alertas de inventario</h2>
            <p class="text-sm" style="color: var(--meta);">Stock bajo el mínimo</p>
        </div>
        @if (Model.Count > 0)
        {
            <span class="text-xs font-bold px-2.5 py-1 rounded-full"
                  style="color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);">
                @Model.Count alerta@(Model.Count != 1 ? "s" : "")
            </span>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-8" style="color: var(--meta);">
            <div class="p-3 rounded-full mb-3" style="background: color-mix(in srgb, var(--success) 12%, transparent);">
                <svg class="w-8 h-8" style="color: var(--success);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="text-sm font-medium" style="color: var(--muted);">Todo en orden</p>
            <p class="text-xs mt-1" style="color: var(--meta);">No hay productos con stock bajo</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var alert in Model.Take(6))
            {
                var severityBg = alert.StockLevel == 0
                    ? "background: color-mix(in srgb, var(--danger) 5%, transparent);"
                    : "background: color-mix(in srgb, var(--tertiary) 5%, transparent);";
                var dotColor = alert.StockLevel == 0
                    ? "background: var(--danger);"
                    : "background: var(--tertiary);";
                var stockTextColor = alert.StockLevel == 0
                    ? "color: var(--danger);"
                    : "color: var(--tertiary);";

                <div class="flex items-center justify-between p-3 rounded-xl hover:shadow-ambient transition-all duration-200"
                     style="@severityBg">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="w-2 h-2 rounded-full shrink-0" style="@dotColor"></span>
                        <div class="min-w-0">
                            <p class="text-sm font-medium truncate" style="color: var(--fg);">@alert.ProductName</p>
                            <p class="text-xs" style="color: var(--meta);">
                                Stock: <span class="font-semibold" style="@stockTextColor">@alert.StockLevel</span>
                                / Mín: @alert.MinimumLevel
                            </p>
                        </div>
                    </div>
                    <a href="/products"
                       class="shrink-0 text-xs font-medium px-2 py-1 rounded-lg transition-colors"
                       style="color: var(--primary);"
                       onmouseover="this.style.background='color-mix(in srgb, var(--primary) 5%, transparent)'"
                       onmouseout="this.style.background='transparent'">
                        Reordenar
                    </a>
                </div>
            }
        </div>
    }
</div>
