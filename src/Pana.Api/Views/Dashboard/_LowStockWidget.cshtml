@* Views/Dashboard/_LowStockWidget.cshtml — Inventory alerts for items below reorder point *@
@model List<Pana.Api.Web.ViewModels.LowStockAlertViewModel>

<div id="low-stock-widget"
     class="bg-white dark:bg-gray-800 rounded-2xl shadow-card border border-gray-100 dark:border-gray-700 p-6"
     hx-get="/web/dashboard/widget/low-stock" hx-trigger="every 120s" hx-swap="outerHTML">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h2 class="font-semibold text-gray-800 dark:text-white">⚠️ Alertas de inventario</h2>
            <p class="text-sm text-gray-400 dark:text-gray-500">Stock bajo el mínimo</p>
        </div>
        @if (Model.Count > 0)
        {
            <span class="text-xs font-bold text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-500/10
                         px-2.5 py-1 rounded-full">
                @Model.Count alerta@(Model.Count != 1 ? "s" : "")
            </span>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-8 text-gray-300 dark:text-gray-600">
            <div class="p-3 bg-emerald-50 dark:bg-emerald-500/10 rounded-full mb-3">
                <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Todo en orden</p>
            <p class="text-xs mt-1 text-gray-400 dark:text-gray-500">No hay productos con stock bajo</p>
        </div>
    }
    else
    {
        <div class="space-y-2">
            @foreach (var alert in Model.Take(6))
            {
                var severityColor = alert.StockLevel == 0
                    ? "border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-500/5"
                    : "border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-500/5";
                var dotColor = alert.StockLevel == 0
                    ? "bg-red-500"
                    : "bg-amber-500";

                <div class="flex items-center justify-between p-3 rounded-xl border @severityColor
                            hover:shadow-sm transition-all duration-200">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="w-2 h-2 rounded-full @dotColor shrink-0"></span>
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-gray-800 dark:text-white truncate">@alert.ProductName</p>
                            <p class="text-xs text-gray-400 dark:text-gray-500">
                                Stock: <span class="font-semibold @(alert.StockLevel == 0 ? "text-red-600 dark:text-red-400" : "text-amber-600 dark:text-amber-400")">@alert.StockLevel</span>
                                / Mín: @alert.MinimumLevel
                            </p>
                        </div>
                    </div>
                    <a href="/products"
                       class="shrink-0 text-xs font-medium text-brand-600 hover:text-brand-700
                              dark:text-brand-400 dark:hover:text-brand-300 px-2 py-1
                              hover:bg-brand-50 dark:hover:bg-brand-500/10 rounded-lg transition-colors">
                        Reordenar
                    </a>
                </div>
            }
        </div>
    }
</div>
