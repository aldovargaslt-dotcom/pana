@model Pana.Api.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="max-w-6xl mx-auto p-4">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">📊 Pana — @Model.TenantName</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">Productos</p>
            <p class="text-2xl font-bold">—</p>
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">Ventas del día</p>
            <p class="text-2xl font-bold text-green-600">$0</p>
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <p class="text-sm text-gray-500">Margen</p>
            <p class="text-2xl font-bold">—</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded-lg shadow p-4">
            <h2 class="font-semibold mb-3">Acciones rápidas</h2>
            <div class="space-y-2">
                <a href="/products" class="block px-4 py-2 bg-blue-600 text-white rounded-lg text-center hover:bg-blue-700">
                    📦 Gestionar Productos
                </a>
                <a href="/sales" class="block px-4 py-2 bg-green-600 text-white rounded-lg text-center hover:bg-green-700">
                    🛒 Nueva Venta
                </a>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow p-4">
            <h2 class="font-semibold mb-3">Estado del sistema</h2>
            <p class="text-green-600">✅ API funcionando</p>
            <p class="text-green-600">✅ Base de datos conectada</p>
        </div>
    </div>
</div>
