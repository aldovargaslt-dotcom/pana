@* Views/Dashboard/Index.cshtml — Production-ready KPI Dashboard *@
@model Pana.Api.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var now = DateTime.Now;
    var todayName = now.ToString("dddd, d 'de' MMMM 'de' yyyy",
        new System.Globalization.CultureInfo("es-MX"));
    string greeting;
    if (now.Hour < 12)
        greeting = "Buenos días";
    else if (now.Hour < 18)
        greeting = "Buenas tardes";
    else
        greeting = "Buenas noches";
}

<div class="content-area space-y-5 fade-in">

    @* ── Welcome header ─────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold" style="color: var(--fg);">
                @greeting, <span class="text-gradient">@Model.TenantName</span>
                <svg class="w-5 h-5 inline-block ml-1 -mt-1" style="color: var(--tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a2.5 2.5 0 015 0v6m0 4.5V14m0 0v-1.5a2.5 2.5 0 00-2.5-2.5h-2a2.5 2.5 0 000 5h2a2.5 2.5 0 012.5 2.5V19"/></svg>
            </h1>
            <p class="text-sm mt-0.5" style="color: var(--muted);">
                @todayName
            </p>
        </div>
        <div class="flex items-center gap-3">
            @* System status *@
            <div class="flex items-center gap-2 text-xs rounded-lg px-3 py-1.5 shadow-ambient"
                 style="color: var(--meta); background: var(--surface-container-lowest);">
                <span class="pulse-dot"></span> Sistema en línea
            </div>
            @* New sale quick action *@
            <button hx-get="/sales/create-form" hx-target="#modal-container"
                    class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold text-white
                           shadow-ambient hover:shadow-ambient transition-all duration-200 active:scale-[0.98]"
                    style="background: var(--gradient-primary);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nueva venta
            </button>
        </div>
    </div>

    @* ── Daily context bar (HTMX-loaded) ────────────────────── *@
    <div hx-get="/web/dashboard/widget/daily-context"
         hx-trigger="load"
         hx-swap="innerHTML">
        <div class="skeleton h-10 rounded-xl"></div>
    </div>

    @* ── KPI stat cards (HTMX-loaded, auto-refresh every 60s) ─ *@
    <div hx-get="/web/dashboard/widget/kpi-cards"
         hx-trigger="load"
         hx-swap="outerHTML">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            @for (int i = 0; i < 4; i++)
            {
                <div class="skeleton h-28 rounded-2xl"></div>
            }
        </div>
    </div>

    @* ── KPI Drilldown panel (slide-down, hidden by default) ── *@
    <div id="kpi-drilldown-panel"
         class="drilldown-panel"
         style="display: none;">
        <div id="kpi-drilldown-panel-inner"
             class="drilldown-panel-inner"
             hx-get=""
             hx-trigger=""
             hx-swap="innerHTML">
        </div>
    </div>

    @* ── Main content grid ──────────────────────────────────── *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        @* Sales trend chart (spans 2 cols on large screens) *@
        <div class="lg:col-span-2" hx-get="/web/dashboard/widget/sales-trend"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-80 rounded-2xl"></div>
        </div>

        @* Recent sales *@
        <div hx-get="/web/dashboard/widget/recent-sales"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-80 rounded-2xl"></div>
        </div>
    </div>

    @* ── Bottom row: Low stock + Quick actions ──────────────── *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        @* Low stock alerts *@
        <div hx-get="/web/dashboard/widget/low-stock"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-64 rounded-2xl"></div>
        </div>

        @* Quick actions *@
        <div class="rounded-2xl shadow-ambient p-6" style="background: var(--surface-container-lowest);">
            <h2 class="font-semibold mb-4" style="color: var(--fg);">
                <svg class="w-5 h-5 inline-block mr-1.5 -mt-0.5" style="color: var(--tertiary);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Acciones rápidas
            </h2>
            <div class="grid grid-cols-2 gap-3">
                @* New Sale *@
                <button hx-get="/sales/create-form" hx-target="#modal-container"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          hover:shadow-sm transition-all duration-200 group"
                   style="background: linear-gradient(135deg, color-mix(in srgb, var(--success) 5%, transparent), color-mix(in srgb, var(--success) 10%, transparent));">
                    <div class="p-2.5 rounded-xl text-white group-hover:scale-110 transition-transform duration-200"
                         style="background: var(--success);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </div>
                    <span class="text-sm font-medium" style="color: var(--success);">Nueva venta</span>
                </button>

                @* New Product *@
                <a href="/products"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          hover:shadow-sm transition-all duration-200 group"
                   style="background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 5%, transparent), color-mix(in srgb, var(--primary) 10%, transparent));">
                    <div class="p-2.5 rounded-xl text-white group-hover:scale-110 transition-transform duration-200"
                         style="background: var(--gradient-primary);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <span class="text-sm font-medium" style="color: var(--primary);">Productos</span>
                </a>

                @* Daily Production *@
                <button hx-get="/operations/daily-production-form" hx-target="#modal-container"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          hover:shadow-sm transition-all duration-200 group"
                   style="background: linear-gradient(135deg, color-mix(in srgb, var(--tertiary) 5%, transparent), color-mix(in srgb, var(--tertiary) 10%, transparent));">
                    <div class="p-2.5 rounded-xl text-white group-hover:scale-110 transition-transform duration-200"
                         style="background: var(--tertiary-fixed); color: var(--on-tertiary-fixed);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <span class="text-sm font-medium" style="color: var(--tertiary);">Producción diaria</span>
                </button>

                @* Inventory *@
                <a href="/inventory"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          hover:shadow-sm transition-all duration-200 group"
                   style="background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 3%, transparent), color-mix(in srgb, var(--primary) 8%, transparent));">
                    <div class="p-2.5 rounded-xl text-white group-hover:scale-110 transition-transform duration-200"
                         style="background: var(--primary-container);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <span class="text-sm font-medium" style="color: var(--primary);">Inventario</span>
                </a>
            </div>
        </div>
    </div>

</div>

@* ── Modal container for HTMX-loaded modals ───────────────── *@
<div id="modal-container"></div>

@* ── Toast container (defined in _Layout, confirmed here) ─── *@
@* Toasts are handled by Alpine.js in _Layout.cshtml.
   Server sets X-Toast-Message header after mutations. *@

@* ── KPI Drilldown JavaScript ─────────────────────────────── *@
<script>
    (function() {
        let activeType = null;
        let isLoading = false;
        const panel = document.getElementById('kpi-drilldown-panel');
        const inner = document.getElementById('kpi-drilldown-panel-inner');

        // ── Skeleton with exact row count ─────────────────────
        function skeletonHTML(rowCount) {
            const count = Math.max(0, rowCount);
            const rows = [];
            for (let i = 0; i < count; i++) {
                rows.push(`
                <div class="drilldown-skeleton-row">
                    <div style="flex:1;">
                        <span class="skeleton-line" style="width:${60 + (i % 5) * 8}%;display:block;margin-bottom:6px;"></span>
                        <span class="skeleton-line" style="width:${35 + (i % 5) * 6}%;height:10px;display:block;"></span>
                    </div>
                    <span class="skeleton-line" style="width:56px;height:22px;border-radius:9999px;"></span>
                </div>`);
            }
            return `<div class="drilldown-skeleton">
                <div class="drilldown-skeleton-header">
                    <span class="skeleton-line" style="width:20px;height:20px;border-radius:50%;"></span>
                    <span class="skeleton-line" style="width:120px;"></span>
                    <span class="skeleton-line" style="width:60px;margin-left:auto;"></span>
                </div>
                ${rows.join('')}
            </div>`;
        }

        // ── Placeholder skeleton (before we know row count) ───
        function placeholderSkeleton() {
            return `<div class="drilldown-skeleton">
                <div class="drilldown-skeleton-header">
                    <span class="skeleton-line" style="width:20px;height:20px;border-radius:50%;"></span>
                    <span class="skeleton-line" style="width:120px;"></span>
                    <span class="skeleton-line" style="width:60px;margin-left:auto;"></span>
                </div>
                <div class="flex items-center justify-center py-10" style="color: var(--meta);">
                    <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                </div>
            </div>`;
        }

        // ── Count rows in response HTML ───────────────────────
        function countRowsInHTML(html) {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const rows = doc.querySelectorAll('.table-tonal > div');
            return rows.length;
        }

        // ── Reveal real content with entrance animations ──────
        function revealContent(html) {
            inner.innerHTML = html;
            isLoading = false;
            const content = inner.querySelector('#kpi-drilldown-content');
            if (content) {
                content.classList.add('drilldown-content-entering');
            }
            const rows = inner.querySelectorAll('.table-tonal > div');
            rows.forEach((row, i) => {
                row.classList.add('drilldown-row-stagger');
                row.style.animationDelay = (i * 60) + 'ms';
            });
        }

        // ── Fetch drilldown, match skeleton to real row count ─
        async function loadDrilldown(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('HTTP ' + response.status);
                const html = await response.text();
                const rowCount = countRowsInHTML(html);

                // Show skeleton with the EXACT number of rows that will appear
                inner.innerHTML = skeletonHTML(rowCount);

                // Let the skeleton breathe so the user sees the transition
                await new Promise(r => setTimeout(r, 450));

                // Reveal the real content with staggered entrance
                revealContent(html);
            } catch (err) {
                isLoading = false;
                inner.innerHTML = `<div class="rounded-2xl p-8 text-center" style="background: var(--surface-container-lowest); color: var(--danger);">
                    <p class="text-sm font-semibold">Error al cargar</p>
                    <p class="text-xs mt-1" style="color: var(--meta);">Intenta de nuevo</p>
                </div>`;
                console.error('Drilldown load error:', err);
            }
        }

        // ── Transition out existing content ───────────────────
        function transitionOutContent(callback) {
            const existing = inner.querySelector('#kpi-drilldown-content');
            if (existing) {
                existing.classList.add('drilldown-content-exiting');
                setTimeout(callback, 130);
            } else {
                callback();
            }
        }

        window.openKpiDrilldown = function(type, btn) {
            // Toggle: if same type is clicked, close
            if (activeType === type && panel.style.display !== 'none' && !isLoading) {
                closeKpiDrilldown();
                return;
            }

            // Highlight the active card
            document.querySelectorAll('#kpi-cards .group').forEach(c => {
                c.style.outline = '';
                c.style.outlineOffset = '';
            });
            const card = btn.closest('.group');
            if (card) {
                card.style.outline = '2px solid var(--primary)';
                card.style.outlineOffset = '-2px';
            }

            const url = '/web/dashboard/widget/kpi-drilldown/' + type;
            const isSwitching = activeType !== null && activeType !== type;
            activeType = type;
            isLoading = true;

            if (isSwitching && panel.style.display !== 'none') {
                // Switching KPI types: fade out old → placeholder → fetch → skeleton → reveal
                transitionOutContent(function() {
                    inner.innerHTML = placeholderSkeleton();
                    loadDrilldown(url);
                });
                return;
            }

            // First open: show placeholder, slide panel open, then fetch
            inner.innerHTML = placeholderSkeleton();
            panel.style.display = 'block';
            requestAnimationFrame(() => {
                panel.classList.add('drilldown-open');
            });
            loadDrilldown(url);
        };

        window.closeKpiDrilldown = function() {
            activeType = null;
            isLoading = false;
            panel.classList.remove('drilldown-open');
            document.querySelectorAll('#kpi-cards .group').forEach(c => {
                c.style.outline = '';
                c.style.outlineOffset = '';
            });
            setTimeout(() => {
                if (!panel.classList.contains('drilldown-open')) {
                    panel.style.display = 'none';
                    inner.innerHTML = '';
                }
            }, 350);
        };

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && panel.style.display !== 'none') {
                closeKpiDrilldown();
            }
        });

        // Re-highlight active KPI card after HTMX refresh
        document.addEventListener('htmx:afterSwap', function(e) {
            if (e.detail.target.id === 'kpi-cards' && activeType) {
                const buttons = document.querySelectorAll('#kpi-cards [onclick*="openKpiDrilldown"]');
                buttons.forEach(b => {
                    const onclick = b.getAttribute('onclick') || '';
                    if (onclick.includes("'" + activeType + "'")) {
                        const card = b.closest('.group');
                        if (card) {
                            card.style.outline = '2px solid var(--primary)';
                            card.style.outlineOffset = '-2px';
                        }
                    }
                });
            }
        });
    })();
</script>
