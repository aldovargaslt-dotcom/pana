@* Views/Dashboard/Index.cshtml — Square-style Dashboard v2 *@
@model Pana.Api.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var now = DateTime.Now;
    var todayName = now.ToString("dddd, d 'de' MMMM 'de' yyyy",
        new System.Globalization.CultureInfo("es-MX"));
    string greeting;
    if (now.Hour < 12)
        greeting = "Buenos días";
    else if (now.Hour < 18)
        greeting = "Buenas tardes";
    else
        greeting = "Buenas noches";
}

<div class="content-area space-y-6 fade-in">

    @* ═══════════════════════════════════════════════════════════
       HERO — Square-style: big greeting + ONE dominant action
       ═══════════════════════════════════════════════════════════ *@
    <div class="rounded-3xl p-6 sm:p-8 shadow-ambient overflow-hidden relative"
         style="background: linear-gradient(135deg, var(--surface-container-lowest) 0%, color-mix(in srgb, var(--primary) 3%, var(--surface-container-lowest)) 100%);">
        @* Decorative grain texture *@
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 15px 15px, var(--tertiary) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full"
                          style="background: color-mix(in srgb, var(--success) 10%, transparent); color: var(--success);">
                        <span class="pulse-dot"></span> Abierto
                    </span>
                    <span class="text-xs" style="color: var(--meta);">@todayName</span>
                </div>
                <h1 class="text-2xl sm:text-3xl font-bold" style="color: var(--fg);">
                    @greeting, <span class="text-gradient">@Model.TenantName</span>
                </h1>
            </div>
            @* THE button — the one action that matters *@
            <a href="/pos"
               class="inline-flex items-center justify-center gap-3 px-8 py-5 rounded-2xl text-white font-bold text-lg
                      shadow-modal hover:shadow-lg transition-all duration-200 active:scale-[0.97] flex-shrink-0"
               style="background: var(--gradient-primary); min-width: 220px;">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
                Ir a Cobrar
            </a>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════
       KPI CARDS — 3 key metrics, auto-refresh every 60s
       ═══════════════════════════════════════════════════════════ *@
    <div hx-get="/web/dashboard/widget/kpi-cards"
         hx-trigger="load"
         hx-swap="outerHTML">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="skeleton h-32 rounded-2xl"></div>
            }
        </div>
    </div>

    @* ── KPI Drilldown panel (slide-down, hidden by default) ── *@
    <div id="kpi-drilldown-panel"
         class="drilldown-panel"
         style="display: none;">
        <div id="kpi-drilldown-panel-inner"
             class="drilldown-panel-inner"
             hx-get=""
             hx-trigger=""
             hx-swap="innerHTML">
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════
       CHART + RECENT ACTIVITY
       ═══════════════════════════════════════════════════════════ *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        @* Sales trend chart (spans 2 cols on large screens) *@
        <div class="lg:col-span-2" hx-get="/web/dashboard/widget/sales-trend"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-72 rounded-2xl"></div>
        </div>

        @* Recent sales *@
        <div hx-get="/web/dashboard/widget/recent-sales"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-72 rounded-2xl"></div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════
       LOW STOCK — only shown when there are alerts
       ═══════════════════════════════════════════════════════════ *@
    <div hx-get="/web/dashboard/widget/low-stock"
         hx-trigger="load" hx-swap="outerHTML">
        <div class="skeleton h-40 rounded-2xl"></div>
    </div>

</div>

@* ── Modal container for HTMX-loaded modals ───────────────── *@
<div id="modal-container"></div>

@* ── Toast container (defined in _Layout, confirmed here) ─── *@
@* Toasts are handled by Alpine.js in _Layout.cshtml.
   Server sets X-Toast-Message header after mutations. *@

@* ── KPI Drilldown JavaScript ─────────────────────────────── *@
<script>
    (function() {
        let activeType = null;
        let isLoading = false;
        const panel = document.getElementById('kpi-drilldown-panel');
        const inner = document.getElementById('kpi-drilldown-panel-inner');

        // ── Skeleton with exact row count ─────────────────────
        function skeletonHTML(rowCount) {
            const count = Math.max(0, rowCount);
            const rows = [];
            for (let i = 0; i < count; i++) {
                rows.push(`
                <div class="drilldown-skeleton-row">
                    <div style="flex:1;">
                        <span class="skeleton-line" style="width:${60 + (i % 5) * 8}%;display:block;margin-bottom:6px;"></span>
                        <span class="skeleton-line" style="width:${35 + (i % 5) * 6}%;height:10px;display:block;"></span>
                    </div>
                    <span class="skeleton-line" style="width:56px;height:22px;border-radius:9999px;"></span>
                </div>`);
            }
            return `<div class="drilldown-skeleton">
                <div class="drilldown-skeleton-header">
                    <span class="skeleton-line" style="width:20px;height:20px;border-radius:50%;"></span>
                    <span class="skeleton-line" style="width:120px;"></span>
                    <span class="skeleton-line" style="width:60px;margin-left:auto;"></span>
                </div>
                ${rows.join('')}
            </div>`;
        }

        // ── Placeholder skeleton (before we know row count) ───
        function placeholderSkeleton() {
            return `<div class="drilldown-skeleton">
                <div class="drilldown-skeleton-header">
                    <span class="skeleton-line" style="width:20px;height:20px;border-radius:50%;"></span>
                    <span class="skeleton-line" style="width:120px;"></span>
                    <span class="skeleton-line" style="width:60px;margin-left:auto;"></span>
                </div>
                <div class="flex items-center justify-center py-10" style="color: var(--meta);">
                    <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                </div>
            </div>`;
        }

        // ── Count rows in response HTML ───────────────────────
        function countRowsInHTML(html) {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const rows = doc.querySelectorAll('.table-tonal > div');
            return rows.length;
        }

        // ── Reveal real content with entrance animations ──────
        function revealContent(html) {
            inner.innerHTML = html;
            isLoading = false;
            const content = inner.querySelector('#kpi-drilldown-content');
            if (content) {
                content.classList.add('drilldown-content-entering');
            }
            const rows = inner.querySelectorAll('.table-tonal > div');
            rows.forEach((row, i) => {
                row.classList.add('drilldown-row-stagger');
                row.style.animationDelay = (i * 60) + 'ms';
            });
        }

        // ── Fetch drilldown, match skeleton to real row count ─
        async function loadDrilldown(url) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('HTTP ' + response.status);
                const html = await response.text();
                const rowCount = countRowsInHTML(html);

                // Show skeleton with the EXACT number of rows that will appear
                inner.innerHTML = skeletonHTML(rowCount);

                // Let the skeleton breathe so the user sees the transition
                await new Promise(r => setTimeout(r, 450));

                // Reveal the real content with staggered entrance
                revealContent(html);
            } catch (err) {
                isLoading = false;
                inner.innerHTML = `<div class="rounded-2xl p-8 text-center" style="background: var(--surface-container-lowest); color: var(--danger);">
                    <p class="text-sm font-semibold">Error al cargar</p>
                    <p class="text-xs mt-1" style="color: var(--meta);">Intenta de nuevo</p>
                </div>`;
                console.error('Drilldown load error:', err);
            }
        }

        // ── Transition out existing content ───────────────────
        function transitionOutContent(callback) {
            const existing = inner.querySelector('#kpi-drilldown-content');
            if (existing) {
                existing.classList.add('drilldown-content-exiting');
                setTimeout(callback, 130);
            } else {
                callback();
            }
        }

        window.openKpiDrilldown = function(type, btn) {
            // Toggle: if same type is clicked, close
            if (activeType === type && panel.style.display !== 'none' && !isLoading) {
                closeKpiDrilldown();
                return;
            }

            // Highlight the active card
            document.querySelectorAll('#kpi-cards .group').forEach(c => {
                c.style.outline = '';
                c.style.outlineOffset = '';
            });
            const card = btn.closest('.group');
            if (card) {
                card.style.outline = '2px solid var(--primary)';
                card.style.outlineOffset = '-2px';
            }

            const url = '/web/dashboard/widget/kpi-drilldown/' + type;
            const isSwitching = activeType !== null && activeType !== type;
            activeType = type;
            isLoading = true;

            if (isSwitching && panel.style.display !== 'none') {
                // Switching KPI types: fade out old → placeholder → fetch → skeleton → reveal
                transitionOutContent(function() {
                    inner.innerHTML = placeholderSkeleton();
                    loadDrilldown(url);
                });
                return;
            }

            // First open: show placeholder, slide panel open, then fetch
            inner.innerHTML = placeholderSkeleton();
            panel.style.display = 'block';
            requestAnimationFrame(() => {
                panel.classList.add('drilldown-open');
            });
            loadDrilldown(url);
        };

        window.closeKpiDrilldown = function() {
            activeType = null;
            isLoading = false;
            panel.classList.remove('drilldown-open');
            document.querySelectorAll('#kpi-cards .group').forEach(c => {
                c.style.outline = '';
                c.style.outlineOffset = '';
            });
            setTimeout(() => {
                if (!panel.classList.contains('drilldown-open')) {
                    panel.style.display = 'none';
                    inner.innerHTML = '';
                }
            }, 350);
        };

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && panel.style.display !== 'none') {
                closeKpiDrilldown();
            }
        });

        // Re-highlight active KPI card after HTMX refresh
        document.addEventListener('htmx:afterSwap', function(e) {
            if (e.detail.target.id === 'kpi-cards' && activeType) {
                const buttons = document.querySelectorAll('#kpi-cards [onclick*="openKpiDrilldown"]');
                buttons.forEach(b => {
                    const onclick = b.getAttribute('onclick') || '';
                    if (onclick.includes("'" + activeType + "'")) {
                        const card = b.closest('.group');
                        if (card) {
                            card.style.outline = '2px solid var(--primary)';
                            card.style.outlineOffset = '-2px';
                        }
                    }
                });
            }
        });
    })();
</script>
