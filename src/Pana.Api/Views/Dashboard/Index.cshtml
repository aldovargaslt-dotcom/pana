@* Views/Dashboard/Index.cshtml — Production-ready KPI Dashboard *@
@model Pana.Api.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var now = DateTime.Now;
    var todayName = now.ToString("dddd, d 'de' MMMM 'de' yyyy",
        new System.Globalization.CultureInfo("es-MX"));
    string greeting;
    if (now.Hour < 12)
        greeting = "Buenos días";
    else if (now.Hour < 18)
        greeting = "Buenas tardes";
    else
        greeting = "Buenas noches";
}

<div class="max-w-7xl mx-auto space-y-5 fade-in">

    @* ── Welcome header ─────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
                @greeting, <span class="text-gradient">@Model.TenantName</span> 👋
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
                @todayName
            </p>
        </div>
        <div class="flex items-center gap-3">
            @* System status *@
            <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500
                        bg-white dark:bg-gray-800 rounded-lg px-3 py-1.5 shadow-card border border-gray-100 dark:border-gray-700">
                <span class="pulse-dot"></span> Sistema en línea
            </div>
            @* New sale quick action *@
            <button hx-get="/sales/create-form" hx-target="#modal-container"
                    class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-700
                           focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500
                           active:bg-brand-800 rounded-lg text-sm font-semibold text-white
                           shadow-soft hover:shadow-glow transition-all duration-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nueva venta
            </button>
        </div>
    </div>

    @* ── Daily context bar (HTMX-loaded) ────────────────────── *@
    <div hx-get="/web/dashboard/widget/daily-context"
         hx-trigger="load"
         hx-swap="innerHTML">
        <div class="skeleton h-10 rounded-xl"></div>
    </div>

    @* ── KPI stat cards (HTMX-loaded, auto-refresh every 60s) ─ *@
    <div hx-get="/web/dashboard/widget/kpi-cards"
         hx-trigger="load"
         hx-swap="outerHTML">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            @for (int i = 0; i < 4; i++)
            {
                <div class="skeleton h-28 rounded-2xl"></div>
            }
        </div>
    </div>

    @* ── Main content grid ──────────────────────────────────── *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        @* Sales trend chart (spans 2 cols on large screens) *@
        <div class="lg:col-span-2" hx-get="/web/dashboard/widget/sales-trend"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-80 rounded-2xl"></div>
        </div>

        @* Recent sales *@
        <div hx-get="/web/dashboard/widget/recent-sales"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-80 rounded-2xl"></div>
        </div>
    </div>

    @* ── Bottom row: Low stock + Quick actions ──────────────── *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        @* Low stock alerts *@
        <div hx-get="/web/dashboard/widget/low-stock"
             hx-trigger="load" hx-swap="outerHTML">
            <div class="skeleton h-64 rounded-2xl"></div>
        </div>

        @* Quick actions *@
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-card border border-gray-100 dark:border-gray-700 p-6">
            <h2 class="font-semibold text-gray-800 dark:text-white mb-4">⚡ Acciones rápidas</h2>
            <div class="grid grid-cols-2 gap-3">
                @* New Sale *@
                <button hx-get="/sales/create-form" hx-target="#modal-container"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          bg-gradient-to-br from-emerald-50 to-emerald-100/50 dark:from-emerald-500/10 dark:to-emerald-500/5
                          border border-emerald-100 dark:border-emerald-500/20
                          hover:border-emerald-200 dark:hover:border-emerald-500/40
                          hover:shadow-sm transition-all duration-200 group">
                    <div class="p-2.5 bg-emerald-500 rounded-xl text-white
                                group-hover:scale-110 transition-transform duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </div>
                    <span class="text-sm font-medium text-emerald-700 dark:text-emerald-400">Nueva venta</span>
                </button>

                @* New Product *@
                <a href="/products"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          bg-gradient-to-br from-brand-50 to-brand-100/50 dark:from-brand-500/10 dark:to-brand-500/5
                          border border-brand-100 dark:border-brand-500/20
                          hover:border-brand-200 dark:hover:border-brand-500/40
                          hover:shadow-sm transition-all duration-200 group">
                    <div class="p-2.5 bg-brand-500 rounded-xl text-white
                                group-hover:scale-110 transition-transform duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    </div>
                    <span class="text-sm font-medium text-brand-700 dark:text-brand-400">Productos</span>
                </a>

                @* Daily Production *@
                <button hx-get="/operations/daily-production-form" hx-target="#modal-container"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          bg-gradient-to-br from-amber-50 to-amber-100/50 dark:from-amber-500/10 dark:to-amber-500/5
                          border border-amber-100 dark:border-amber-500/20
                          hover:border-amber-200 dark:hover:border-amber-500/40
                          hover:shadow-sm transition-all duration-200 group">
                    <div class="p-2.5 bg-amber-500 rounded-xl text-white
                                group-hover:scale-110 transition-transform duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <span class="text-sm font-medium text-amber-700 dark:text-amber-400">Producción diaria</span>
                </button>

                @* Inventory *@
                <a href="/inventory"
                   class="flex flex-col items-center gap-2 p-4 rounded-xl
                          bg-gradient-to-br from-purple-50 to-purple-100/50 dark:from-purple-500/10 dark:to-purple-500/5
                          border border-purple-100 dark:border-purple-500/20
                          hover:border-purple-200 dark:hover:border-purple-500/40
                          hover:shadow-sm transition-all duration-200 group">
                    <div class="p-2.5 bg-purple-500 rounded-xl text-white
                                group-hover:scale-110 transition-transform duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <span class="text-sm font-medium text-purple-700 dark:text-purple-400">Inventario</span>
                </a>
            </div>
        </div>
    </div>

</div>

@* ── Modal container for HTMX-loaded modals ───────────────── *@
<div id="modal-container"></div>

@* ── Toast container (defined in _Layout, confirmed here) ─── *@
@* Toasts are handled by Alpine.js in _Layout.cshtml.
   Server sets X-Toast-Message header after mutations. *@
