@model Pana.Api.Web.ViewModels.DashboardViewModel

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
        <p class="text-gray-500 mt-1">@Model.TenantName — Resumen del día</p>
    </div>

    @* Stats row *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        @await Component.InvokeAsync("StatCard", new {
            label = "Ventas hoy",
            value = "$0",
            trend = "up",
            trendValue = "+0%",
            icon = "money",
            hxGet = "/web/dashboard/widget/sales-chart"
        })

        @await Component.InvokeAsync("StatCard", new {
            label = "Productos",
            value = "—",
            icon = "box",
            hxGet = "/web/dashboard/widget/product-count"
        })

        @await Component.InvokeAsync("StatCard", new {
            label = "Ventas del mes",
            value = "$0",
            trend = "up",
            trendValue = "+0%",
            icon = "chart"
        })

        @await Component.InvokeAsync("StatCard", new {
            label = "Margen promedio",
            value = "—",
            icon = "trend"
        })
    </div>

    @* Main grid *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        @* Sales chart — spans 2 cols *@
        <div class="lg:col-span-2">
            @await Component.InvokeAsync("Card", new {
                title = "Ventas del día",
                subtitle = DateTime.UtcNow.ToString("dd MMM yyyy"),
                hxGet = "/web/dashboard/widget/sales-chart"
            })
        </div>

        @* Recent activity *@
        <div>
            @await Component.InvokeAsync("Card", new {
                title = "Últimas ventas",
                hxGet = "/web/dashboard/widget/recent-sales"
            })
        </div>

        @* Low stock — spans full width *@
        <div class="lg:col-span-3">
            @await Component.InvokeAsync("Card", new {
                title = "Stock bajo",
                hxGet = "/web/dashboard/widget/low-stock"
            })
        </div>
    </div>
</div>
