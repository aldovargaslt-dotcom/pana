@* Views/Dashboard/_DailyContextBar.cshtml — Weather, day type, payday indicators *@
@model Pana.Api.Application.Common.DailyContextDto?
@{
    // Weather SVG icons (18x18, stroke-based)
    var weatherIcon = Model?.Weather switch
    {
        "frio" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z""/></svg>",
        "templado" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><circle cx=""12"" cy=""12"" r=""5"" stroke-width=""2""/><path stroke-linecap=""round"" stroke-width=""2"" d=""M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42""/></svg>",
        "calor" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z""/><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z""/></svg>",
        "lluvia" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M19 16.9A5 5 0 0018 7h-1.26a8 8 0 10-11.62 9""/><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M13 11l-4 6m6 0l-2 3m4 0l-1 2""/></svg>",
        _ => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M3 15a4 4 0 004 4h9a5 5 0 10-4.5-7.4""/><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M16.5 7.5A4.5 4.5 0 0012 3a4.5 4.5 0 00-4.09 2.8""/></svg>"
    };
    var weatherLabel = Model?.Weather switch
    {
        "frio" => "Frío",
        "templado" => "Templado",
        "calor" => "Calor",
        "lluvia" => "Lluvia",
        _ => "—"
    };
    // Day type SVG icons
    var dayTypeIcon = Model?.DayType switch
    {
        "finde" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z""/></svg>",
        "festivo" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M14.828 14.828a4 4 0 01-5.656 0M9.172 9.172a4 4 0 015.656 0M21 12a9 9 0 11-18 0 9 9 0 0118 0z""/><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M12 8v2m0 4v2m-2-4h2m2 0h-2""/></svg>",
        "vacaciones" => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M3 12l2-2m0 0l7-7 7 7m0 0l2 2M5 10v10a1 1 0 001 1h3m11-1a1 1 0 01-1 1h-3m-4-6a2 2 0 100-4 2 2 0 000 4z""/></svg>",
        _ => @"<svg class=""w-4 h-4"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><rect x=""3"" y=""4"" width=""18"" height=""18"" rx=""2"" ry=""2"" stroke-width=""2""/><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M16 2v4M8 2v4M3 10h18""/></svg>"
    };
    var dayTypeLabel = Model?.DayType switch
    {
        "normal" => "Día normal",
        "finde" => "Fin de semana",
        "festivo" => "Festivo",
        "vacaciones" => "Vacaciones",
        _ => "—"
    };
    var todayName = DateTime.Now.ToString("dddd, d 'de' MMMM",
        new System.Globalization.CultureInfo("es-MX"));
}

<div id="daily-context"
     class="flex flex-wrap items-center gap-2 sm:gap-3 px-4 py-2.5 rounded-xl shadow-ambient text-sm"
     style="background: var(--glass-bg); backdrop-filter: blur(var(--glass-blur)); -webkit-backdrop-filter: blur(var(--glass-blur));"
     hx-get="/web/dashboard/widget/daily-context" hx-trigger="every 300s" hx-swap="outerHTML">
    @* Date *@
    <span class="inline-flex items-center gap-1 font-medium" style="color: var(--muted);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 2v4M8 2v4M3 10h18"/></svg>
        @todayName
    </span>
    <span style="color: var(--meta);">|</span>
    @* Weather *@
    <span class="inline-flex items-center gap-1" style="color: var(--fg-2);">
        @Html.Raw(weatherIcon)
        <span class="font-medium">@weatherLabel</span>
    </span>
    <span style="color: var(--meta);">|</span>
    @* Day type *@
    <span class="inline-flex items-center gap-1" style="color: var(--fg-2);">
        @Html.Raw(dayTypeIcon)
        <span class="font-medium">@dayTypeLabel</span>
    </span>
    @* Payday indicator *@
    @if (Model?.IsPayday == true)
    {
        <span style="color: var(--meta);">|</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
              style="color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Quincena
        </span>
    }
    @* Local event *@
    @if (Model?.HasLocalEvent == true)
    {
        <span style="color: var(--meta);">|</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
              style="color: var(--primary); background: color-mix(in srgb, var(--primary) 10%, transparent);">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2m10 0v2M3 8h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l2 2 4-4"/></svg>
            Evento local
        </span>
    }
    @* School out *@
    @if (Model?.SchoolOut == true)
    {
        <span style="color: var(--meta);">|</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
              style="color: var(--tertiary); background: color-mix(in srgb, var(--tertiary) 12%, transparent);">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            Sin clases
        </span>
    }
    @* Low stock alert *@
    @if (Model?.LowStock == true)
    {
        <span style="color: var(--meta);">|</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
              style="color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            Stock bajo
        </span>
    }
</div>
