@model Pana.Api.Web.ViewModels.ProductFormViewModel
@{
    var isCreate = Model.Id == null;
    var modalId = "product-form-" + Guid.NewGuid().ToString("N")[..6];
}

@* ── Modal wrapper ─────────────────────────────────────────── *@
<div id="@modalId"
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
     x-data="{ open: true }"
     x-show="open"
     x-transition.opacity.duration.200ms
     @@keydown.escape.window="open = false">

    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-0 max-h-[85vh] flex flex-col scale-in"
         @@click.outside="open = false">

        @* Header *@
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800">
                @(isCreate ? "Nuevo Producto" : "Editar Producto")
            </h2>
            <button @@click="open = false"
                    class="p-2 rounded-xl hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6">
            <form hx-post="@(isCreate ? "/products/create" : $"/products/{Model.Id}/edit")"
                  hx-target="@(isCreate ? "#table-body-name" : $"#product-row-{Model.Id}")"
                  hx-swap="@(isCreate ? "innerHTML" : "outerHTML")"
                  class="space-y-5"
                  @@htmx:after-request="if(event.detail.successful) open = false">

                @if (!isCreate)
                {
                    <input type="hidden" name="Id" value="@Model.Id" />
                }

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre del producto</label>
                    <input type="text" name="Name" value="@Model.Name" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                  focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                                  transition-all duration-200"
                           placeholder="Ej. Pan Francés" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">SKU</label>
                    <input type="text" name="Sku" value="@Model.Sku" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm font-mono
                                  focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                                  transition-all duration-200"
                           placeholder="Ej. PAN-001" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Precio de venta</label>
                        <div class="relative">
                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium">$</span>
                            <input type="number" name="Price" value="@Model.Price.ToString("F2")" required step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                          focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                                          transition-all duration-200" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Costo</label>
                        <div class="relative">
                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-medium">$</span>
                            <input type="number" name="Cost" value="@Model.Cost.ToString("F2")" required step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                          focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                                          transition-all duration-200" />
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Descripción</label>
                    <textarea name="Description" rows="3"
                              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm resize-none
                                     focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                                     transition-all duration-200"
                              placeholder="Opcional...">@Model.Description</textarea>
                </div>

                <div class="flex items-center justify-end gap-3 pt-3 border-t border-gray-100">
                    <button type="button" @@click="open = false"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 text-gray-600 hover:bg-gray-100 cursor-pointer active:scale-[0.97]">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white
                                   hover:from-brand-600 hover:to-brand-700 shadow-sm hover:shadow-md
                                   cursor-pointer active:scale-[0.97]">
                        @(isCreate ? "Crear Producto" : "Guardar Cambios")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
