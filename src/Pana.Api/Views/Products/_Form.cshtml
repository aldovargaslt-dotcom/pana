@model Pana.Api.Web.ViewModels.ProductFormViewModel
@{
    var isCreate = Model.Id == null;
    var modalId = "product-form-" + Guid.NewGuid().ToString("N")[..6];
}

@* ── Modal wrapper ─────────────────────────────────────────── *@
<div id="@modalId"
     style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)"
     onclick="if(event.target===this)this.remove()">

    <div style="background:var(--surface-container-lowest);border-radius:16px;box-shadow:var(--elev-modal);width:100%;max-width:32rem;max-height:85vh;display:flex;flex-direction:column"
         onclick="event.stopPropagation()">

        @* Header — tonal separation, no border *@
        <div class="flex items-center justify-between px-6 py-4 rounded-t-2xl"
             style="background: var(--surface-container-low);">
            <h2 class="text-lg font-semibold" style="color: var(--fg);">
                @(isCreate ? "Nuevo Producto" : "Editar Producto")
            </h2>
            <button onclick="document.getElementById('@modalId').remove()"
                    class="p-2 rounded-xl transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                    onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* Body *@
        <div class="overflow-y-auto p-6">
            <form hx-post="@(isCreate ? "/products/create" : $"/products/{Model.Id}/edit")"
                  hx-target="@(isCreate ? "#table-body-name" : $"#product-row-{Model.Id}")"
                  hx-swap="@(isCreate ? "innerHTML" : "outerHTML")"
                  hx-on::after-request="if(event.detail.successful) document.getElementById('@modalId').remove()"
                  class="space-y-5">

                @if (!isCreate)
                {
                    <input type="hidden" name="Id" value="@Model.Id" />
                }

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Nombre del producto</label>
                    <input type="text" name="Name" value="@Model.Name" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"
                           placeholder="Ej. Pan Francés" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">SKU</label>
                    <input type="text" name="Sku" value="@Model.Sku" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm font-mono focus:outline-none focus:ring-2 transition-all duration-200"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"
                           placeholder="Ej. PAN-001" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Precio de venta</label>
                        <div class="relative">
                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-sm font-medium" style="color: var(--meta);">$</span>
                            <input type="number" name="Price" value="@Model.Price.ToString("F2")" required step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-2.5 rounded-xl text-sm focus:outline-none transition-all duration-200"
                                   style="background: var(--surface-container-high); color: var(--fg);"
                                   onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                   onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Costo</label>
                        <div class="relative">
                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-sm font-medium" style="color: var(--meta);">$</span>
                            <input type="number" name="Cost" value="@Model.Cost.ToString("F2")" required step="0.01" min="0"
                                   class="w-full pl-8 pr-4 py-2.5 rounded-xl text-sm focus:outline-none transition-all duration-200"
                                   style="background: var(--surface-container-high); color: var(--fg);"
                                   onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                                   onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Descripción</label>
                    <textarea name="Description" rows="3"
                              class="w-full px-4 py-2.5 rounded-xl text-sm resize-none focus:outline-none transition-all duration-200"
                              style="background: var(--surface-container-high); color: var(--fg);"
                              onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                              onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"
                              placeholder="Opcional...">@Model.Description</textarea>
                </div>

                <div class="flex items-center justify-end gap-3 pt-3" style="background: var(--surface-container-low); margin: 0 -1.5rem -1.5rem; padding: 0.75rem 1.5rem; border-radius: 0 0 16px 16px;">
                    <button type="button" onclick="document.getElementById('@modalId').remove()"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 text-gray-600 hover:bg-gray-100 cursor-pointer active:scale-[0.97]">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white
                                   hover:from-brand-600 hover:to-brand-700 shadow-sm hover:shadow-md
                                   cursor-pointer active:scale-[0.97]">
                        @(isCreate ? "Crear Producto" : "Guardar Cambios")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Close on Escape key *@
<script>
    (function() {
        var modal = document.getElementById('@modalId');
        console.log('[Pana] Modal loaded:', '@modalId', modal);
        if (!modal) return;
        function onKey(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onKey); } }
        document.addEventListener('keydown', onKey);
        new MutationObserver(function() {
            if (!document.getElementById('@modalId')) document.removeEventListener('keydown', onKey);
        }).observe(document.body, { childList: true, subtree: true });
    })();
</script>
