@model Pana.Api.Web.ViewModels.ProductRowViewModel

<tr class="hover:bg-gray-50 transition-colors fade-in"
    id="product-row-@Model.Id">
    <td class="px-4 py-3">
        <p class="font-medium text-gray-900">@Model.Name</p>
        <p class="text-xs text-gray-400">@Model.Sku</p>
    </td>
    <td class="px-4 py-3 text-gray-600">@Model.Sku</td>
    <td class="px-4 py-3 font-medium text-gray-900">$@Model.Price.ToString("N2")</td>
    <td class="px-4 py-3">
        <div class="flex items-center gap-2">
            <span class="@(Model.MarginPercentage >= 30 ? "text-emerald-600" : "text-amber-600") font-medium">
                @Model.MarginPercentage.ToString("F1")%
            </span>
            <span class="text-xs text-gray-400">$@Model.Margin.ToString("N2")</span>
        </div>
    </td>
    <td class="px-4 py-3">
        <pana-badge variant="@(Model.IsActive ? "success" : "default")">
            @(Model.IsActive ? "Activo" : "Inactivo")
        </pana-badge>
    </td>
    <td class="px-4 py-3">
        <div class="flex items-center gap-1">
            <button hx-get="/products/@Model.Id/edit-form"
                    hx-target="#modal-container"
                    class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors"
                    title="Editar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
            </button>
            <button hx-post="/products/@Model.Id/delete"
                    hx-confirm="¿Eliminar @Model.Name?"
                    hx-target="#product-row-@Model.Id"
                    hx-swap="delete swap:0.3s"
                    class="p-1.5 rounded-lg hover:bg-red-50 text-gray-400 hover:text-red-600 transition-colors"
                    title="Eliminar">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
            </button>
        </div>
    </td>
</tr>
