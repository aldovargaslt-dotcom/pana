@* Products/_TableRow.cshtml — Individual product card for HTMX *@
@model Pana.Api.Web.ViewModels.ProductRowViewModel

<div class="product-card group rounded-2xl overflow-hidden shadow-ambient transition-all duration-200
            hover:shadow-modal hover:-translate-y-0.5 fade-in"
     style="background: var(--surface-container-lowest);"
     id="product-card-@Model.Id">
    @* Product image — real photo or bakery placeholder *@
    @{
        var trColors = new[] {
            ("#c44b3c", "#f0c9b0"), ("#d4982a", "#fce4b8"),
            ("#a0522d", "#e8c9a0"), ("#8b6b3c", "#dcc8a0"),
            ("#b85c38", "#f0d0b8"), ("#9e7c4a", "#e8d5b8"),
            ("#c4784a", "#f5dcc8"), ("#7a5c3c", "#d4c0a0")
        };
        var trColorIdx = Math.Abs(Model.Name.GetHashCode()) % trColors.Length;
        var (trBg, trFg) = trColors[trColorIdx];
        var trInit = Model.Name.Length >= 2 ? Model.Name[..2].ToUpper() : Model.Name.ToUpper();
        var trHasImage = !string.IsNullOrEmpty(Model.ImageUrl);
    }
    <div class="w-full aspect-[3/4] flex items-center justify-center relative overflow-hidden"
         style="@(trHasImage ? "" : $"background: linear-gradient(135deg, {trBg}, {trFg});")">
        @if (trHasImage)
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
        }
        else
        {
            <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle at 20px 20px, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 30px 30px;"></div>
            <span class="relative text-4xl font-extrabold tracking-tight opacity-80 select-none" style="color: @trBg; filter: brightness(0.4);">@trInit</span>
        }
        @* Quick actions overlay on hover *@
        <div class="absolute inset-0 flex items-center justify-center gap-2
                    opacity-0 group-hover:opacity-100 transition-opacity duration-200"
             style="background: rgba(28,28,25,0.4); backdrop-filter: blur(2px);">
            <button hx-get="/products/@Model.Id/edit-form"
                    hx-target="#modal-container"
                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                    style="background: var(--surface-container-lowest); color: var(--fg);"
                    title="Editar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
            <button hx-post="/products/@Model.Id/delete"
                    hx-confirm="¿Eliminar @Model.Name?"
                    hx-target="#product-card-@Model.Id"
                    hx-swap="delete swap:0.3s"
                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                    style="background: var(--surface-container-lowest); color: var(--danger);"
                    title="Eliminar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
        </div>
    </div>

    @* Name + Price + Status — compact row below image *@
    <div class="px-3 py-2.5 space-y-1">
        <h3 class="font-semibold text-sm leading-tight truncate" style="color: var(--fg);">@Model.Name</h3>
        <div class="flex items-center justify-between">
            <span class="font-bold text-base tabular-nums" style="color: var(--primary);">$@Model.Price.ToString("N2")</span>
            <span class="inline-flex items-center gap-1 text-[10px] font-medium" style="color: @(Model.IsActive ? "var(--meta)" : "var(--meta)");">
                <span class="w-1.5 h-1.5 rounded-full" style="background: @(Model.IsActive ? "var(--success)" : "var(--meta)");"></span>@Model.Sku
            </span>
        </div>
    </div>
</div>
