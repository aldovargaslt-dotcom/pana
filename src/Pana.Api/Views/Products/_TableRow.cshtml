@* Products/_TableRow.cshtml — Individual product card for HTMX *@
@model Pana.Api.Web.ViewModels.ProductRowViewModel

<div class="product-card group rounded-2xl p-5 shadow-ambient transition-all duration-200
            hover:shadow-modal hover:-translate-y-0.5 fade-in"
     style="background: var(--surface-container-lowest);"
     id="product-card-@Model.Id">
    @* Product image placeholder *@
    <div class="w-full aspect-[4/3] rounded-xl mb-4 flex items-center justify-center relative overflow-hidden"
         style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
        <svg class="w-12 h-12" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        @* Quick actions overlay on hover *@
        <div class="absolute inset-0 flex items-center justify-center gap-2
                    opacity-0 group-hover:opacity-100 transition-opacity duration-200"
             style="background: rgba(28,28,25,0.4); backdrop-filter: blur(2px);">
            <button hx-get="/products/@Model.Id/edit-form"
                    hx-target="#modal-container"
                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                    style="background: var(--surface-container-lowest); color: var(--fg);"
                    title="Editar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
            <button hx-post="/products/@Model.Id/delete"
                    hx-confirm="¿Eliminar @Model.Name?"
                    hx-target="#product-card-@Model.Id"
                    hx-swap="delete swap:0.3s"
                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                    style="background: var(--surface-container-lowest); color: var(--danger);"
                    title="Eliminar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
        </div>
    </div>

    @* Product name *@
    <h3 class="font-semibold text-lg mb-1" style="color: var(--fg);">@Model.Name</h3>

    @* Price — THE dominant element *@
    <div class="flex items-baseline gap-1 mb-3">
        <span class="text-2xl font-bold" style="color: var(--primary);">$@Model.Price.ToString("N2")</span>
    </div>

    @* Footer row: status + SKU (subtle) *@
    <div class="flex items-center justify-between">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium"
              style="color: @(Model.IsActive ? "var(--success)" : "var(--meta)"); background: color-mix(in srgb, @(Model.IsActive ? "var(--success)" : "var(--meta)") 12%, transparent);">
            <span class="w-1.5 h-1.5 rounded-full" style="background: @(Model.IsActive ? "var(--success)" : "var(--meta)");"></span>
            @(Model.IsActive ? "Activo" : "Inactivo")
        </span>
        <span class="text-xs font-mono" style="color: var(--meta);">@Model.Sku</span>
    </div>
</div>
