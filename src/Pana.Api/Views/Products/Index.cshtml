@model Pana.Api.Web.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Productos";
}

<div class="max-w-7xl mx-auto space-y-6">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                <span class="text-gradient">Productos</span>
            </h1>
            <p class="text-sm text-gray-500 mt-1">@Model.TotalCount productos registrados</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="search" placeholder="Buscar productos..."
                       class="pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm
                              focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-300
                              w-48 sm:w-64 transition-all duration-200" />
            </div>
            <a href="/products/create"
               class="inline-flex items-center gap-2 px-4 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600
                      text-white text-sm font-medium rounded-xl hover:from-brand-600 hover:to-brand-700
                      transition-all duration-200 shadow-sm hover:shadow-md active:scale-[0.98]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nuevo
            </a>
        </div>
    </div>

    @* ── Table ──────────────────────────────────────────────── *@
    <div class="bg-white rounded-2xl shadow-card border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100">
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Producto</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">SKU</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Precio</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Costo</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Margen</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-400 uppercase tracking-wider">Estado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @if (!Model.Products.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center">
                                        <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                    </div>
                                    <p class="text-gray-400 font-medium">No hay productos aún</p>
                                    <p class="text-xs text-gray-300">Crea tu primer producto para empezar</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.Products)
                        {
                            var margin = p.Price > 0 ? ((p.Price - p.Cost) / p.Price * 100) : 0;
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 bg-gradient-to-br from-brand-50 to-brand-100 rounded-lg flex items-center justify-center text-brand-600 font-bold text-xs">
                                            @p.Name[..Math.Min(2, p.Name.Length)].ToUpper()
                                        </div>
                                        <span class="font-medium text-gray-800">@p.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-500 font-mono text-xs">@p.Sku</td>
                                <td class="px-6 py-4 text-right font-medium text-gray-800">$@p.Price.ToString("F2")</td>
                                <td class="px-6 py-4 text-right text-gray-500">$@p.Cost.ToString("F2")</td>
                                <td class="px-6 py-4 text-right">
                                    <span class="@(margin >= 30 ? "text-emerald-600" : margin >= 15 ? "text-amber-600" : "text-red-500") font-medium">
                                        @margin.ToString("F0")%
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full
                                                 bg-emerald-50 text-emerald-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Activo
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Footer *@
        <div class="px-6 py-3 border-t border-gray-100 bg-gray-50/50 flex items-center justify-between">
            <span class="text-xs text-gray-400">Mostrando @Model.Products.Count de @Model.TotalCount productos</span>
            <a href="/" class="text-xs text-brand-600 hover:text-brand-700 font-medium transition-colors">← Dashboard</a>
        </div>
    </div>

</div>
