@model Pana.Api.Web.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Productos";
}

<div class="content-area space-y-5">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Productos</span>
            </h1>
            <p class="text-sm mt-1" style="color: var(--muted);">@Model.TotalCount productos registrados</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="search" name="q" placeholder="Buscar productos..."
                       hx-get="/products/table-rows"
                       hx-trigger="keyup changed delay:300ms"
                       hx-target="#table-body-name"
                       hx-indicator="#table-body-name"
                       class="pl-9 pr-4 py-2.5 rounded-xl text-sm
                              focus:outline-none focus:ring-2 w-48 sm:w-64 transition-all duration-200"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
            </div>
            <button hx-get="/products/create-form"
                    hx-target="#modal-container"
                    class="inline-flex items-center gap-2 px-4 py-2.5 text-white text-sm font-medium rounded-xl
                           transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                    style="background: var(--gradient-primary);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nuevo
            </button>
        </div>
    </div>

    @* ── Table ──────────────────────────────────────────────── *@
    <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr style="background: var(--surface-container-low);">
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Producto</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">SKU</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Precio</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Costo</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Margen</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Estado</th>
                    </tr>
                </thead>
                <tbody id="table-body-name" class="table-tonal"
                       hx-get="/products/table-rows" hx-trigger="product-created from:body">
                    @if (!Model.Products.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-14 h-14 rounded-2xl flex items-center justify-center" style="background: var(--surface-container);">
                                        <svg class="w-7 h-7" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                    </div>
                                    <p class="font-medium" style="color: var(--meta);">No hay productos aún</p>
                                    <p class="text-xs" style="color: var(--meta);">Crea tu primer producto para empezar</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.Products)
                        {
                            var margin = p.Price > 0 ? ((p.Price - p.Cost) / p.Price * 100) : 0;
                            <tr class="hover:bg-[var(--surface-container-low)] transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-lg flex items-center justify-center font-bold text-xs"
                                             style="background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 5%, transparent), color-mix(in srgb, var(--primary) 10%, transparent)); color: var(--primary);">
                                            @p.Name[..Math.Min(2, p.Name.Length)].ToUpper()
                                        </div>
                                        <span class="font-medium" style="color: var(--fg);">@p.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-mono text-xs" style="color: var(--muted);">@p.Sku</td>
                                <td class="px-6 py-4 text-right font-medium" style="color: var(--fg);">$@p.Price.ToString("F2")</td>
                                <td class="px-6 py-4 text-right" style="color: var(--muted);">$@p.Cost.ToString("F2")</td>
                                <td class="px-6 py-4 text-right">
                                    <span class="font-medium" style="color: @(margin >= 30 ? "var(--success)" : margin >= 15 ? "var(--tertiary)" : "var(--danger)");">
                                        @margin.ToString("F0")%
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full"
                                          style="color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);">
                                        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--success);"></span> Activo
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Footer *@
        <div class="px-6 py-3 flex items-center justify-between"
             style="background: var(--surface-container-low); border-top: 1px solid var(--sidebar-border);">
            <span class="text-xs" style="color: var(--meta);">Mostrando @Model.Products.Count de @Model.TotalCount productos</span>
            <a href="/" class="text-xs font-medium transition-colors" style="color: var(--primary);">← Dashboard</a>
        </div>
    </div>

</div>
