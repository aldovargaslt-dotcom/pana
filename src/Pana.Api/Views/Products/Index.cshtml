@* Products/Index.cshtml — Square-style card grid v2 *@
@model Pana.Api.Web.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Productos";
}

<div class="content-area space-y-5 fade-in">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Productos</span>
            </h1>
            <p class="text-sm mt-1" style="color: var(--muted);">@Model.TotalCount productos en catálogo</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="search" name="q" placeholder="Buscar productos..."
                       hx-get="/products/table-rows"
                       hx-trigger="keyup changed delay:300ms"
                       hx-target="#product-grid"
                       hx-indicator="#product-grid"
                       class="pl-9 pr-4 py-2.5 rounded-xl text-sm
                              focus:outline-none focus:ring-2 w-48 sm:w-64 transition-all duration-200"
                       style="background: var(--surface-container-high); color: var(--fg);"
                       onfocus="this.style.background='var(--primary-fixed)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--primary) 20%, transparent)'"
                       onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
            </div>
            <button hx-get="/products/create-form"
                    hx-target="#modal-container"
                    class="inline-flex items-center gap-2 px-5 py-3 text-white text-sm font-semibold rounded-xl
                           transition-all duration-200 shadow-ambient hover:shadow-modal active:scale-[0.98]"
                    style="background: var(--gradient-primary);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nuevo producto
            </button>
        </div>
    </div>

    @* ── Catalog sub-navigation ─────────────────────────────── *@
    <div class="flex items-center gap-2">
        <span class="px-4 py-2 rounded-xl text-sm font-semibold text-white shadow-ambient" style="background: var(--gradient-primary);">Productos</span>
        <a href="/raw-materials" class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200" style="color: var(--fg-2); background: var(--surface-container-low);" onmouseover="this.style.background='var(--surface-container)'" onmouseout="this.style.background='var(--surface-container-low)'">Materias Primas</a>
        <a href="/recipes" class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200" style="color: var(--fg-2); background: var(--surface-container-low);" onmouseover="this.style.background='var(--surface-container)'" onmouseout="this.style.background='var(--surface-container-low)'">Recetas</a>
    </div>

    @* ── Product Card Grid ──────────────────────────────────── *@
    <div id="product-grid"
         class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
         hx-get="/products/table-rows" hx-trigger="product-created from:body">
        @if (!Model.Products.Any())
        {
            <div class="col-span-full text-center py-20">
                <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto mb-5"
                     style="background: var(--surface-container);">
                    <svg class="w-10 h-10" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <h2 class="text-lg font-semibold" style="color: var(--fg);">No hay productos aún</h2>
                <p class="text-sm mt-2" style="color: var(--muted);">Creá tu primer producto para empezar a vender</p>
                <button hx-get="/products/create-form"
                        hx-target="#modal-container"
                        class="inline-flex items-center gap-2 mt-5 px-6 py-3 text-white text-sm font-semibold rounded-xl
                               transition-all duration-200 shadow-ambient active:scale-[0.98]"
                        style="background: var(--gradient-primary);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Nuevo producto
                </button>
            </div>
        }
        else
        {
            @foreach (var p in Model.Products)
            {
                <div class="product-card group rounded-2xl p-5 shadow-ambient transition-all duration-200
                            hover:shadow-modal hover:-translate-y-0.5"
                     style="background: var(--surface-container-lowest);"
                     id="product-card-@p.Id">
                    @* Product image placeholder *@
                    <div class="w-full aspect-[4/3] rounded-xl mb-4 flex items-center justify-center relative overflow-hidden"
                         style="background: linear-gradient(135deg, var(--surface-container-low), var(--surface-container));">
                        <svg class="w-12 h-12" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        @* Quick actions overlay on hover *@
                        <div class="absolute inset-0 flex items-center justify-center gap-2
                                    opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                             style="background: rgba(28,28,25,0.4); backdrop-filter: blur(2px);">
                            <button hx-get="/products/@p.Id/edit-form"
                                    hx-target="#modal-container"
                                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                                    style="background: var(--surface-container-lowest); color: var(--fg);"
                                    title="Editar">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </button>
                            <button hx-post="/products/@p.Id/delete"
                                    hx-confirm="¿Eliminar @p.Name?"
                                    hx-target="#product-card-@p.Id"
                                    hx-swap="delete swap:0.3s"
                                    class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform hover:scale-110"
                                    style="background: var(--surface-container-lowest); color: var(--danger);"
                                    title="Eliminar">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        </div>
                    </div>

                    @* Product name *@
                    <h3 class="font-semibold text-lg mb-1" style="color: var(--fg);">@p.Name</h3>

                    @* Price — THE dominant element *@
                    <div class="flex items-baseline gap-1 mb-3">
                        <span class="text-2xl font-bold" style="color: var(--primary);">$@p.Price.ToString("N2")</span>
                    </div>

                    @* Footer row: status + SKU (subtle) *@
                    <div class="flex items-center justify-between">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium"
                              style="color: var(--success); background: color-mix(in srgb, var(--success) 12%, transparent);">
                            <span class="w-1.5 h-1.5 rounded-full" style="background: var(--success);"></span>
                            Activo
                        </span>
                        <span class="text-xs font-mono" style="color: var(--meta);">@p.Sku</span>
                    </div>
                </div>
            }
        }
    </div>

    @* ── Footer ─────────────────────────────────────────────── *@
    <div class="flex items-center justify-between text-sm">
        <span style="color: var(--meta);">@Model.Products.Count de @Model.TotalCount productos</span>
        <a href="/" class="font-medium transition-colors" style="color: var(--primary);">← Dashboard</a>
    </div>

</div>

<div id="modal-container"></div>
