@* Views/Activity/ScheduledOrders.cshtml — Pre-orders / Scheduled Orders View *@
@model Pana.Api.Web.ViewModels.ActivityViewModel
@{
    ViewData["Title"] = "Actividad — Pre-órdenes";
}

<div class="content-area space-y-5 fade-in">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Actividad</span>
            </h1>
            <p class="text-sm mt-0.5" style="color: var(--muted);">Pre-órdenes programadas</p>
        </div>
        <a href="/pos"
           class="inline-flex items-center gap-2 px-4 py-2 text-white text-sm font-medium rounded-xl
                  transition-all duration-200 shadow-ambient hover:shadow-modal active:scale-[0.98]"
           style="background: var(--gradient-primary);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            Nueva pre-orden
        </a>
    </div>

    @* ── Activity layout: sidebar + content ─────────────────── *@
    <div class="flex flex-col lg:flex-row gap-5">
        @* Left navigation *@
        <div class="lg:w-56 flex-shrink-0">
            @await Component.InvokeAsync("ActivitySidebar")
        </div>

        @* Main content *@
        <div class="flex-1 min-w-0 space-y-5">
            @* ── Stats cards ──────────────────────────────────── *@
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                <div class="rounded-xl p-4 shadow-ambient" style="background: var(--surface-container-lowest);">
                    <p class="text-xs" style="color: var(--muted);">Total pre-órdenes</p>
                    <p class="text-2xl font-bold mt-1" style="color: var(--fg);">@Model.ScheduledOrders.Count</p>
                </div>
                <div class="rounded-xl p-4 shadow-ambient" style="background: var(--surface-container-lowest);">
                    <p class="text-xs" style="color: var(--muted);">Por confirmar</p>
                    <p class="text-2xl font-bold mt-1" style="color: var(--tertiary);">@Model.ScheduledOrders.Count(o => o.Status == "Draft")</p>
                </div>
                <div class="rounded-xl p-4 shadow-ambient" style="background: var(--surface-container-lowest);">
                    <p class="text-xs" style="color: var(--muted);">En producción</p>
                    <p class="text-2xl font-bold mt-1" style="color: var(--primary);">@Model.ScheduledOrders.Count(o => o.Status is "InProduction" or "Confirmed")</p>
                </div>
                <div class="rounded-xl p-4 shadow-ambient" style="background: var(--surface-container-lowest);">
                    <p class="text-xs" style="color: var(--muted);">Valor total</p>
                    <p class="text-2xl font-bold mt-1" style="color: var(--fg);">$@Model.ScheduledOrders.Sum(o => o.TotalAmount).ToString("N2")</p>
                </div>
            </div>

            @* ── Scheduled orders table ──────────────────────── *@
            <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
                @if (!Model.ScheduledOrders.Any())
                {
                    <div class="text-center py-16">
                        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                             style="background: var(--surface-container);">
                            <svg class="w-8 h-8" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <p class="font-medium" style="color: var(--meta);">Sin pre-órdenes activas</p>
                        <p class="text-xs mt-1" style="color: var(--meta);">Las pre-órdenes creadas desde el POS aparecerán aquí</p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr style="background: var(--surface-container-low);">
                                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Cliente</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Teléfono</th>
                                    <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Programada</th>
                                    <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Total</th>
                                    <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Anticipo</th>
                                    <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Saldo</th>
                                    <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Estado</th>
                                    <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Pago</th>
                                    <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);"></th>
                                </tr>
                            </thead>
                            <tbody class="table-tonal">
                                @foreach (var item in Model.ScheduledOrders)
                                {
                                    var (statusColor, statusBg) = item.Status switch
                                    {
                                        "Confirmed" => ("var(--primary)", "color-mix(in srgb, var(--primary) 12%, transparent)"),
                                        "InProduction" => ("var(--tertiary)", "color-mix(in srgb, var(--tertiary) 12%, transparent)"),
                                        "Ready" => ("var(--success)", "color-mix(in srgb, var(--success) 12%, transparent)"),
                                        _ => ("var(--meta)", "color-mix(in srgb, var(--meta) 12%, transparent)")
                                    };
                                    var statusLabel = item.Status switch
                                    {
                                        "Confirmed" => "Confirmada",
                                        "InProduction" => "En producción",
                                        "Ready" => "Lista",
                                        "Draft" => "Borrador",
                                        _ => item.Status
                                    };
                                    var (payColor, payBg) = item.PaymentStatus switch
                                    {
                                        "Paid" => ("var(--success)", "color-mix(in srgb, var(--success) 12%, transparent)"),
                                        "PartiallyPaid" => ("var(--tertiary)", "color-mix(in srgb, var(--tertiary) 12%, transparent)"),
                                        _ => ("var(--meta)", "color-mix(in srgb, var(--meta) 12%, transparent)")
                                    };
                                    var payLabel = item.PaymentStatus switch
                                    {
                                        "Paid" => "Pagado",
                                        "PartiallyPaid" => "Parcial",
                                        _ => "Pendiente"
                                    };

                                    <tr class="transition-colors"
                                        onmouseover="this.style.background='var(--surface-container-low)'"
                                        onmouseout="this.style.background='transparent'">
                                        <td class="px-6 py-3.5">
                                            <p class="font-medium" style="color: var(--fg);">@item.CustomerName</p>
                                            <p class="text-xs font-mono" style="color: var(--meta);">@item.OrderLabel</p>
                                        </td>
                                        <td class="px-6 py-3.5">
                                            <span style="color: var(--fg-2);">@(item.CustomerPhone ?? "—")</span>
                                        </td>
                                        <td class="px-6 py-3.5">
                                            @if (item.ScheduledDate.HasValue)
                                            {
                                                <p class="text-xs" style="color: var(--fg-2);">@item.ScheduledDate.Value.ToString("dd/MM/yyyy")</p>
                                                <p class="text-xs font-medium" style="color: var(--primary);">@item.ScheduledDate.Value.ToString("HH:mm")</p>
                                            }
                                            else
                                            {
                                                <span style="color: var(--meta);">—</span>
                                            }
                                        </td>
                                        <td class="px-6 py-3.5 text-right">
                                            <span class="font-semibold" style="color: var(--fg);">$@item.TotalAmount.ToString("N2")</span>
                                            <p class="text-xs" style="color: var(--meta);">@item.ItemCount items</p>
                                        </td>
                                        <td class="px-6 py-3.5 text-right">
                                            <span style="color: var(--fg-2);">$@item.DepositAmount.ToString("N2")</span>
                                        </td>
                                        <td class="px-6 py-3.5 text-right">
                                            <span style="color: @(item.BalanceDue > 0 ? "var(--danger)" : "var(--fg-2)");">$@item.BalanceDue.ToString("N2")</span>
                                        </td>
                                        <td class="px-6 py-3.5 text-center">
                                            <span class="inline-block text-xs px-2.5 py-1 rounded-full font-medium"
                                                  style="color: @statusColor; background: @statusBg;">@statusLabel</span>
                                        </td>
                                        <td class="px-6 py-3.5 text-center">
                                            <span class="inline-block text-xs px-2.5 py-1 rounded-full font-medium"
                                                  style="color: @payColor; background: @payBg;">@payLabel</span>
                                        </td>
                                        <td class="px-6 py-3.5 text-right">
                                            <button hx-get="/sales/@item.Id"
                                                    hx-target="#modal-container"
                                                    class="p-1.5 rounded-lg transition-colors"
                                                    style="color: var(--meta);"
                                                    onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                                                    onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'"
                                                    title="Ver detalle">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                                </svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* ── Summary ───────────────────────────────────────── *@
            <div class="flex items-center justify-between text-sm">
                <span style="color: var(--muted);">@Model.ScheduledOrders.Count pre-órdenes activas</span>
                <span style="color: var(--muted);">
                    Saldo pendiente total: <strong style="color: var(--danger);">$@Model.ScheduledOrders.Sum(o => o.BalanceDue).ToString("N2")</strong>
                </span>
            </div>
        </div>
    </div>
</div>
