@model Pana.Api.Web.ViewModels.WasteIndexViewModel
@{
    ViewData["Title"] = "Desperdicios";
}

<div class="w-full space-y-5">

    @* ── Header ─────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2" style="color: var(--fg);">
                <span class="text-gradient">Desperdicios</span>
            </h1>
            <p class="text-sm mt-1" style="color: var(--muted);">Registro de mermas y desperdicios</p>
        </div>
        <button hx-get="/waste/record-form"
                hx-target="#modal-container"
                class="inline-flex items-center gap-2 px-4 py-2.5 text-white text-sm font-medium rounded-xl
                       transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                style="background: var(--danger);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Registrar desperdicio
        </button>
    </div>

    @* ── Categories ─────────────────────────────────────────── *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var cat in Model.Categories)
        {
            <div class="rounded-2xl shadow-ambient p-5" style="background: var(--surface-container-lowest);">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                         style="background: color-mix(in srgb, var(--danger) 12%, transparent); color: var(--danger);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </div>
                    <h3 class="font-semibold" style="color: var(--fg);">@cat.Name</h3>
                </div>
                @if (cat.Subcategories.Count > 0)
                {
                    <div class="flex flex-wrap gap-1.5 mt-2">
                        @foreach (var sub in cat.Subcategories)
                        {
                            <span class="px-2.5 py-1 text-xs font-medium rounded-lg" style="background: var(--surface-container); color: var(--fg-2);">@sub.Name</span>
                        }
                    </div>
                }
                @if (cat.Description != null)
                {
                    <p class="text-xs mt-2" style="color: var(--meta);">@cat.Description</p>
                }
            </div>
        }
    </div>

    @* ── Recent Records ─────────────────────────────────────── *@
    <div class="rounded-2xl shadow-ambient overflow-hidden" style="background: var(--surface-container-lowest);">
        <div class="px-6 py-4" style="background: var(--surface-container-low);">
            <h2 class="font-semibold" style="color: var(--fg);">Registros recientes</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr style="background: var(--surface-container-low);">
                        <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Producto</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Categoría</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Cantidad</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Motivo</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider" style="color: var(--muted);">Fecha</th>
                    </tr>
                </thead>
                <tbody id="waste-table-body" class="table-tonal"
                       hx-get="/waste/table-rows" hx-trigger="waste-recorded from:body">
                    @if (!Model.RecentRecords.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-16 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-14 h-14 rounded-2xl flex items-center justify-center" style="background: var(--surface-container);">
                                        <svg class="w-7 h-7" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </div>
                                    <p class="font-medium" style="color: var(--meta);">Sin registros aún</p>
                                    <p class="text-xs" style="color: var(--meta);">Registrá tu primer desperdicio</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in Model.RecentRecords)
                        {
                            <tr class="transition-colors" onmouseover="this.style.background='var(--surface-container-low)'" onmouseout="this.style.background='transparent'">
                                <td class="px-6 py-3 font-medium" style="color: var(--fg);">@r.ProductName</td>
                                <td class="px-6 py-3">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full"
                                          style="color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);">
                                        @r.CategoryName
                                    </span>
                                </td>
                                <td class="px-6 py-3 text-right font-medium" style="color: var(--danger);">@r.Quantity</td>
                                <td class="px-6 py-3" style="color: var(--muted);">@(r.Reason ?? "—")</td>
                                <td class="px-6 py-3 text-right text-xs" style="color: var(--meta);">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
