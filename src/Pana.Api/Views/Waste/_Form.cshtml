@model Pana.Api.Web.ViewModels.WasteRecordFormViewModel
@{
    var products = ViewBag.Products as List<dynamic>;
    var categories = ViewBag.Categories as List<Pana.Api.Application.Inventory.WasteCategoryDto>;
    var modalId = "waste-form-" + Guid.NewGuid().ToString("N")[..6];
}

<div id="@modalId"
     style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)"
     onclick="if(event.target===this)this.remove()">

    <div style="background:var(--surface-container-lowest);border-radius:16px;box-shadow:var(--elev-modal);width:100%;max-width:32rem;max-height:85vh;display:flex;flex-direction:column"
         onclick="event.stopPropagation()">

        <div class="flex items-center justify-between px-6 py-4 rounded-t-2xl"
             style="background: var(--surface-container-low);">
            <h2 class="text-lg font-semibold" style="color: var(--fg);">Registrar desperdicio</h2>
            <button onclick="document.getElementById('@modalId').remove()"
                    class="p-2 rounded-xl transition-colors"
                    style="color: var(--meta);"
                    onmouseover="this.style.background='var(--surface-container)'; this.style.color='var(--fg-2)'"
                    onmouseout="this.style.background='transparent'; this.style.color='var(--meta)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="overflow-y-auto p-6">
            <form hx-post="/waste/record"
                  hx-target="#waste-table-body"
                  hx-swap="innerHTML"
                  hx-on::after-request="if(event.detail.successful) document.getElementById('@modalId').remove()"
                  class="space-y-5">

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Producto</label>
                    <select name="ProductId" required
                            class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                            style="background: var(--surface-container-high); color: var(--fg);"
                            onfocus="this.style.background='color-mix(in srgb, var(--danger) 8%, transparent)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--danger) 20%, transparent)'"
                            onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'">
                        <option value="">Seleccionar producto...</option>
                        @foreach (var p in products!)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Cantidad desperdiciada</label>
                    <input type="number" name="Quantity" value="@Model.Quantity.ToString("F2")"
                           step="0.01" min="0.01" required
                           class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                           style="background: var(--surface-container-high); color: var(--fg);"
                           onfocus="this.style.background='color-mix(in srgb, var(--danger) 8%, transparent)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--danger) 20%, transparent)'"
                           onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Categoría</label>
                    <select name="WasteCategoryId"
                            class="w-full px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:ring-2"
                            style="background: var(--surface-container-high); color: var(--fg);"
                            onfocus="this.style.background='color-mix(in srgb, var(--danger) 8%, transparent)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--danger) 20%, transparent)'"
                            onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'">
                        <option value="">Sin categoría...</option>
                        @foreach (var cat in categories!)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1.5" style="color: var(--fg-2);">Motivo (opcional)</label>
                    <textarea name="Reason" rows="2"
                              class="w-full px-4 py-2.5 rounded-xl text-sm resize-none focus:outline-none focus:ring-2"
                              style="background: var(--surface-container-high); color: var(--fg);"
                              onfocus="this.style.background='color-mix(in srgb, var(--danger) 8%, transparent)'; this.style.boxShadow='0 0 0 2px color-mix(in srgb, var(--danger) 20%, transparent)'"
                              onblur="this.style.background='var(--surface-container-high)'; this.style.boxShadow='none'"
                              placeholder="Ej. Producto vencido, error de producción...">@Model.Reason</textarea>
                </div>

                <div class="flex items-center justify-end gap-3 pt-3" style="border-top: 1px solid var(--sidebar-border);">
                    <button type="button" onclick="document.getElementById('@modalId').remove()"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 cursor-pointer active:scale-[0.97]"
                            style="color: var(--fg-2);"
                            onmouseover="this.style.background='var(--surface-container)'"
                            onmouseout="this.style.background='transparent'">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-semibold rounded-xl
                                   transition-all duration-200 shadow-ambient hover:shadow-ambient active:scale-[0.98]"
                            style="background: var(--danger);">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Registrar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function() {
        var modal = document.getElementById('@modalId');
        if (!modal) return;
        function onKey(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onKey); } }
        document.addEventListener('keydown', onKey);
        new MutationObserver(function() {
            if (!document.getElementById('@modalId')) document.removeEventListener('keydown', onKey);
        }).observe(document.body, { childList: true, subtree: true });
    })();
</script>
