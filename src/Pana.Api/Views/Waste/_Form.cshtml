@model Pana.Api.Web.ViewModels.WasteRecordFormViewModel
@{
    var products = ViewBag.Products as List<dynamic>;
    var categories = ViewBag.Categories as List<Pana.Api.Application.Inventory.WasteCategoryDto>;
    var modalId = "waste-form-" + Guid.NewGuid().ToString("N")[..6];
}

<div id="@modalId"
     style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)"
     onclick="if(event.target===this)this.remove()">

    <div style="background:white;border-radius:16px;box-shadow:0 25px 50px -12px rgba(0,0,0,0.25);width:100%;max-width:32rem;max-height:85vh;display:flex;flex-direction:column"
         onclick="event.stopPropagation()">

        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800">Registrar desperdicio</h2>
            <button onclick="document.getElementById('@modalId').remove()"
                    class="p-2 rounded-xl hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="overflow-y-auto p-6">
            <form hx-post="/waste/record"
                  hx-target="#waste-table-body"
                  hx-swap="innerHTML"
                  hx-on::after-request="if(event.detail.successful) document.getElementById('@modalId').remove()"
                  class="space-y-5">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Producto</label>
                    <select name="ProductId" required
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                   focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:border-red-300">
                        <option value="">Seleccionar producto...</option>
                        @foreach (var p in products!)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Cantidad desperdiciada</label>
                    <input type="number" name="Quantity" value="@Model.Quantity.ToString("F2")"
                           step="0.01" min="0.01" required
                           class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                  focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:border-red-300" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Categoría</label>
                    <select name="WasteCategoryId"
                            class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm
                                   focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:border-red-300">
                        <option value="">Sin categoría...</option>
                        @foreach (var cat in categories!)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Motivo (opcional)</label>
                    <textarea name="Reason" rows="2"
                              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm resize-none
                                     focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:border-red-300"
                              placeholder="Ej. Producto vencido, error de producción...">@Model.Reason</textarea>
                </div>

                <div class="flex items-center justify-end gap-3 pt-3 border-t border-gray-100">
                    <button type="button" onclick="document.getElementById('@modalId').remove()"
                            class="inline-flex items-center justify-center gap-2 rounded-xl font-semibold text-sm
                                   transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-1
                                   px-4 py-2.5 text-gray-600 hover:bg-gray-100 cursor-pointer active:scale-[0.97]">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-red-500 to-red-600
                                   text-white text-sm font-semibold rounded-xl hover:from-red-600 hover:to-red-700
                                   transition-all duration-200 shadow-sm hover:shadow-md active:scale-[0.98]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Registrar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function() {
        var modal = document.getElementById('@modalId');
        if (!modal) return;
        function onKey(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onKey); } }
        document.addEventListener('keydown', onKey);
        new MutationObserver(function() {
            if (!document.getElementById('@modalId')) document.removeEventListener('keydown', onKey);
        }).observe(document.body, { childList: true, subtree: true });
    })();
</script>
