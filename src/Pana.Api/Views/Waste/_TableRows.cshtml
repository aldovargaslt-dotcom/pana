@model List<Pana.Api.Web.ViewModels.WasteRecordViewModel>

@if (!Model.Any())
{
    <tr>
        <td colspan="5" class="px-6 py-16 text-center">
            <div class="flex flex-col items-center gap-3">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center" style="background: var(--surface-container);">
                    <svg class="w-7 h-7" style="color: var(--meta);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </div>
                <p class="font-medium" style="color: var(--meta);">Sin registros aún</p>
            </div>
        </td>
    </tr>
}
else
{
    @foreach (var r in Model)
    {
        <tr class="transition-colors fade-in"
            onmouseover="this.style.background='var(--surface-container-low)'"
            onmouseout="this.style.background='transparent'">
            <td class="px-6 py-3 font-medium" style="color: var(--fg);">@r.ProductName</td>
            <td class="px-6 py-3">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full"
                      style="color: var(--danger); background: color-mix(in srgb, var(--danger) 12%, transparent);">
                    @r.CategoryName
                </span>
            </td>
            <td class="px-6 py-3 text-right font-medium" style="color: var(--danger);">@r.Quantity</td>
            <td class="px-6 py-3" style="color: var(--muted);">@(r.Reason ?? "—")</td>
            <td class="px-6 py-3 text-right text-xs" style="color: var(--meta);">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
        </tr>
    }
}
