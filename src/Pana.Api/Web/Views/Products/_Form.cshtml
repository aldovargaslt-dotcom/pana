@model Pana.Api.Web.ViewModels.ProductFormViewModel

<form hx-post="@(Model.Id == null ? "/products/create" : $"/products/{Model.Id}/edit")"
      hx-target="@(Model.Id == null ? "#table-body-name" : $"#product-row-{Model.Id}")"
      hx-swap="@(Model.Id == null ? "innerHTML" : "outerHTML")"
      class="space-y-4">

    @if (Model.Id != null)
    {
        <input type="hidden" name="Id" value="@Model.Id" />
    }

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
        <input type="text" name="Name" value="@Model.Name" required
               class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm
                      focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
               placeholder="Ej. Pan Francés" />
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">SKU</label>
        <input type="text" name="Sku" value="@Model.Sku" required
               class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm
                      focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
               placeholder="Ej. PAN-001" />
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Precio de venta</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
                <input type="number" name="Price" value="@Model.Price.ToString("F2")" required step="0.01" min="0"
                       class="w-full pl-7 pr-4 py-2 border border-gray-200 rounded-lg text-sm
                              focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Costo</label>
            <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
                <input type="number" name="Cost" value="@Model.Cost.ToString("F2")" required step="0.01" min="0"
                       class="w-full pl-7 pr-4 py-2 border border-gray-200 rounded-lg text-sm
                              focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" />
            </div>
        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
        <textarea name="Description" rows="3"
                  class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm resize-none
                         focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
                  placeholder="Opcional...">@Model.Description</textarea>
    </div>

    <div class="flex items-center justify-end gap-3 pt-2 border-t border-gray-100">
        <pana-button variant="ghost"
                     @@click="const modal = $el.closest('[id]'); if(modal) Alpine.evaluate(modal, 'open = false')">
            Cancelar
        </pana-button>
        <pana-button type="submit" variant="primary">
            @(Model.Id == null ? "Crear Producto" : "Guardar Cambios")
        </pana-button>
    </div>
</form>
