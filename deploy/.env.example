# Pana Production Environment — EXAMPLE
# Copy to .env and fill with real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=generate-a-strong-random-password-here

# JWT (generate with: openssl rand -base64 48)
JWT__KEY=your-jwt-secret-at-least-32-chars-long
JWT__ISSUER=Pana
JWT__AUDIENCE=Pana

# ASP.NET
ASPNETCORE_ENVIRONMENT=Production
