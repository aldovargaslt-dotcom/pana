## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# .NET
bin/
obj/
*.user
*.suo
*.cache
*.vs/
*.DotSettings.user

# Node
node_modules/

# Environment
.env
.env.local
.env.*.local
deploy/.env

# MCP config (contains credentials)
.vscode/mcp.json

# E2E test artifacts
**/E2E_Screenshots/

# Certbot (SSL)
deploy/certbot/conf/
deploy/certbot/www/

# OS
.DS_Store
Thumbs.db

# Docker
pgdata/
